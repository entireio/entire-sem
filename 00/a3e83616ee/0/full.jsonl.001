onfig, execution_config)\\n@@\\n                 runtime_path_prefix=args.runtime_path_prefix,\\n                 timeout_seconds=args.timeout_seconds,\\n+                execution_config_sha256=execution_config_sha256,\\n@@\\n                 cbm=args.cbm_binary.resolve(strict=True),\\n                 runtime_path_prefix=args.runtime_path_prefix,\\n+                execution_config_sha256=execution_config_sha256,\\n+                model=args.model, max_turns=args.max_turns,\\n+                max_budget_usd=args.max_budget_usd,\\n             )\\n@@\\n def main() -> int:\\n     args = build_parser().parse_args()\\n+    require_protocol_output_compatible(args.output)\\n     manifest = load_manifest(args.manifest)\\n*** End Patch\";\ntext(await tools.apply_patch(patch));\n","internal_chat_message_metadata_passthrough":{"turn_id":"019f756f-5147-7222-9084-187ed68d3651"}}}
