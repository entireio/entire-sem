t.write_bytes(b\\\"modified\\\")\\n+    with pytest.raises(smoke.SmokeError, match=\\\"cache differs\\\"):\\n+        smoke.load_or_setup_treatment_index(\\n+            repository, \\\"entire-graph\\\", output,\\n+            graph=Path(\\\"/runtime/graph\\\"), cbm=Path(\\\"/runtime/cbm\\\"),\\n+            runtime_path_prefix=\\\"\\\", timeout_seconds=30,\\n+            execution_config_sha256=\\\"config\\\", product_binding=product_binding,\\n+        )\\n*** End Patch\";\ntext(await tools.apply_patch(patch));\n","internal_chat_message_metadata_passthrough":{"turn_id":"019f756f-5147-7222-9084-187ed68d3651"}}}
