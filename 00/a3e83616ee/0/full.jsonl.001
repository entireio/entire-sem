{"timestamp":"2026-07-18T14:20:34.009Z","type":"response_item","payload":{"type":"custom_tool_call","id":"ctc_0bd6d73b974b1fab016a5b8bb1f59081918c7ea1c1878a4883","status":"completed","call_id":"call_GZ2tosn6QvhVrFn8kcTGg6sc","name":"exec","input":"const r = await tools.exec_command({cmd:\"sed -n '1,430p' competitive-eval/tools/test_run_agentic_tasks_smoke.py\",workdir:\"/private/tmp/brain-bench-graph-agentic-pilot\",yield_time_ms:10000,max_output_tokens:40000}); text(r.output);\n","internal_chat_message_metadata_passthrough":{"turn_id":"019f756f-5147-7222-9084-187ed68d3651"}}}
{"timestamp":"2026-07-18T14:20:34.239Z","type":"response_item","payload":{"type":"custom_tool_call_output","id":"ctco_019f7599-b03f-7be0-8a19-29c64e20af16","call_id":"call_GZ2tosn6QvhVrFn8kcTGg6sc","output":[{"type":"input_text","text":"Script completed\nWall time 0.2 seconds\nOutput:\n"},{"type":"input_text","text":"import json\nimport subprocess\nfrom pathlib import Path\nfrom types import SimpleNamespace\n\nimport pytest\n\nimport run_agentic_tasks_smoke as smoke\n\n\ndef definition(case_id=\"case\"):\n    return {\n        \"id\": case_id,\n        \"category\": \"symbol_discovery\",\n        \"expected\": {\"kind\": \"definition\", \"name\": \"Target\", \"file_path\": \"src/target.py\"},\n    }\n\n\ndef test_definition_scoring_requires_name_and_repository_relative_file():\n    answer = {\"locations\": [{\"name\": \"class Target(Base)\", \"file_path\": \"./src/target.py\", \"line\": 4}]}\n    score = smoke.score_answer(definition(), answer)\n    assert score == {\n        \"id\": \"case\", \"category\": \"symbol_discovery\", \"passed\": True,\n        \"precision\": 1.0, \"recall\": 1.0, \"matched_items\": 1, \"expected_items\": 1,\n    }\n\n\ndef test_callgraph_scoring_reports_partial_quality():\n    case = {\n        \"id\": \"calls\", \"category\": \"direct_callers_callees\",\n        \"expected\": {\"kind\": \"callgraph\", \"items\": [\n            {\"name\": \"One\", \"file_path\": \"a.go\"}, {\"name\": \"Two\", \"file_path\": \"b.go\"},\n        ]},\n    }\n    answer = {\"locations\": [{\"name\": \"One\", \"file_path\": \"a.go\", \"line\": 1}]}\n    score = smoke.score_answer(case, answer)\n    assert not score[\"passed\"]\n    assert score[\"precision\"] == 1.0\n    assert score[\"recall\"] == 0.5\n\n\ndef test_callgraph_extras_do_not_fail_non_exhaustive_authored_expectations():\n    case = {\n        \"id\": \"calls\", \"category\": \"direct_callers_callees\",\n        \"expected\": {\"kind\": \"callgraph\", \"items\": [{\"name\": \"One\", \"file_path\": \"a.go\"}]},\n    }\n    answer = {\"locations\": [\n        {\"name\": \"One (direct call)\", \"file_path\": \"a.go\", \"line\": 1},\n        {\"name\": \"Another legitimate edge\", \"file_path\": \"b.go\", \"line\": 2},\n    ]}\n    assert smoke.score_answer(case, answer)[\"passed\"]\n\n\ndef test_complete_oracle_callgraph_requires_exact_lines_and_no_extras():\n    case = {\n        \"id\": \"calls\", \"category\": \"direct_callers\",\n        \"expected\": {\"kind\": \"callgraph\", \"complete\": True, \"items\": [\n            {\"name\": \"One\", \"file_path\": \"a.go\", \"line\": 10},\n            {\"name\": \"Two\", \"file_path\": \"b.go\", \"line\": 20},\n        ]},\n    }\n    exact = {\"locations\": [\n        {\"name\": \"One\", \"file_path\": \"a.go\", \"line\": 10},\n        {\"name\": \"Two\", \"file_path\": \"b.go\", \"line\": 20},\n    ]}\n    assert smoke.score_answer(case, exact)[\"passed\"]\n    wrong_line = {\"locations\": [*exact[\"locations\"][:1], {\"name\": \"Two\", \"file_path\": \"b.go\", \"line\": 21}]}\n    assert not smoke.score_answer(case, wrong_line)[\"passed\"]\n    with_extra = {\"locations\": [*exact[\"locations\"], {\"name\": \"Extra\", \"file_path\": \"c.go\", \"line\": 30}]}\n    score = smoke.score_answer(case, with_extra)\n    assert not score[\"passed\"]\n    assert score[\"precision\"] == 2 / 3\n\n\ndef test_path_scoring_is_exact_over_symbol_triples():\n    case = {\n        \"id\": \"path\", \"category\": \"transitive_call_path\",\n        \"expected\": {\"kind\": \"call_path\", \"items\": [{\n            \"caller\": {\"name\": \"A\"}, \"focus\": {\"name\": \"B\"}, \"callee\": {\"name\": \"C\"},\n        }]},\n    }\n    answer = {\"paths\": [{\"caller\": \"A\", \"focus\": \"B\", \"callee\": \"C\"}]}\n    assert smoke.score_answer(case, answer)[\"passed\"]\n\n\ndef test_path_scoring_expands_compact_cartesian_families():\n    case = {\n        \"id\": \"path\", \"category\": \"transitive_call_path\",\n        \"expected\": {\"kind\": \"call_path\", \"items\": [\n            {\"caller\": {\"name\": caller}, \"focus\": {\"name\": \"B\"}, \"callee\": {\"name\": callee}}\n            for caller in (\"A1\", \"A2\") for callee in (\"C1\", \"C2\")\n        ]},\n    }\n    answer = {\"path_families\": [{\"callers\": [\"A1\", \"A2\"], \"focus\": \"B\", \"callees\": [\"C1\", \"C2\"]}]}\n    score = smoke.score_answer(case, answer)\n    assert score[\"passed\"]\n    assert score[\"matched_items\"] == 4\n\n\ndef test_complete_oracle_paths_distinguish_same_named_locations():\n    def loc(file_path, line):\n        return {\"name\": \"parse\", \"file_path\": file_path, \"line\": line}\n\n    case = {\n        \"id\": \"path\", \"category\": \"transitive_call_path\",\n        \"expected\": {\"kind\": \"call_path\", \"complete\": True, \"items\": [\n            {\"caller\": loc(\"a.ts\", 1), \"focus\": loc(\"focus.ts\", 5), \"callee\": loc(\"c.ts\", 9)},\n            {\"caller\": loc(\"b.ts\", 2), \"focus\": loc(\"focus.ts\", 5), \"callee\": loc(\"c.ts\", 9)},\n        ]},\n    }\n    answer = {\"path_families\": [{\n        \"callers\": [loc(\"a.ts\", 1), loc(\"b.ts\", 2)],\n        \"focus\": loc(\"focus.ts\", 5), \"callees\": [loc(\"c.ts\", 9)],\n    }]}\n    assert smoke.score_answer(case, answer)[\"passed\"]\n\n\ndef test_missing_structured_response_fails_every_question():\n    scores = smoke.score_response([definition(\"one\"), definition(\"two\")], None)\n    assert [row[\"passed\"] for row in scores] == [False, False]\n\n\ndef test_structured_result_accepts_cli_object_or_json_string():\n    assert smoke.structured_result({\"structured_output\": {\"answers\": []}}) == {\"answers\": []}\n    assert smoke.structured_result({\"result\": '{\"answers\":[]}'}) == {\"answers\": []}\n\n\ndef test_smoke_audit_accepts_one_preindexed_graph_retrieval(monkeypatch):\n    graph = Path(\"/runtime/entire-graph\")\n    cache = Path(\"/runtime/cache\")\n    monkeypatch.setattr(\n        smoke.runtime,\n        \"audit_treatment\",\n        lambda *_args: {\"passed\": True, \"violations\": []},\n    )\n    monkeypatch.setattr(smoke.runtime, \"bash_command\", lambda tool: tool.get(\"command\", \"\"))\n    search = smoke.audit_smoke_treatment(\n        \"entire-graph\",\n        [{\"command\": f'{graph} search --repo . --query x --format agent --head --profile full --index-all-files --cache-dir \"{cache}\"', \"result\": {\"content\": \"Index: cache-hit (1ms)\"}}],\n        graph, graph_cache=cache,\n    )\n    assert search[\"passed\"]\n    neighbors = smoke.audit_smoke_treatment(\n        \"entire-graph\",\n        [{\"command\": f'{graph} neighbors --repo . --symbol X --format agent --head --profile full --cache-dir \"{cache}\"', \"result\": {\"content\": \"Index: cache-hit (1ms)\"}}],\n        graph, graph_cache=cache,\n    )\n    assert neighbors[\"passed\"]\n    assert neighbors[\"entire_graph_neighbor_calls\"] == 1\n\n\ndef test_smoke_audit_rejects_graph_cache_misses_and_timed_cbm_indexing(monkeypatch):\n    graph = Path(\"/runtime/entire-graph\")\n    monkeypatch.setattr(\n        smoke.runtime,\n        \"audit_treatment\",\n        lambda *_args: {\"passed\": True, \"violations\": []},\n    )\n    monkeypatch.setattr(smoke.runtime, \"bash_command\", lambda tool: tool.get(\"command\", \"\"))\n    invalid = smoke.audit_smoke_treatment(\n        \"entire-graph\",\n        [{\"command\": f\"{graph} neighbors --repo . --symbol X --format agent --worktree --no-cache\"}],\n        graph, graph_cache=Path(\"/runtime/cache\"),\n    )\n    assert \"entire_graph_retrieval_not_bound_to_preindexed_head\" in invalid[\"violations\"]\n    assert \"entire_graph_retrieval_wrong_cache\" in invalid[\"violations\"]\n\n    indexed = smoke.audit_smoke_treatment(\n        \"cbm\",\n        [{\"name\": \"mcp__codebase-memory-mcp__index_repository\", \"input\": {\"repo_path\": \".\"}}],\n        graph, cbm_project=\"project-a\",\n    )\n    assert \"cbm_mutated_index_during_timed_task\" in indexed[\"violations\"]\n    assert \"missing_cbm_retrieval\" in indexed[\"violations\"]\n\n\ndef test_pristine_checkout_rejects_dirty_worktree(tmp_path):\n    checkout = tmp_path / \"repo\"\n    smoke.runtime.checked_git([\"init\", \"--quiet\", str(checkout)])\n    smoke.runtime.checked_git([\"config\", \"user.name\", \"Test\"], cwd=checkout)\n    smoke.runtime.checked_git([\"config\", \"user.email\", \"test@example.com\"], cwd=checkout)\n    (checkout / \"source.py\").write_text(\"value = 1\\n\")\n    smoke.runtime.checked_git([\"add\", \"source.py\"], cwd=checkout)\n    smoke.runtime.checked_git([\"commit\", \"--quiet\", \"-m\", \"base\"], cwd=checkout)\n    head = smoke.runtime.checked_git([\"rev-parse\", \"HEAD\"], cwd=checkout).decode().strip()\n    tree = smoke.runtime.checked_git([\"rev-parse\", \"HEAD^{tree}\"], cwd=checkout).decode().strip()\n    repository = {\"repository\": \"example/repo\", \"commit\": head, \"tree\": tree}\n    smoke.assert_pristine_checkout(checkout, repository)\n    (checkout / \"scratch.txt\").write_text(\"not allowed\\n\")\n    try:\n        smoke.assert_pristine_checkout(checkout, repository)\n    except smoke.SmokeError:\n        pass\n    else:\n        raise AssertionError(\"dirty checkout passed the smoke guard\")\n\n\ndef frozen_repository(tmp_path, system):\n    checkout = tmp_path / \"checkouts\" / system\n    smoke.runtime.checked_git([\"init\", \"--quiet\", str(checkout)])\n    smoke.runtime.checked_git([\"config\", \"user.name\", \"Test\"], cwd=checkout)\n    smoke.runtime.checked_git([\"config\", \"user.email\", \"test@example.com\"], cwd=checkout)\n    (checkout / \"source.py\").write_text(\"value = 1\\n\")\n    smoke.runtime.checked_git([\"add\", \"source.py\"], cwd=checkout)\n    smoke.runtime.checked_git([\"commit\", \"--quiet\", \"-m\", \"base\"], cwd=checkout)\n    head = smoke.runtime.checked_git([\"rev-parse\", \"HEAD\"], cwd=checkout).decode().strip()\n    tree = smoke.runtime.checked_git([\"rev-parse\", \"HEAD^{tree}\"], cwd=checkout).decode().strip()\n    return {\n        \"execution_index\": 1, \"suite\": smoke.ORACLE_SUITE,\n        \"repository\": \"example/repo\", \"commit\": head, \"tree\": tree,\n        \"source_repository\": str(checkout), \"checkouts\": {system: str(checkout)},\n    }, checkout\n\n\ndef test_graph_setup_builds_and_validates_cache_before_task(tmp_path, monkeypatch):\n    repository, checkout = frozen_repository(tmp_path, \"entire-graph\")\n    calls = []\n\n    def fake_run(command, **_kwargs):\n        calls.append(command)\n        cache = Path(command[command.index(\"--cache-dir\") + 1])\n        cache.mkdir(parents=True, exist_ok=True)\n        (cache / \"snapshot.gz\").write_bytes(b\"index\")\n        response = {\n            \"repo_root\": str(checkout.resolve()), \"commit\": repository[\"commit\"],\n            \"tree\": repository[\"tree\"], \"profile\": \"full\",\n            \"index_cache_hit\": len(calls) > 1,\n        }\n        return subprocess.CompletedProcess(command, 0, json.dumps(response).encode(), b\"\")\n\n    monkeypatch.setattr(smoke, \"assert_pristine_checkout\", lambda *_args: None)\n    monkeypatch.setattr(smoke.runtime, \"run_command\", fake_run)\n    setup = smoke.setup_treatment_index(\n        repository, \"entire-graph\", tmp_path / \"output\",\n        graph=Path(\"/runtime/entire-graph\"), cbm=Path(\"/runtime/cbm\"),\n        runtime_path_prefix=\"\", timeout_seconds=30,\n    )\n    assert len(calls) == 2\n    assert setup[\"validation\"][\"validation_cache_hit\"] is True\n    assert setup[\"validation\"][\"cache_inventory\"]\n    assert setup[\"setup_wall_time_ms\"] >= 1\n\n\ndef test_cbm_degraded_setup_fails_before_paid_execution(tmp_path, monkeypatch):\n    repository, _checkout = frozen_repository(tmp_path, \"cbm\")\n\n    def fake_run(command, **_kwargs):\n        response = {\"project\": \"example\", \"status\": \"degraded\", \"nodes\": 0, \"error\": None}\n        return subprocess.CompletedProcess(command, 0, json.dumps(response).encode(), b\"\")\n\n    monkeypatch.setattr(smoke, \"assert_pristine_checkout\", lambda *_args: None)\n    monkeypatch.setattr(smoke.runtime, \"run_command\", fake_run)\n    with pytest.raises(smoke.SmokeError, match=\"not healthy\"):\n        smoke.setup_treatment_index(\n            repository, \"cbm\", tmp_path / \"output\",\n            graph=Path(\"/runtime/entire-graph\"), cbm=Path(\"/runtime/cbm\"),\n            runtime_path_prefix=\"\", timeout_seconds=30,\n        )\n    assert not (tmp_path / \"output\" / \"records\" / \"repo-01\" / \"cbm\" / \"setup.json\").exists()\n\n\ndef test_smoke_sandbox_checkout_is_read_only(tmp_path):\n    output = tmp_path / \"output\"\n    checkout = output / \"checkouts\" / \"file-tools\"\n    checkout.mkdir(parents=True)\n    source = tmp_path / \"corpus\" / \"repos\" / \"example\"\n    source.mkdir(parents=True)\n    command, _ = smoke.runtime.sandboxed_agent_command(\n        [\"/bin/sh\", \"-c\", \"test -r source.py && ! touch forbidden.txt\"],\n        checkout=checkout,\n        output=output,\n        source_repository=source,\n        readable_files=[],\n        readable_paths=[],\n        writable_paths=[],\n        checkout_writable=False,\n    )\n    (checkout / \"source.py\").write_text(\"value = 1\\n\")\n    subprocess.run(command, cwd=checkout, check=True)\n    assert not (checkout / \"forbidden.txt\").exists()\n\n\ndef test_summary_supports_targeted_single_system_followup(tmp_path):\n    record = {\n        \"repository\": \"example/repo\",\n        \"system\": \"entire-graph\",\n        \"scores\": [{\"passed\": True, \"recall\": 1.0, \"precision\": 1.0, \"matched_items\": 1, \"expected_items\": 1}],\n        \"usage\": {},\n        \"tool_call_count\": 2,\n        \"wall_time_ms\": 100,\n        \"reported_total_cost_usd\": 0.01,\n        \"treatment_audit\": {\"passed\": True},\n    }\n    summary = smoke.summarize([record], tmp_path, (\"entire-graph\",))\n    assert list(summary[\"systems\"]) == [\"entire-graph\"]\n    assert summary[\"attempt_count\"] == 1\n    assert summary[\"repository_count\"] == 1\n    assert summary[\"all_question_exact_claim_allowed\"] is False\n    assert summary[\"callgraph_oracle_complete\"] is False\n    assert summary[\"systems\"][\"entire-graph\"][\"retained_assertion_pass_rate\"] == 1.0\n\n\ndef runner_args(tmp_path):\n    binaries = {}\n    for name in (\"claude\", \"graph\", \"cbm\"):\n        path = tmp_path / name\n        path.write_text(\"fixture\\n\")\n        binaries[name] = path\n    return SimpleNamespace(\n        graph_source_head=\"a\" * 40, systems=[\"entire-graph\"], repositories=None,\n        model=\"opus\", max_turns=4, max_budget_usd=1.0, timeout_seconds=30,\n        workers=1, runtime_path_prefix=\"\", claude_binary=binaries[\"claude\"],\n        graph_binary=binaries[\"graph\"], cbm_binary=binaries[\"cbm\"],\n    )\n\n\ndef test_setup_failure_launches_zero_paid_attempts(tmp_path, monkeypatch):\n    prepared = {\n        \"suite\": smoke.ORACLE_SUITE,\n        \"repositories\": [{\n            \"repository\": \"example/repo\", \"system_order\": [\"entire-graph\"] * 3,\n        }],\n    }\n    args = runner_args(tmp_path)\n    launched = []\n    monkeypatch.setattr(smoke.runtime, \"executable_binding\", lambda *_args: {\"sha256\": \"fixture\"})\n    monkeypatch.setattr(\n        smoke, \"load_or_setup_treatment_index\",\n        lambda *_args, **_kwargs: (_ for _ in ()).throw(smoke.SmokeError(\"setup failed\")),\n    )\n    monkeypatch.setattr(smoke, \"execute_one\", lambda *_args, **_kwargs: launched.append(True))\n    with pytest.raises(smoke.SmokeError, match=\"setup failed\"):\n        smoke.run(prepared, tmp_path / \"output\", args)\n    assert launched == []\n\n\ndef test_preindexed_runner_rejects_legacy_evidence_directory(tmp_path, monkeypatch):\n    output = tmp_path / \"output\"\n    output.mkdir()\n    smoke.canonical_write(output / \"execution-config.json\", {\"schema_version\": 1})\n    args = runner_args(tmp_path)\n    monkeypatch.setattr(smoke.runtime, \"executable_binding\", lambda *_args: {\"sha256\": \"fixture\"})\n    prepared = {\"suite\": smoke.ORACLE_SUITE, \"repositories\": []}\n    with pytest.raises(smoke.SmokeError, match=\"legacy evidence directory\"):\n        smoke.run(prepared, output, args)\n\n\ndef test_prompt_defines_file_level_and_imported_path_semantics():\n    repository = {\"cases\": [{\"id\": \"case\", \"question\": \"Question?\"}]}\n    prompt = smoke.prompt_for(repository, \"file-tools\", Path(\"/graph\"))\n    assert \"file-level caller\" in prompt\n    assert \"imported or re-exported callee endpoints remain valid\" in prompt\n    assert \"path_families\" in prompt\n    assert \"Cartesian product\" in prompt\n\n\ndef test_oracle_prompt_requires_location_aware_complete_answers():\n    repository = {\"oracle_complete\": True, \"cases\": [{\"id\": \"case\", \"question\": \"Question?\"}]}\n    prompt = smoke.prompt_for(repository, \"file-tools\", Path(\"/graph\"))\n    assert \"four questions\" in prompt\n    assert \"complete compiler-resolved set\" in prompt\n    assert \"Every caller, focus, and callee\" in prompt\n\n\ndef test_both_frozen_smoke_manifests_load():\n    retained = smoke.load_manifest(smoke.DEFAULT_MANIFEST)\n    oracle = smoke.load_manifest(\n        smoke.ROOT / \"competitive-eval\" / \"oracle-agentic-overlay\" / \"manifest.json\"\n    )\n    assert retained[\"suite\"] == smoke.SUITE\n    assert oracle[\"suite\"] == smoke.ORACLE_SUITE\n    converted = smoke.oracle_case(oracle[\"repositories\"][0][\"cases\"][0])\n    assert converted[\"expected\"][\"kind\"] == \"definition\"\n    assert converted[\"expected\"][\"symbol_kind\"] == \"method\"\n"}],"internal_chat_message_metadata_passthrough":{"turn_id":"019f756f-5147-7222-9084-187ed68d3651"}}}
