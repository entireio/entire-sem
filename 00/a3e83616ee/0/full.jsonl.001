{"timestamp":"2026-07-18T14:16:07.240Z","type":"response_item","payload":{"type":"custom_tool_call","id":"ctc_0bd6d73b974b1fab016a5b8aa7332c8191b1015a087f801ced","status":"completed","call_id":"call_lphiRp5wTiOV9MHhJTwJjFsA","name":"exec","input":"const r = await tools.exec_command({cmd:\"sed -n '430,1120p' competitive-eval/tools/run_agentic_tasks_smoke.py\",workdir:\"/private/tmp/brain-bench-graph-agentic-pilot\",yield_time_ms:10000,max_output_tokens:50000}); text(r.output);\n","internal_chat_message_metadata_passthrough":{"turn_id":"019f756f-5147-7222-9084-187ed68d3651"}}}
{"timestamp":"2026-07-18T14:16:07.441Z","type":"response_item","payload":{"type":"custom_tool_call_output","id":"ctco_019f7595-9e11-73a3-8bd5-cc1cb8e54085","call_id":"call_lphiRp5wTiOV9MHhJTwJjFsA","output":[{"type":"input_text","text":"Script completed\nWall time 0.2 seconds\nOutput:\n"},{"type":"input_text","text":"    return [score_answer(case, by_id.get(case[\"id\"])) for case in cases]\n\n\ndef assert_pristine_checkout(checkout: Path, repository: dict[str, Any]) -> None:\n    head = runtime.checked_git([\"rev-parse\", \"HEAD\"], cwd=checkout).decode().strip()\n    tree = runtime.checked_git([\"rev-parse\", \"HEAD^{tree}\"], cwd=checkout).decode().strip()\n    status = runtime.checked_git([\"status\", \"--porcelain=v1\", \"--untracked-files=all\"], cwd=checkout)\n    if head != repository[\"commit\"] or tree != repository[\"tree\"] or status.strip():\n        raise SmokeError(\n            f\"agent checkout is not pristine for {repository['repository']}: \"\n            f\"head={head} tree={tree} status={status.decode('utf-8', 'replace')!r}\"\n        )\n\n\ndef treatment_paths(\n    repository: dict[str, Any], system: str, output: Path,\n) -> tuple[Path, Path, Path, Path, Path]:\n    record_root = output / \"records\" / f\"repo-{repository['execution_index']:02d}\" / system\n    graph_cache = record_root / \"graph-cache\"\n    cbm_cache = record_root / \"cbm-cache\"\n    temp = record_root / \"agent-temp\"\n    home = record_root / \"agent-home\"\n    return record_root, graph_cache, cbm_cache, temp, home\n\n\ndef cache_inventory(path: Path) -> list[dict[str, Any]]:\n    if not path.is_dir():\n        return []\n    return [\n        {\n            \"path\": str(item.relative_to(path)),\n            \"bytes\": item.stat().st_size,\n            \"sha256\": artifacts.sha256_file(item),\n        }\n        for item in sorted(path.rglob(\"*\"))\n        if item.is_file()\n    ]\n\n\ndef parse_setup_json(process: subprocess.CompletedProcess[bytes], label: str) -> dict[str, Any]:\n    if process.returncode != 0:\n        detail = process.stderr.decode(\"utf-8\", \"replace\")[-2000:]\n        raise SmokeError(f\"{label} failed before paid execution: {detail}\")\n    try:\n        response = json.loads(process.stdout)\n    except json.JSONDecodeError as error:\n        raise SmokeError(f\"{label} did not return JSON\") from error\n    if not isinstance(response, dict):\n        raise SmokeError(f\"{label} returned a non-object response\")\n    return response\n\n\ndef setup_treatment_index(\n    repository: dict[str, Any], system: str, output: Path, *, graph: Path,\n    cbm: Path, runtime_path_prefix: str, timeout_seconds: int,\n) -> dict[str, Any]:\n    \"\"\"Prepare and validate product state before any paid agent process starts.\"\"\"\n    checkout = Path(repository[\"checkouts\"][system]).resolve(strict=True)\n    assert_pristine_checkout(checkout, repository)\n    record_root, graph_cache, cbm_cache, temp, home = treatment_paths(repository, system, output)\n    for path in (record_root, temp, home):\n        path.mkdir(parents=True, exist_ok=True)\n    environment = runtime.runtime_environment(runtime_path_prefix)\n    environment.update({\n        \"HOME\": str(home), \"TMPDIR\": str(temp),\n        \"GIT_CONFIG_GLOBAL\": \"/dev/null\", \"GIT_CONFIG_NOSYSTEM\": \"1\",\n    })\n    started = time.monotonic()\n    project = None\n    validation: dict[str, Any]\n    setup_stdout = b\"\"\n    setup_stderr = b\"\"\n    if system == \"file-tools\":\n        validation = {\"status\": \"not_required\"}\n    elif system == \"entire-graph\":\n        shutil.rmtree(graph_cache, ignore_errors=True)\n        graph_cache.mkdir(parents=True)\n        command = [\n            str(graph), \"index\", \"--repo\", str(checkout), \"--head\",\n            \"--profile\", \"full\", \"--cache-dir\", str(graph_cache), \"--format\", \"json\",\n        ]\n        first = runtime.run_command(command, cwd=checkout, env=environment, timeout=timeout_seconds)\n        setup_stdout += first.stdout\n        setup_stderr += first.stderr\n        first_response = parse_setup_json(first, \"Entire Graph preindex\")\n        second = runtime.run_command(command, cwd=checkout, env=environment, timeout=timeout_seconds)\n        setup_stdout += second.stdout\n        setup_stderr += second.stderr\n        second_response = parse_setup_json(second, \"Entire Graph cache validation\")\n        for response in (first_response, second_response):\n            if (\n                response.get(\"commit\") != repository[\"commit\"]\n                or response.get(\"tree\") != repository[\"tree\"]\n                or response.get(\"profile\") != \"full\"\n                or Path(str(response.get(\"repo_root\") or \"\")).resolve() != checkout\n            ):\n                raise SmokeError(\"Entire Graph preindex provenance does not match the frozen checkout\")\n        if second_response.get(\"index_cache_hit\") is not True:\n            raise SmokeError(\"Entire Graph preindex validation did not hit the prepared cache\")\n        inventory = cache_inventory(graph_cache)\n        if not inventory:\n            raise SmokeError(\"Entire Graph preindex produced no persistent cache\")\n        validation = {\n            \"status\": \"indexed\", \"first_cache_hit\": first_response.get(\"index_cache_hit\"),\n            \"validation_cache_hit\": True, \"cache_inventory\": inventory,\n        }\n    elif system == \"cbm\":\n        shutil.rmtree(cbm_cache, ignore_errors=True)\n        cbm_cache.mkdir(parents=True)\n        environment[\"CBM_CACHE_DIR\"] = str(cbm_cache)\n        payload = json.dumps({\"repo_path\": str(checkout)}, separators=(\",\", \":\"), sort_keys=True)\n        indexed = runtime.run_command(\n            [str(cbm), \"cli\", \"index_repository\", payload],\n            cwd=checkout, env=environment, timeout=timeout_seconds,\n        )\n        setup_stdout += indexed.stdout\n        setup_stderr += indexed.stderr\n        indexed_response = parse_setup_json(indexed, \"Codebase Memory preindex\")\n        project = indexed_response.get(\"project\")\n        if (\n            indexed_response.get(\"status\") != \"indexed\"\n            or not isinstance(project, str) or not project\n            or int(indexed_response.get(\"nodes\") or 0) <= 0\n            or indexed_response.get(\"error\")\n        ):\n            raise SmokeError(f\"Codebase Memory preindex is not healthy: {indexed_response}\")\n        status_payload = json.dumps({\"project\": project}, separators=(\",\", \":\"), sort_keys=True)\n        status = runtime.run_command(\n            [str(cbm), \"cli\", \"index_status\", status_payload],\n            cwd=checkout, env=environment, timeout=timeout_seconds,\n        )\n        setup_stdout += status.stdout\n        setup_stderr += status.stderr\n        status_response = parse_setup_json(status, \"Codebase Memory index validation\")\n        if status_response.get(\"error\") or status_response.get(\"status\") in {\"degraded\", \"missing\", \"corrupt\"}:\n            raise SmokeError(f\"Codebase Memory index validation is not healthy: {status_response}\")\n        inventory = cache_inventory(cbm_cache)\n        if not inventory:\n            raise SmokeError(\"Codebase Memory preindex produced no persistent cache\")\n        validation = {\"status\": \"indexed\", \"project\": project, \"cache_inventory\": inventory}\n    else:\n        raise SmokeError(f\"unknown treatment: {system}\")\n    assert_pristine_checkout(checkout, repository)\n    setup_wall_time_ms = max(1, round((time.monotonic() - started) * 1000))\n    (record_root / \"setup.stdout\").write_bytes(setup_stdout)\n    (record_root / \"setup.stderr\").write_bytes(setup_stderr)\n    record = {\n        \"schema_version\": 1, \"measurement_protocol\": MEASUREMENT_PROTOCOL,\n        \"suite\": repository[\"suite\"], \"repository\": repository[\"repository\"],\n        \"system\": system, \"commit\": repository[\"commit\"], \"tree\": repository[\"tree\"],\n        \"setup_wall_time_ms\": setup_wall_time_ms, \"project\": project,\n        \"validation\": validation,\n    }\n    digest = canonical_write(record_root / \"setup.json\", record)\n    record[\"record_sha256\"] = digest\n    return record\n\n\ndef load_or_setup_treatment_index(\n    repository: dict[str, Any], system: str, output: Path, *, graph: Path,\n    cbm: Path, runtime_path_prefix: str, timeout_seconds: int,\n) -> dict[str, Any]:\n    record_root, graph_cache, cbm_cache, _temp, _home = treatment_paths(repository, system, output)\n    path = record_root / \"setup.json\"\n    if not path.is_file():\n        return setup_treatment_index(\n            repository, system, output, graph=graph, cbm=cbm,\n            runtime_path_prefix=runtime_path_prefix, timeout_seconds=timeout_seconds,\n        )\n    setup = artifacts.read_canonical_json(path, expected_type=dict).document\n    if (\n        setup.get(\"measurement_protocol\") != MEASUREMENT_PROTOCOL\n        or setup.get(\"repository\") != repository[\"repository\"]\n        or setup.get(\"system\") != system\n        or setup.get(\"commit\") != repository[\"commit\"]\n        or setup.get(\"tree\") != repository[\"tree\"]\n    ):\n        raise SmokeError(\"existing setup record does not match the preindexed protocol binding\")\n    if system == \"entire-graph\" and cache_inventory(graph_cache) != setup.get(\"validation\", {}).get(\"cache_inventory\"):\n        raise SmokeError(\"existing Entire Graph cache differs from its validated setup record\")\n    if system == \"cbm\" and cache_inventory(cbm_cache) != setup.get(\"validation\", {}).get(\"cache_inventory\"):\n        raise SmokeError(\"existing Codebase Memory cache differs from its validated setup record\")\n    setup[\"record_sha256\"] = artifacts.sha256_file(path)\n    return setup\n\n\ndef audit_smoke_treatment(\n    system: str, tools: list[dict[str, Any]], graph_binary: Path, *,\n    graph_cache: Path | None = None, cbm_project: str | None = None,\n) -> dict[str, Any]:\n    audit = runtime.audit_treatment(system, tools, graph_binary)\n    executed = [\n        tool for tool in tools\n        if not isinstance(tool.get(\"result\"), dict) or not tool[\"result\"].get(\"is_error\")\n    ]\n    commands = [runtime.bash_command(tool) for tool in executed if runtime.bash_command(tool)]\n    graph_search_commands = [\n        command for command in commands\n        if str(graph_binary) in command and \" search \" in f\" {command} \"\n    ]\n    graph_neighbor_commands = [\n        command for command in commands\n        if str(graph_binary) in command and \" neighbors \" in f\" {command} \"\n    ]\n    graph_retrieval_commands = graph_search_commands + graph_neighbor_commands\n    neighbor_calls = sum(\n        str(graph_binary) in command and \" neighbors \" in f\" {command} \"\n        for command in commands\n    )\n    violations = set(audit[\"violations\"])\n    if system == \"entire-graph\":\n        # The generic pilot audit historically required search specifically.\n        # This suite permits the agent to choose the appropriate Graph\n        # retrieval instead of forcing search + neighbors + verification.\n        violations.discard(\"missing_entire_graph_search\")\n        violations.discard(\"missing_entire_graph_agent_format\")\n        if not graph_retrieval_commands:\n            violations.add(\"missing_entire_graph_retrieval\")\n        accepted_cache_values = {\"$ENTIRE_GRAPH_CACHE_DIR\"}\n        if graph_cache is not None:\n            accepted_cache_values.add(str(graph_cache))\n        for command in graph_retrieval_commands:\n            if \"--head\" not in command or \"--worktree\" in command or \"--no-cache\" in command:\n                violations.add(\"entire_graph_retrieval_not_bound_to_preindexed_head\")\n            if \"--format agent\" not in command and \"--format=agent\" not in command:\n                violations.add(\"entire_graph_retrieval_not_agent_format\")\n            if not any(\n                f'--cache-dir \"{value}\"' in command\n                or f\"--cache-dir '{value}'\" in command\n                or f\"--cache-dir {value}\" in command\n                or f\"--cache-dir={value}\" in command\n                for value in accepted_cache_values\n            ):\n                violations.add(\"entire_graph_retrieval_wrong_cache\")\n        for command in graph_search_commands:\n            if \"--profile full\" not in command and \"--profile=full\" not in command:\n                violations.add(\"entire_graph_search_wrong_profile\")\n            if \"--index-all-files\" not in command:\n                violations.add(\"entire_graph_search_not_query_independent\")\n        for command in graph_neighbor_commands:\n            if \"--profile full\" not in command and \"--profile=full\" not in command:\n                violations.add(\"entire_graph_neighbors_wrong_profile\")\n        for tool in executed:\n            command = runtime.bash_command(tool)\n            if command not in graph_retrieval_commands:\n                continue\n            result = tool.get(\"result\") if isinstance(tool.get(\"result\"), dict) else {}\n            if \"Index: cache-hit\" not in str(result.get(\"content\") or \"\"):\n                violations.add(\"entire_graph_retrieval_cache_miss\")\n    if system == \"cbm\":\n        cbm_tools = [\n            tool for tool in executed\n            if str(tool.get(\"name\") or \"\").startswith(\"mcp__codebase-memory-mcp\")\n        ]\n        retrieval_suffixes = {\n            \"search_graph\", \"query_graph\", \"trace_path\", \"get_code_snippet\",\n            \"get_architecture\", \"search_code\",\n        }\n        retrieval_tools = [\n            tool for tool in cbm_tools\n            if any(str(tool.get(\"name\") or \"\").endswith(suffix) for suffix in retrieval_suffixes)\n        ]\n        if any(\n            str(tool.get(\"name\") or \"\").endswith((\"index_repository\", \"delete_project\"))\n            for tool in cbm_tools\n        ):\n            violations.add(\"cbm_mutated_index_during_timed_task\")\n        if not retrieval_tools:\n            violations.add(\"missing_cbm_retrieval\")\n        if cbm_project and any(\n            (tool.get(\"input\") or {}).get(\"project\") != cbm_project\n            for tool in retrieval_tools\n        ):\n            violations.add(\"cbm_retrieval_used_wrong_project\")\n    if system == \"file-tools\" and neighbor_calls:\n        violations.add(\"baseline_used_graph_product\")\n    audit[\"entire_graph_neighbor_calls\"] = neighbor_calls\n    audit[\"entire_graph_retrieval_calls\"] = len(graph_retrieval_commands)\n    audit[\"violations\"] = sorted(violations)\n    audit[\"passed\"] = not violations\n    return audit\n\n\ndef execute_one(\n    repository: dict[str, Any], system: str, output: Path, *, claude: Path,\n    graph: Path, cbm: Path, model: str, max_turns: int, max_budget_usd: float,\n    timeout_seconds: int, runtime_path_prefix: str, setup: dict[str, Any],\n) -> dict[str, Any]:\n    checkout = Path(repository[\"checkouts\"][system]).resolve(strict=True)\n    assert_pristine_checkout(checkout, repository)\n    record_root, graph_cache, cbm_cache, temp, home = treatment_paths(repository, system, output)\n    for path in (cbm_cache, graph_cache, temp, home / \".claude\"):\n        path.mkdir(parents=True, exist_ok=True)\n    runtime.copy_claude_credentials(home / \".claude\" / \".credentials.json\")\n    mcp = runtime.mcp_config(system, output, cbm, cbm_cache)\n    command = claude_command(\n        claude=claude, model=model, system=system,\n        prompt=prompt_for(repository, system, graph, cbm_project=setup.get(\"project\")),\n        mcp=mcp, graph=graph,\n        max_turns=max_turns, max_budget_usd=max_budget_usd,\n    )\n    command, sandbox_sha = runtime.sandboxed_agent_command(\n        command, checkout=checkout, output=output,\n        source_repository=Path(repository[\"source_repository\"]),\n        readable_files=[claude, graph, cbm, mcp],\n        readable_paths=[Path(row).parent for row in runtime_path_prefix.split(os.pathsep) if row],\n        writable_paths=[cbm_cache, graph_cache, temp, home],\n        checkout_writable=False,\n    )\n    environment = runtime.runtime_environment(runtime_path_prefix)\n    environment.update({\n        \"HOME\": str(home), \"CLAUDE_CONFIG_DIR\": str(home / \".claude\"),\n        \"TMPDIR\": str(temp), \"CLAUDE_CODE_TMPDIR\": str(temp), \"CLAUDE_TMPDIR\": str(temp),\n        \"ENTIRE_GRAPH_CACHE_DIR\": str(graph_cache),\n        \"CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC\": \"1\", \"DISABLE_AUTOUPDATER\": \"1\",\n        \"GIT_CONFIG_GLOBAL\": \"/dev/null\", \"GIT_CONFIG_NOSYSTEM\": \"1\",\n    })\n    started = time.monotonic()\n    timed_out = False\n    try:\n        process = runtime.run_command(command, cwd=checkout, env=environment, timeout=timeout_seconds)\n        stdout, stderr, returncode = process.stdout, process.stderr, process.returncode\n    except subprocess.TimeoutExpired as error:\n        timed_out, stdout, stderr, returncode = True, error.stdout or b\"\", error.stderr or b\"\", 124\n    finally:\n        shutil.rmtree(home, ignore_errors=True)\n    task_wall_time_ms = max(1, round((time.monotonic() - started) * 1000))\n    assert_pristine_checkout(checkout, repository)\n    (record_root / \"transcript.jsonl\").write_bytes(stdout)\n    (record_root / \"stderr.txt\").write_bytes(stderr)\n    parsed = runtime.parse_stream(stdout)\n    response = structured_result(parsed[\"result\"])\n    scores = score_response(repository[\"cases\"], response)\n    audit = audit_smoke_treatment(\n        system, parsed[\"tools\"], graph, graph_cache=graph_cache,\n        cbm_project=setup.get(\"project\"),\n    )\n    if system == \"entire-graph\":\n        before = setup.get(\"validation\", {}).get(\"cache_inventory\") or []\n        after = cache_inventory(graph_cache)\n        if after != before:\n            audit[\"violations\"] = sorted(set(audit[\"violations\"]) | {\"entire_graph_cache_changed_during_task\"})\n            audit[\"passed\"] = False\n    result = parsed.get(\"result\") or {}\n    record = {\n        \"schema_version\": 1, \"suite\": repository[\"suite\"], \"repository\": repository[\"repository\"],\n        \"system\": system, \"model\": model, \"returncode\": returncode, \"timed_out\": timed_out,\n        \"wall_time_ms\": task_wall_time_ms,\n        \"task_wall_time_ms\": task_wall_time_ms,\n        \"setup_wall_time_ms\": setup[\"setup_wall_time_ms\"],\n        \"setup_record_sha256\": setup[\"record_sha256\"],\n        \"measurement_protocol\": MEASUREMENT_PROTOCOL,\n        \"sandbox_profile_sha256\": sandbox_sha, \"treatment_audit\": audit,\n        \"tool_call_count\": len(parsed[\"tools\"]), \"scores\": scores,\n        \"exact_pass_rate\": sum(row[\"passed\"] for row in scores) / len(scores),\n        \"retained_assertion_pass_rate\": (\n            None if repository.get(\"oracle_complete\")\n            else sum(row[\"passed\"] for row in scores) / len(scores)\n        ),\n        \"mean_recall\": sum(row[\"recall\"] for row in scores) / len(scores),\n        \"mean_precision\": sum(row[\"precision\"] for row in scores) / len(scores),\n        \"usage\": result.get(\"usage\") if isinstance(result.get(\"usage\"), dict) else {},\n        \"num_turns\": result.get(\"num_turns\"), \"reported_total_cost_usd\": result.get(\"total_cost_usd\"),\n        \"structured_response_present\": response is not None,\n    }\n    canonical_write(record_root / \"record.json\", record)\n    return record\n\n\ndef recover_existing_attempt(\n    repository: dict[str, Any], system: str, output: Path, *, claude: Path,\n    graph: Path, cbm: Path, runtime_path_prefix: str,\n) -> dict[str, Any] | None:\n    \"\"\"Score an immutable transcript left by a post-execution controller failure.\"\"\"\n    record_root = output / \"records\" / f\"repo-{repository['execution_index']:02d}\" / system\n    record_path = record_root / \"record.json\"\n    if record_path.is_file():\n        return artifacts.read_canonical_json(record_path, expected_type=dict).document\n    transcript = record_root / \"transcript.jsonl\"\n    if not transcript.is_file():\n        return None\n\n    checkout = Path(repository[\"checkouts\"][system]).resolve(strict=True)\n    assert_pristine_checkout(checkout, repository)\n    _record_root, graph_cache, cbm_cache, temp, home = treatment_paths(repository, system, output)\n    setup_path = record_root / \"setup.json\"\n    if not setup_path.is_file():\n        raise SmokeError(\"cannot recover an attempt without its preindex setup record\")\n    setup = artifacts.read_canonical_json(setup_path, expected_type=dict).document\n    mcp = output / \"runtime\" / \"mcp\" / f\"repo-{repository['execution_index']:02d}-{system}.json\"\n    _command, sandbox_sha = runtime.sandboxed_agent_command(\n        [], checkout=checkout, output=output,\n        source_repository=Path(repository[\"source_repository\"]),\n        readable_files=[claude, graph, cbm, mcp],\n        readable_paths=[Path(row).parent for row in runtime_path_prefix.split(os.pathsep) if row],\n        writable_paths=[cbm_cache, graph_cache, temp, home], checkout_writable=False,\n    )\n    parsed = runtime.parse_stream(transcript.read_bytes())\n    response = structured_result(parsed[\"result\"])\n    scores = score_response(repository[\"cases\"], response)\n    audit = audit_smoke_treatment(\n        system, parsed[\"tools\"], graph, graph_cache=graph_cache,\n        cbm_project=setup.get(\"project\"),\n    )\n    result = parsed.get(\"result\") or {}\n    record = {\n        \"schema_version\": 1, \"suite\": repository[\"suite\"],\n        \"repository\": repository[\"repository\"], \"system\": system,\n        \"model\": result.get(\"model\") or \"opus\",\n        \"returncode\": 1 if result.get(\"is_error\") else 0,\n        \"timed_out\": False,\n        \"wall_time_ms\": max(1, int(result.get(\"duration_ms\") or 1)),\n        \"task_wall_time_ms\": max(1, int(result.get(\"duration_ms\") or 1)),\n        \"setup_wall_time_ms\": setup[\"setup_wall_time_ms\"],\n        \"setup_record_sha256\": artifacts.sha256_file(setup_path),\n        \"measurement_protocol\": MEASUREMENT_PROTOCOL,\n        \"sandbox_profile_sha256\": sandbox_sha,\n        \"treatment_audit\": audit,\n        \"tool_call_count\": len(parsed[\"tools\"]), \"scores\": scores,\n        \"exact_pass_rate\": sum(row[\"passed\"] for row in scores) / len(scores),\n        \"retained_assertion_pass_rate\": (\n            None if repository.get(\"oracle_complete\")\n            else sum(row[\"passed\"] for row in scores) / len(scores)\n        ),\n        \"mean_recall\": sum(row[\"recall\"] for row in scores) / len(scores),\n        \"mean_precision\": sum(row[\"precision\"] for row in scores) / len(scores),\n        \"usage\": result.get(\"usage\") if isinstance(result.get(\"usage\"), dict) else {},\n        \"num_turns\": result.get(\"num_turns\"),\n        \"reported_total_cost_usd\": result.get(\"total_cost_usd\"),\n        \"structured_response_present\": response is not None,\n        \"recovered_after_controller_scoring_failure\": True,\n        \"source_transcript_sha256\": artifacts.sha256_file(transcript),\n    }\n    canonical_write(record_path, record)\n    return record\n\n\ndef summarize(\n    records: list[dict[str, Any]], output: Path, systems_to_report: tuple[str, ...] = SYSTEMS,\n) -> dict[str, Any]:\n    oracle_complete = bool(records) and all(row.get(\"suite\") == ORACLE_SUITE for row in records)\n    systems = {}\n    for system in systems_to_report:\n        rows = [row for row in records if row[\"system\"] == system]\n        scores = [score for row in rows for score in row[\"scores\"]]\n        provider_input_tokens = sum(\n            (row[\"usage\"].get(\"input_tokens\") or 0)\n            + (row[\"usage\"].get(\"cache_creation_input_tokens\") or 0)\n            + (row[\"usage\"].get(\"cache_read_input_tokens\") or 0)\n            for row in rows\n        )\n        systems[system] = {\n            \"attempts\": len(rows), \"questions\": len(scores),\n            \"exact_pass_rate\": sum(row[\"passed\"] for row in scores) / len(scores),\n            \"retained_assertion_pass_rate\": (\n                None if oracle_complete else sum(row[\"passed\"] for row in scores) / len(scores)\n            ),\n            \"mean_recall\": sum(row[\"recall\"] for row in scores) / len(scores),\n            \"mean_precision\": sum(row[\"precision\"] for row in scores) / len(scores),\n            \"micro_recall\": sum(row[\"matched_items\"] for row in scores) / sum(row[\"expected_items\"] for row in scores),\n            \"mean_tool_calls\": sum(row[\"tool_call_count\"] for row in rows) / len(rows),\n            \"mean_wall_time_ms\": sum(row.get(\"task_wall_time_ms\", row[\"wall_time_ms\"]) for row in rows) / len(rows),\n            \"mean_task_wall_time_ms\": sum(row.get(\"task_wall_time_ms\", row[\"wall_time_ms\"]) for row in rows) / len(rows),\n            \"mean_setup_wall_time_ms\": sum(row.get(\"setup_wall_time_ms\", 0) for row in rows) / len(rows),\n            \"input_tokens\": sum((row[\"usage\"].get(\"input_tokens\") or 0) for row in rows),\n            \"provider_input_tokens_including_cache\": provider_input_tokens,\n            \"output_tokens\": sum((row[\"usage\"].get(\"output_tokens\") or 0) for row in rows),\n            \"reported_cost_usd\": sum((row.get(\"reported_total_cost_usd\") or 0) for row in rows),\n            \"treatment_compliance_rate\": sum(row[\"treatment_audit\"][\"passed\"] for row in rows) / len(rows),\n        }\n    summary = {\n        \"schema_version\": 1,\n        \"suite\": ORACLE_SUITE if oracle_complete else SUITE,\n        \"development_only\": True,\n        \"confirmatory_use_allowed\": False,\n        \"all_question_exact_claim_allowed\": oracle_complete,\n        \"callgraph_oracle_complete\": oracle_complete,\n        \"repository_count\": len({row[\"repository\"] for row in records if row.get(\"repository\")}) or 3,\n        \"attempt_count\": len(records),\n        \"systems\": systems,\n    }\n    canonical_write(output / \"summary.json\", summary)\n    if oracle_complete:\n        title = \"# Compiler-Oracle Agentic Smoke\"\n        scope = \"Development-only; predefined repositories; Claude Opus; exhaustive expectations for the selected compiler-oracle neighborhoods. Exactness is scoped to those compiled neighborhoods.\"\n        quality_label = \"Exact\"\n    else:\n        title = \"# Retained Tasks Agentic Smoke\"\n        scope = \"Development-only; predefined repositories; Claude Opus; one attempt per selected repository and treatment. Callgraph expectations are retained non-exhaustive assertions, so an all-question exact claim is disallowed.\"\n        quality_label = \"Retained assertions\"\n    lines = [title, \"\", scope, \"\", f\"| System | {quality_label} | Macro recall | Micro recall | Tool calls | Task wall time, preindexed (s) | Setup/index, excluded (s) | Provider input incl. cache | Output tokens | Cost (USD) | Compliance |\", \"| --- | ---: | ---: | ---: | ---: | ---: | ---: | ---: | ---: | ---: | ---: |\"]\n    for system in systems_to_report:\n        row = systems[system]\n        lines.append(f\"| {system} | {row['exact_pass_rate']:.3f} | {row['mean_recall']:.3f} | {row['micro_recall']:.3f} | {row['mean_tool_calls']:.1f} | {row['mean_task_wall_time_ms']/1000:.1f} | {row['mean_setup_wall_time_ms']/1000:.1f} | {row['provider_input_tokens_including_cache']} | {row['output_tokens']} | {row['reported_cost_usd']:.4f} | {row['treatment_compliance_rate']:.3f} |\")\n    (output / \"scoreboard.md\").write_text(\"\\n\".join(lines) + \"\\n\", encoding=\"utf-8\")\n    return summary\n\n\ndef rescore(prepared: dict[str, Any], output: Path) -> dict[str, Any]:\n    repositories = {row[\"repository\"]: row for row in prepared[\"repositories\"]}\n    rescored = []\n    provenance = []\n    for record_path in sorted((output / \"records\").glob(\"repo-*/*/record.json\")):\n        source = artifacts.read_canonical_json(record_path, expected_type=dict).document\n        transcript = record_path.with_name(\"transcript.jsonl\")\n        parsed = runtime.parse_stream(transcript.read_bytes())\n        response = structured_result(parsed[\"result\"])\n        cases = repositories[source[\"repository\"]][\"cases\"]\n        scores = score_response(cases, response)\n        row = dict(source)\n        row[\"scores\"] = scores\n        row[\"exact_pass_rate\"] = sum(score[\"passed\"] for score in scores) / len(scores)\n        row[\"retained_assertion_pass_rate\"] = (\n            None if source.get(\"suite\") == ORACLE_SUITE else row[\"exact_pass_rate\"]\n        )\n        row[\"mean_recall\"] = sum(score[\"recall\"] for score in scores) / len(scores)\n        row[\"mean_precision\"] = sum(score[\"precision\"] for score in scores) / len(scores)\n        rescored.append(row)\n        provenance.append(\n            {\n                \"repository\": source[\"repository\"],\n                \"system\": source[\"system\"],\n                \"source_record_sha256\": artifacts.sha256_file(record_path),\n                \"source_transcript_sha256\": artifacts.sha256_file(transcript),\n            }\n        )\n    if len(rescored) != 9:\n        raise SmokeError(\"rescore requires nine immutable raw attempt records\")\n    summary = summarize(rescored, output / \"rescored\")\n    summary[\"source_provenance\"] = provenance\n    summary[\"scorer_sha256\"] = artifacts.sha256_file(Path(__file__).resolve())\n    summary[\"raw_records_mutated\"] = False\n    canonical_write(output / \"rescored\" / \"summary.json\", summary)\n    return summary\n\n\ndef run(prepared: dict[str, Any], output: Path, args: argparse.Namespace) -> dict[str, Any]:\n    if not isinstance(args.graph_source_head, str) or re.fullmatch(r\"[0-9a-f]{40}\", args.graph_source_head) is None:\n        raise SmokeError(\"run requires --graph-source-head with the exact 40-character product commit\")\n    selected_systems = tuple(args.systems)\n    if not selected_systems or len(set(selected_systems)) != len(selected_systems):\n        raise SmokeError(\"run requires one or more distinct --systems values\")\n    available_repositories = {row[\"repository\"] for row in prepared[\"repositories\"]}\n    selected_repositories = set(args.repositories or available_repositories)\n    unknown_repositories = selected_repositories - available_repositories\n    if unknown_repositories:\n        raise SmokeError(f\"unknown --repositories values: {sorted(unknown_repositories)}\")\n    if args.workers != 1:\n        raise SmokeError(\"preindexed-agentic-v2 requires --workers 1 for uncontended latency measurement\")\n    existing_config = output / \"execution-config.json\"\n    if existing_config.is_file():\n        previous = artifacts.read_canonical_json(existing_config, expected_type=dict).document\n        if previous.get(\"measurement_protocol\") != MEASUREMENT_PROTOCOL:\n            raise SmokeError(\"refusing to run the preindexed protocol in a legacy evidence directory\")\n    execution_config = {\n        \"schema_version\": 1,\n        \"measurement_protocol\": MEASUREMENT_PROTOCOL,\n        \"suite\": prepared[\"suite\"],\n        \"model\": args.model,\n        \"max_turns_per_attempt\": args.max_turns,\n        \"max_budget_usd_per_attempt\": args.max_budget_usd,\n        \"timeout_seconds_per_attempt\": args.timeout_seconds,\n        \"workers\": args.workers,\n        \"systems\": list(selected_systems),\n        \"repositories\": sorted(selected_repositories),\n        \"runtime_path_prefix\": args.runtime_path_prefix,\n        \"graph_source_head\": args.graph_source_head,\n        \"claude\": runtime.executable_binding(args.claude_binary, [\"--version\"]),\n        \"entire_graph\": runtime.executable_binding(args.graph_binary, [\"--version\"]),\n        \"cbm\": runtime.executable_binding(args.cbm_binary, [\"--version\"]),\n        \"runner_sha256\": artifacts.sha256_file(Path(__file__).resolve()),\n    }\n    canonical_write(output / \"execution-config.json\", execution_config)\n    graph = args.graph_binary.resolve(strict=True)\n    cbm = args.cbm_binary.resolve(strict=True)\n    setups_by_key: dict[tuple[str, str], dict[str, Any]] = {}\n    # Fail closed before launching any paid process. Index setup is deliberately\n    # sequential so comparator indexing never competes for local CPU or I/O.\n    for repo in prepared[\"repositories\"]:\n        if repo[\"repository\"] not in selected_repositories:\n            continue\n        for system in selected_systems:\n            setup = load_or_setup_treatment_index(\n                repo, system, output, graph=graph, cbm=cbm,\n                runtime_path_prefix=args.runtime_path_prefix,\n                timeout_seconds=args.timeout_seconds,\n            )\n            setups_by_key[(repo[\"repository\"], system)] = setup\n    records_by_key: dict[tuple[str, str], dict[str, Any]] = {}\n    for repo in prepared[\"repositories\"]:\n        if repo[\"repository\"] not in selected_repositories:\n            continue\n        for system in selected_systems:\n            recovered = recover_existing_attempt(\n                repo, system, output,\n                claude=args.claude_binary.resolve(strict=True),\n                graph=args.graph_binary.resolve(strict=True),\n                cbm=args.cbm_binary.resolve(strict=True),\n                runtime_path_prefix=args.runtime_path_prefix,\n            )\n            if recovered is not None:\n                records_by_key[(repo[\"repository\"], system)] = recovered\n    for round_index in range(3):\n        attempts = [\n            (repo, repo[\"system_order\"][round_index])\n            for repo in prepared[\"repositories\"]\n            if repo[\"repository\"] in selected_repositories\n            and repo[\"system_order\"][round_index] in selected_systems\n            and (repo[\"repository\"], repo[\"system_order\"][round_index]) not in records_by_key\n        ]\n        if not attempts:\n            continue\n        with concurrent.futures.ThreadPoolExecutor(max_workers=min(args.workers, 3)) as executor:\n            futures = {\n                executor.submit(\n                    execute_one, repo, system, output, claude=args.claude_binary.resolve(strict=True),\n                    graph=graph, cbm=cbm,\n                    model=args.model, max_turns=args.max_turns, max_budget_usd=args.max_budget_usd,\n                    timeout_seconds=args.timeout_seconds, runtime_path_prefix=args.runtime_path_prefix,\n                    setup=setups_by_key[(repo[\"repository\"], system)],\n                ): (repo, system) for repo, system in attempts\n            }\n            for future in concurrent.futures.as_completed(futures):\n                repo, system = futures[future]\n                record = future.result()\n                records_by_key[(repo[\"repository\"], system)] = record\n                metric = \"exact\" if repo.get(\"oracle_complete\") else \"retained_assertions\"\n                print(f\"completed {repo['repository']} {system}: {metric}={record['exact_pass_rate']:.3f}\", file=sys.stderr, flush=True)\n    return summarize(list(records_by_key.values()), output, selected_systems)\n\n\ndef build_parser() -> argparse.ArgumentParser:\n    parser = argparse.ArgumentParser(description=__doc__)\n    parser.add_argument(\"command\", choices=(\"prepare\", \"run\", \"rescore\", \"all\"))\n    parser.add_argument(\"--manifest\", type=Path, default=DEFAULT_MANIFEST)\n    parser.add_argument(\"--output\", type=Path, required=True)\n    parser.add_argument(\"--repos-dir\", type=Path, default=Path(\"/private/tmp/entire-graph-agentic-tasks-smoke-repos\"))\n    parser.add_argument(\"--claude-binary\", type=Path, default=Path(shutil.which(\"claude\") or \"/missing/claude\"))\n    parser.add_argument(\"--graph-binary\", type=Path, default=Path(shutil.which(\"entire-graph\") or \"/missing/entire-graph\"))\n    parser.add_argument(\"--cbm-binary\", type=Path, default=Path(shutil.which(\"codebase-memory-mcp\") or \"/missing/codebase-memory-mcp\"))\n    parser.add_argument(\"--model\", default=\"opus\")\n    parser.add_argument(\"--graph-source-head\")\n    parser.add_argument(\"--max-turns\", type=int, default=24)\n    parser.add_argument(\"--max-budget-usd\", type=float, default=5.0)\n    parser.add_argument(\"--timeout-seconds\", type=int, default=1200)\n    parser.add_argument(\"--workers\", type=int, default=1)\n    parser.add_argument(\"--systems\", nargs=\"+\", choices=SYSTEMS, default=list(SYSTEMS))\n    parser.add_argument(\"--repositories\", nargs=\"+\")\n    parser.add_argument(\"--runtime-path-prefix\", default=\"\")\n    return parser\n\n\ndef main() -> int:\n    args = build_parser().parse_args()\n    manifest = load_manifest(args.manifest)\n    if args.command in {\"prepare\", \"all\"}:\n        prepared = prepare(manifest, args.output, args.repos_dir, args.manifest)\n    else:\n        prepared = artifacts.read_canonical_json(args.output / \"runtime-manifest.json\", expected_type=dict).document\n    if args.command in {\"run\", \"all\"}:\n        run(prepared, args.output, args)\n    elif args.command == \"rescore\":\n        rescore(prepared, args.output)\n    return 0\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n"}],"internal_chat_message_metadata_passthrough":{"turn_id":"019f756f-5147-7222-9084-187ed68d3651"}}}
