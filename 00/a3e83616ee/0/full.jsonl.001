               \"properties\": {\n   450\t    audit[\"entire_graph_neighbor_calls\"] = neighbor_calls\n   451\t    audit[\"violations\"] = sorted(violations)\n   452\t    audit[\"passed\"] = not violations\n   453\t    return audit\n   454\t\n   455\t\n   456\tdef execute_one(\n   457\t    repository: dict[str, Any], system: str, output: Path, *, claude: Path,\n   458\t    graph: Path, cbm: Path, model: str, max_turns: int, max_budget_usd: float,\n   459\t    timeout_seconds: int, runtime_path_prefix: str,\n   460\t) -> dict[str, Any]:\n   461\t    checkout = Path(repository[\"checkouts\"][system]).resolve(strict=True)\n   462\t    assert_pristine_checkout(checkout, repository)\n   463\t    record_root = output / \"records\" / f\"repo-{repository['execution_index']:02d}\" / system\n   464\t    record_root.mkdir(parents=True, exist_ok=True)\n   465\t    cache, temp, home = record_root / \"cbm-cache\", record_root / \"agent-temp\", record_root / \"agent-home\"\n   466\t    for path in (cache, temp, home / \".claude\"):\n   467\t        path.mkdir(parents=True, exist_ok=True)\n   468\t    runtime.copy_claude_credentials(home / \".claude\" / \".credentials.json\")\n   469\t    mcp = runtime.mcp_config(system, output, cbm, cache)\n   470\t    command = claude_command(\n   471\t        claude=claude, model=model, system=system,\n   472\t        prompt=prompt_for(repository, system, graph), mcp=mcp, graph=graph,\n   473\t        max_turns=max_turns, max_budget_usd=max_budget_usd,\n   474\t    )\n   475\t    command, sandbox_sha = runtime.sandboxed_agent_command(\n   476\t        command, checkout=checkout, output=output,\n   477\t        source_repository=Path(repository[\"source_repository\"]),\n   478\t        readable_files=[claude, graph, cbm, mcp],\n   479\t        readable_paths=[Path(row).parent for row in runtime_path_prefix.split(os.pathsep) if row],\n   480\t        writable_paths=[cache, temp, home],\n"}],"internal_chat_message_metadata_passthrough":{"turn_id":"