{"timestamp":"2026-07-18T14:16:03.036Z","type":"response_item","payload":{"type":"custom_tool_call_output","id":"ctco_019f7595-8cdc-7b73-9360-fa2097dbbb07","call_id":"call_XZNGq1yF1Gz2JGNQSotIibYY","output":[{"type":"input_text","text":"Script completed\nWall time 0.2 seconds\nOutput:\n"},{"type":"input_text","text":"Warning: truncated output (original token count: 10829)\nTotal output lines: 774\n\ndiff --git a/competitive-eval/tools/run_agentic_tasks_smoke.py b/competitive-eval/tools/run_agentic_tasks_smoke.py\nindex a23fa36..7f45d6e 100644\n--- a/competitive-eval/tools/run_agentic_tasks_smoke.py\n+++ b/competitive-eval/tools/run_agentic_tasks_smoke.py\n@@ -25,6 +25,7 @@ ROOT = Path(__file__).resolve().parents[2]\n DEFAULT_MANIFEST = ROOT / \"competitive-eval\" / \"agentic-tasks-smoke\" / \"manifest.json\"\n SUITE = \"entire_graph_agentic_mini_v1\"\n ORACLE_SUITE = \"entire_graph_oracle_agentic_overlay_v1\"\n+MEASUREMENT_PROTOCOL = \"preindexed-agentic-v2\"\n SYSTEMS = (\"file-tools\", \"entire-graph\", \"cbm\")\n ROTATIONS = (\n     SYSTEMS,\n@@ -235,7 +236,9 @@ ANSWER_SCHEMA = {\n }\n \n \n-def prompt_for(repository: dict[str, Any], system: str, graph_binary: Path) -> str:\n+def prompt_for(\n+    repository: dict[str, Any], system: str, graph_binary: Path, *, cbm_project: str | None = None,\n+) -> str:\n     questions = \"\\n\".join(f\"- `{case['id']}`: {case['question']}\" for case in repository[\"cases\"])\n     if repository.get(\"oracle_complete\"):\n         question_count = \"four\"\n@@ -255,9 +258,14 @@ Do not edit files. Do not use the network, Git history, Git objects, remotes, pa\n     if system == \"file-tools\":\n         treatment = \"Use Claude Code's native Grep, Glob, Read, and Bash tools. Entire Graph and Codebase Memory are unavailable.\"\n     elif system == \"entire-graph\":\n-        treatment = f\"Use normal file tools plus Entire Graph. Invoke `{graph_binary} search --repo . --query \\\"...\\\" --format agent --head` at least once. After locating the symbol that the relationship questions name, invoke `{graph_binary} neighbors --repo . --symbol NAME --file PATH --depth 2 --limit 100 --format agent --head --cache-dir \\\"$TMPDIR/entire-graph-cache\\\"`; use targeted file-tool checks to verify or fill gaps. Do not invoke neighbors for a symbol asked about only by definition, snippet, or code-search questions. Do not stream or dump the full graph.\"\n+        scope_flags = \" --internal-only --exclude-tests\" if repository.get(\"oracle_complete\") else \"\"\n+        treatment = f\"\"\"Entire Graph is already indexed and validated for this exact committed tree. Use normal file tools plus Entire Graph, with Entire Graph as the primary retrieval system. Make at least one successful Entire Graph retrieval call, choosing `search` or `neighbors` according to the question. Use additional Graph calls or targeted file reads only when useful; do not automatically duplicate Graph results with file tools.\n+\n+For search use `{graph_binary} search --repo . --query \\\"...\\\" --format agent --head --profile full --index-all-files --cache-dir \\\"$ENTIRE_GRAPH_CACHE_DIR\\\"`. For a named relationship focus use `{graph_binary} neighbors --repo . --symbol NAME --file PATH --depth 2 --limit 100 --format agent --head --profile full --cache-dir \\\"$ENTIRE_GRAPH_CACHE_DIR\\\"{scope_flags}`. Do not use `--worktree` or `--no-cache`, and do not stream or dump the full graph.\"\"\"\n     elif system == \"cbm\":\n-        treatment = \"Use normal file tools plus Codebase Memory. Index this repository and invoke at least one Codebase Memory retrieval tool, then use any targeted file-tool checks that help.\"\n+        if not cbm_project:\n+            raise SmokeError(\"CBM prompt requires a validated preindexed project\")\n+        treatment = f\"\"\"Codebase Memory project `{cbm_project}` is already indexed and validated. Use normal file tools plus Codebase Memory, with Codebase Memory as the primary retrieval system. Make at least one successful retrieval call against exactly that project. Use additional Codebase Memory calls or targeted file reads only when useful; do not automatically duplicate product results with file tools. Do not invoke `index_repository`, delete the project, or rebuild the index during the task.\"\"\"\n     else:\n         raise SmokeError(f\"unknown treatment: {system}\")\n     return common + treatment\n@@ -433,21 +441,270 @@ def assert_pristine_checkout(checkout: Path, repository: dict[str, Any]) -> None\n         )\n \n \n+def treatment_paths(\n+    repository: dict[str, Any], system: str, output: Path,\n+) -> tuple[Path, Path, Path, Path, Path]:\n+    record_root = output / \"records\" / f\"repo-{repository['execution_index']:02d}\" / system\n+    graph_cache = record_root / \"graph-cache\"\n+    cbm_cache = record_root / \"cbm-cache\"\n+    temp = record_root / \"agent-temp\"\n+    home = record_root / \"agent-home\"\n+    return record_root, graph_cache, cbm_cache, temp, home\n+\n+\n+def cache_inventory(path: Path) -> list[dict[str, Any]]:\n+    if not path.is_dir():\n+        return []\n+    return [\n+        {\n+            \"path\": str(item.relative_to(path)),\n+            \"bytes\": item.stat().st_size,\n+            \"sha256\": artifacts.sha256_file(item),\n+        }\n+        for item in sorted(path.rglob(\"*\"))\n+        if item.is_file()\n+    ]\n+\n+\n+def parse_setup_json(process: subprocess.CompletedProcess[bytes], label: str) -> dict[str, Any]:\n+    if process.returncode != 0:\n+        detail = process.stderr.decode(\"utf-8\", \"replace\")[-2000:]\n+        raise SmokeError(f\"{label} failed before paid execution: {detail}\")\n+    try:\n+        response = json.loads(process.stdout)\n+    except json.JSONDecodeError as error:\n+        raise SmokeError(f\"{label} did not return JSON\") from error\n+    if not isinstance(response, dict):\n+        raise SmokeError(f\"{label} returned a non-object response\")\n+    return response\n+\n+\n+def setup_treatment_index(\n+    repository: dict[str, Any], system: str, output: Path, *, graph: Path,\n+    cbm: Path, runtime_path_prefix: str, timeout_seconds: int,\n+) -> dict[str, Any]:\n+    \"\"\"Prepare and validate product state before any paid agent process starts.\"\"\"\n+    checkout = Path(repository[\"checkouts\"][system]).resolve(strict=True)\n+    assert_pristine_checkout(checkout, repository)\n+    record_root, graph_cache, cbm_cache, temp, home = treatment_paths(repository, system, output)\n+    for path in (record_root, temp, home):\n+        path.mkdir(parents=True, exist_ok=True)\n+    environment = runtime.runtime_environment(runtime_path_prefix)\n+    environment.update({\n+        \"HOME\": str(home), \"TMPDIR\": str(temp),\n+        \"GIT_CONFIG_GLOBAL\": \"/dev/null\", \"GIT_CONFIG_NOSYSTEM\": \"1\",\n+    })\n+    started = time.monotonic()\n+    project = None\n+    validation: dict[str, Any]\n+    setup_stdout = b\"\"\n+    setup_stderr = b\"\"\n+    if system == \"file-tools\":\n+        validation = {\"status\": \"not_required\"}\n+    elif system == \"entire-graph\":\n+        shutil.rmtree(graph_cache, ignore_errors=True)\n+        graph_cache.mkdir(parents=True)\n+        command = [\n+            str(graph), \"index\", \"--repo\", str(checkout), \"--head\",\n+            \"--profile\", \"full\", \"--cache-dir\", str(graph_cache), \"--format\", \"json\",\n+        ]\n+        first = runtime.run_command(command, cwd=checkout, env=environment, timeout=timeout_seconds)\n+        setup_stdout += first.stdout\n+        setup_stderr += first.stderr\n+        first_response = parse_setup_json(first, \"Entire Graph preindex\")\n+        second = runtime.run_command(command, cwd=checkout, env=environment, timeout=timeout_seconds)\n+        setup_stdout += second.stdout\n+        setup_stderr += second.stderr\n+        second_response = parse_setup_json(second, \"Entire Graph cache validation\")\n+        for response in (first_response, second_response):\n+            if (\n+                response.get(\"commit\") != repository[\"commit\"]\n+                or response.get(\"tree\") != repository[\"tree\"]\n+                or response.get(\"profile\") != \"full\"\n+                or Path(str(response.get(\"repo_root\") or \"\")).resolve() != checkout\n+            ):\n+                raise SmokeError(\"Entire Graph preindex provenance does not match the frozen checkout\")\n+        if second_response.get(\"index_cache_hit\") is not True:\n+            raise SmokeError(\"Entire Graph preindex validation did not hit the prepared cache\")\n+        inventory = cache_inventory(graph_cache)\n+        if not inventory:\n+            raise SmokeError(\"Entire Graph preindex produced no persistent cache\")\n+        validation = {\n+            \"status\": \"indexed\", \"first_cache_hit\": first_response.get(\"index_cache_hit\"),\n+            \"validation_cache_hit\": True, \"cache_inventory\": inventory,\n+        }\n+    elif system == \"cbm\":\n+        shutil.rmtree(cbm_cache, ignore_errors=True)\n+        cbm_cache.mkdir(parents=True)\n+        environment[\"CBM_CACHE_DIR\"] = str(cbm_cache)\n+        payload = json.dumps({\"repo_path\": str(checkout)}, separators=(\",\", \":\"), sort_keys=True)\n+        indexed = runtime.run_command(\n+            [str(cbm), \"cli\", \"index_repository\", payload],\n+            cwd=checkout, env=environment, timeout=timeout_seconds,\n+        )\n+        setup_stdout += indexed.stdout\n+        setup_stderr += indexed.stderr\n+        indexed_response = parse_setup_json(indexed, \"Codebase Memory preindex\")\n+        project = indexed_response.get(\"project\")\n+        if (\n+            indexed_response.get(\"status\") != \"indexed\"\n+            or not isinstance(project, str) or not project\n+            or int(indexed_response.get(\"nodes\") or 0) <= 0\n+            or indexed_response.get(\"error\")\n+        ):\n+            raise SmokeError(f\"Codebase Memory preindex is not healthy: {indexed_response}\")\n+        status_payload = json.dumps({\"project\": project}, separators=(\",\", \":\"), sort_keys=True)\n+        status = runtime.run_command(\n+            [str(cbm), \"cli\", \"index_status\", status_payload],\n+            cwd=checkout, env=environment, timeout=timeout_seconds,\n+        )\n+        setup_stdout += status.stdout\n+        setup_stderr += status.stderr\n+        status_response = parse_setup_json(status, \"Codebase Memory index validation\")\n+        if status_response.get(\"error\") or status_response.get(\"status\") in {\"degraded\", \"missing\", \"corrupt\"}:\n+            raise SmokeError(f\"Codebase Memory index validation is not healthy: {status_response}\")\n+        inventory = cache_inventory(cbm_cache)\n+        if not inventory:\n+            raise SmokeError(\"Codebase Memory preindex produced no persistent cache\")\n+        validation = {\"status\": \"indexed\", \"project\": project, \"cache_inventory\": inventory}\n+    else:\n+        raise SmokeError(f\"unknown treatment: {system}\")\n+    assert_pristine_checkout(checkout, repository)\n+    setup_wall_time_ms = max(1, round((time.monotonic() - started) * 1000))\n+    (record_root / \"setup.stdout\").write_bytes(setup_stdout)\n+    (record_root / \"setup.stderr\").write_bytes(setup_stderr)\n+    record = {\n+        \"schema_version\": 1, \"measurement_protocol\": MEASUREMENT_PROTOCOL,\n+        \"suite\": repository[\"suite\"], \"repository\": repository[\"repository\"],\n+        \"system\": system, \"commit\": repository[\"commit\"], \"tree\": repository[\"tree\"],\n+        \"setup_wall_time_ms\": setup_wall_time_ms, \"project\": project,\n+        \"validation\": validation,\n+    }\n+    digest = canonical_write(record_root / \"setup.json\", record)\n+    record[\"record_sha256\"] = digest\n+    return record\n+\n+\n+def load_or_setup_treatment_index(\n+    repository: dict[str, Any], system: str, output: Path, *, graph: Path,\n+    cbm: Path, runtime_path_prefix: str, timeout_seconds: int,\n+) -> dict[str, Any]:\n+    record_root, graph_cache, cbm_cache, _temp, _home = treatment_paths(repository, system, output)\n+    path = record_root / \"setup.json\"\n+    if not path.is_file():\n+        return setup_treatment_index(\n+            repository, system, output, graph=graph, cbm=cbm,\n+            runtime_path_prefix=runtime_path_prefix, timeout_seconds=timeout_seconds,\n+        )\n+    setup = artifacts.read_canonical_json(path, expected_type=dict).document\n+    if (\n+        setup.get(\"measurement_protocol\") != MEASUREMENT_PROTOCOL\n+        or setup.get(\"repository\") != repository[\"repository\"]\n+        or setup.get(\"system\") != system\n+        or setup.get(\"commit\") != repository[\"commit\"]\n+        or setup.get(\"tree\") != repository[\"tree\"]\n+    ):\n+        raise SmokeError(\"existing setup record does not match the preindexed protocol binding\")\n+    if system == \"entire-graph\" and cache_inventory(graph_cache) != setup.get(\"validation\", {}).get(\"cache_inventory\"):\n+        raise SmokeError(\"existing Entire Graph cache differs from its validated setup record\")\n+    if system == \"cbm\" and cache_inventory(cbm_cache) != setup.get(\"validation\", {}).get(\"cache_inventory\"):\n+        raise SmokeError(\"existing Codebase Memory cache differs from its validated setup record\")\n+    setup[\"record_sha256\"] = artifacts.sha256_file(path)\n+    return setup\n+\n+\n def audit_smoke_treatment(\n-    system: str, tools: list[dict[str, Any]], graph_binary: Path,\n+    system: str, tools: list[dict[str, Any]], graph_binary: Path, *,\n+    graph_cache: Path | None = None, cbm_project: str | None = None,\n ) -> dict[str, Any]:\n     audit = runtime.audit_treatment(system, tools, graph_binary)\n-    commands = [runtime.bash_command(tool) for tool in tools if runtime.bash_command(tool)]\n+    executed = [\n+        tool for tool in tools\n+        i