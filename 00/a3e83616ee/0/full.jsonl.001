usage\"].get(\"cache_creation_input_tokens\") or 0)\n596:            + (row[\"usage\"].get(\"cache_read_input_tokens\") or 0)\n611:            \"provider_input_tokens_including_cache\": provider_input_tokens,\n636:    lines = [title, \"\", scope, \"\", f\"| System | {quality_label} | Macro recall | Micro recall | Tool calls | Wall time (s) | Provider input incl. cache | Output tokens | Cost (USD) | Compliance |\", \"| --- | ---: | ---: | ---: | ---: | ---: | ---: | ---: | ---: | ---: |\"]\n639:        lines.append(f\"| {system} | {row['exact_pass_rate']:.3f} | {row['mean_recall']:.3f} | {row['micro_recall']:.3f} | {row['mean_tool_calls']:.1f} | {row['mean_wall_time_ms']/1000:.1f} | {row['provider_input_tokens_including_cache']} | {row['output_tokens']} | {row['reported_cost_usd']:.4f} | {row['treatment_compliance_rate']:.3f} |\")\n706:        \"entire_graph\": runtime.executable_binding(args.graph_binary, [\"--version\"]),\n758:    parser.add_argument(\"--repos-dir\", type=Path, default=Path(\"/private/tmp/entire-graph-agentic-tasks-smoke-repos\"))\n760:    parser.add_argument(\"--graph-binary\", type=Path, default=Path(shutil.which(\"entire-graph\") or \"/missing/entire-graph\"))\n"}],"internal_chat_message_metadata_passthrough":{"turn_id":"019f7569-6161-7702-9ed1-5f5d3ff8fdff"}}}
