ovider_test.go:10983:\twriteFile(t, repo, \"src/generated.py\", \"def generated():\\n    return True\\n\")\ninternal/sem/provider_test.go:11001:\tif snapshotHasPath(snapshot, \"src/generated.py\") {\ninternal/sem/provider_test.go:11031:\twriteFile(t, repo, \".brainignore\", \"generated/\\n\")\ninternal/sem/provider_test.go:11032:\twriteFile(t, repo, \".graphinclude\", \"generated/\\n\")\ninternal/sem/provider_test.go:11033:\twriteFile(t, repo, \"generated/included.py\", \"def included():\\n    return True\\n\")\ninternal/sem/provider_test.go:11390:\t// token templates for generated code, not calls executed by the function.\ninternal/sem/provider_test.go:11439:\t\t// hyphenated LLVM compiler-rt is treated as vendored.\ninternal/sem/provider_test.go:11441:\t\t// Universally vendored/generated directories at any depth.\ninternal/sem/provider_test.go:11443:\t\t{\"a/b/third_party\", \"third_party\", true},\ninternal/sem/provider_test.go:11445:\t\t{\"vendor\", \"vendor\", true},\ninternal/sem/provider_test.go:11446:\t\t// Ambiguous generated-output names are not unconditionally vendored;\ninternal/sem/provider_test.go:11474:\t\t// The same names untracked are generated/fetched output and skipped.\ninternal/sem/provider_test.go:11478:\t\t// Unambiguous vendored names are skipped even when tracked.\ninternal/sem/provider_test.go:11480:\t\t{\"vendor\", \"vendor\", true},\ninternal/sem/provider_test.go:11491:\t// source; the vendored-directory heuristic must not skip a tracked\ninternal/sem/provider_test.go:11502:\twriteFile(t, repo, \"build/out.js\", \"function generatedOutput() {\\n  return 1\\n}\\n\")\ninternal/sem/provider_test.go:11511:\tif snapshotHasPath(snapshot, \"build/out.js\") || snapshotHasSymbol(snapshot, \"generatedOutput\") {\ninternal/sem/provider_test.go:11518:\t// generated-output names (build, dist, deps, external) must never be\ninternal/sem/provider_test.go:11539:\t// proven first-party, so it keeps the conservative vendored treatment.\ninternal/sem/prov