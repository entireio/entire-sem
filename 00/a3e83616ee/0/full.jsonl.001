{"timestamp":"2026-07-18T13:36:24.405Z","type":"response_item","payload":{"type":"custom_tool_call","id":"ctc_0bd6d73b974b1fab016a5b81584d8c81918f8222407a4d2db1","status":"completed","call_id":"call_DZYwqrD8slDH2Rfz25COnumE","name":"exec","input":"const r = await tools.exec_command({cmd:\"sed -n '1,180p' /private/tmp/brain-bench-graph-agentic-pilot/competitive-eval/tools/run_agentic_tasks_smoke.py\\nsed -n '180,460p' /private/tmp/brain-bench-graph-agentic-pilot/competitive-eval/tools/run_agentic_tasks_smoke.py\\nsed -n '460,820p' /private/tmp/brain-bench-graph-agentic-pilot/competitive-eval/tools/run_agentic_tasks_smoke.py\",\"workdir\":\"/Users/thomi/Projects/entire-graph\",\"yield_time_ms\":10000,\"max_output_tokens\":40000});\ntext(r.output);","internal_chat_message_metadata_passthrough":{"turn_id":"019f756f-5147-7222-9084-187ed68d3651"}}}
{"timestamp":"2026-07-18T13:36:24.816Z","type":"response_item","payload":{"type":"custom_tool_call_output","id":"ctco_019f7571-42f0-73b0-b842-8123cb4e4883","call_id":"call_DZYwqrD8slDH2Rfz25COnumE","output":[{"type":"input_text","text":"Script completed\nWall time 0.4 seconds\nOutput:\n"},{"type":"input_text","text":"#!/usr/bin/env python3\n\"\"\"Run a frozen three-repository agentic smoke through Claude Code treatments.\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport concurrent.futures\nimport json\nimport os\nimport re\nimport shutil\nimport subprocess\nimport sys\nimport time\nfrom collections import defaultdict\nfrom pathlib import Path\nfrom typing import Any\n\nimport agentic_parity\nimport run_graph_agentic_repair_pilot as runtime\nimport sem_v7_artifacts as artifacts\n\n\nROOT = Path(__file__).resolve().parents[2]\nDEFAULT_MANIFEST = ROOT / \"competitive-eval\" / \"agentic-tasks-smoke\" / \"manifest.json\"\nSUITE = \"entire_graph_agentic_mini_v1\"\nORACLE_SUITE = \"entire_graph_oracle_agentic_overlay_v1\"\nSYSTEMS = (\"file-tools\", \"entire-graph\", \"cbm\")\nROTATIONS = (\n    SYSTEMS,\n    (\"entire-graph\", \"cbm\", \"file-tools\"),\n    (\"cbm\", \"file-tools\", \"entire-graph\"),\n)\n\n\nclass SmokeError(ValueError):\n    pass\n\n\ndef canonical_write(path: Path, value: Any) -> str:\n    path.parent.mkdir(parents=True, exist_ok=True)\n    data = artifacts.canonical_bytes(value)\n    path.write_bytes(data)\n    return artifacts.sha256_bytes(data)\n\n\ndef load_manifest(path: Path) -> dict[str, Any]:\n    manifest = artifacts.read_canonical_json(path, expected_type=dict).document\n    common_invalid = (\n        manifest.get(\"development_only\") is not True\n        or manifest.get(\"confirmatory_use_allowed\") is not False\n        or manifest.get(\"repository_count\") != 3\n    )\n    if common_invalid or manifest.get(\"suite\") not in {SUITE, ORACLE_SUITE}:\n        raise SmokeError(\"manifest is not the frozen three-repository Tasks smoke\")\n    if manifest[\"suite\"] == SUITE:\n        if manifest.get(\"case_count\") != 18:\n            raise SmokeError(\"retained Tasks smoke must contain 18 cases\")\n        for repository in manifest[\"repositories\"]:\n            for task in repository[\"tasks\"]:\n                task_path = ROOT / task[\"path\"]\n                if artifacts.sha256_file(task_path) != task[\"sha256\"]:\n                    raise SmokeError(f\"retained task commitment changed: {task['path']}\")\n    else:\n        if manifest.get(\"case_count\") != 12:\n            raise SmokeError(\"compiler-oracle overlay must contain 12 cases\")\n        boundary = manifest.get(\"claim_boundary\", {})\n        if boundary.get(\"callgraph_oracle_complete\") is not True:\n            raise SmokeError(\"compiler-oracle overlay must declare complete callgraph scope\")\n    return manifest\n\n\ndef oracle_case(case: dict[str, Any]) -> dict[str, Any]:\n    \"\"\"Convert a frozen oracle case to the runner's controller-only shape.\"\"\"\n    def expected_location(value: dict[str, Any]) -> dict[str, Any]:\n        return {\n            \"name\": value[\"name\"], \"file_path\": value[\"file\"],\n            \"line\": value[\"line\"], \"symbol_kind\": value[\"kind\"],\n        }\n\n    category = case[\"category\"]\n    if category == \"symbol_discovery\":\n        expected = {\n            \"kind\": \"definition\", \"complete\": True,\n            **expected_location(case[\"expected\"][0]),\n        }\n    elif category in {\"direct_callers\", \"direct_callees\"}:\n        expected = {\n            \"kind\": \"callgraph\", \"complete\": True,\n            \"items\": [expected_location(value) for value in case[\"expected\"]],\n        }\n    elif category == \"transitive_call_path\":\n        family = case[\"expected_path_families\"][0]\n        expected = {\n            \"kind\": \"call_path\", \"complete\": True,\n            \"items\": [\n                {\n                    \"caller\": expected_location(caller),\n                    \"focus\": expected_location(family[\"focus\"]),\n                    \"callee\": expected_location(callee),\n                }\n                for caller in family[\"callers\"] for callee in family[\"callees\"]\n            ],\n        }\n    else:\n        raise SmokeError(f\"unsupported oracle category: {category}\")\n    return {\"id\": case[\"id\"], \"category\": category, \"question\": case[\"question\"], \"expected\": expected}\n\n\ndef prepare(\n    manifest: dict[str, Any], output: Path, repos_dir: Path,\n    manifest_path: Path = DEFAULT_MANIFEST,\n) -> dict[str, Any]:\n    output.mkdir(parents=True, exist_ok=True)\n    rows = []\n    for index, repository in enumerate(manifest[\"repositories\"]):\n        oracle_complete = manifest[\"suite\"] == ORACLE_SUITE\n        if oracle_complete:\n            cases = [oracle_case(case) for case in repository[\"cases\"]]\n            slug = repository[\"name\"]\n            repo_name = repository[\"repository\"].removeprefix(\"github.com/\")\n        else:\n            cases = [case for case in manifest[\"cases\"] if case[\"repo\"] == repository[\"repository\"]]\n            slug = cases[0][\"slug\"]\n            repo_name = repository[\"repository\"]\n        expected_count = 4 if oracle_complete else 6\n        if len(cases) != expected_count:\n            raise SmokeError(f\"each selected repository must have {expected_count} frozen questions\")\n        spec = agentic_parity.RepoSpec(\n            slug=slug,\n            repo=repo_name,\n            commit=repository[\"commit\"],\n            language=repository[\"language\"],\n        )\n        state = agentic_parity.prepare_repo(spec, repos_dir, strict_clean=True)\n        if not state.get(\"ready\"):\n            raise SmokeError(f\"repository preparation failed: {state}\")\n        source = Path(state[\"path\"]).resolve(strict=True)\n        tree = runtime.checked_git([\"rev-parse\", \"HEAD^{tree}\"], cwd=source).decode().strip()\n        checkouts = {}\n        for system in SYSTEMS:\n            checkout = output / \"checkouts\" / f\"repo-{index + 1:02d}\" / system\n            runtime.materialize_checkout(source, repository[\"commit\"], tree, checkout)\n            checkouts[system] = str(checkout)\n        rows.append(\n            {\n                \"execution_index\": index + 1,\n                \"suite\": manifest[\"suite\"],\n                \"repository\": repository[\"repository\"],\n                \"language\": repository[\"language\"],\n                \"commit\": repository[\"commit\"],\n                \"tree\": tree,\n                \"source_repository\": str(source),\n                \"checkouts\": checkouts,\n                \"system_order\": list(ROTATIONS[index]),\n                \"cases\": cases,\n                \"oracle_complete\": oracle_complete,\n            }\n        )\n    prepared = {\n        \"schema_version\": 1,\n        \"suite\": manifest[\"suite\"],\n        \"stage\": \"prepared_agentic_tasks_smoke\",\n        \"development_only\": True,\n        \"confirmatory_use_allowed\": False,\n        \"source_manifest_sha256\": artifacts.sha256_file(manifest_path),\n        \"repositories\": rows,\n    }\n    canonical_write(output / \"runtime-manifest.json\", prepared)\n    return prepared\n\n\nLOCATION_SCHEMA = {\n    \"type\": \"object\",\n    \"additionalProperties\": False,\n    \"properties\": {\n        \"name\": {\"type\": \"string\"},\n        \"file_path\": {\"type\": \"string\"},\n        \"line\": {\"type\": [\"integer\", \"null\"]},\n    },\n    },\n    \"required\": [\"name\", \"file_path\", \"line\"],\n}\n\n\nANSWER_SCHEMA = {\n    \"type\": \"object\",\n    \"additionalProperties\": False,\n    \"properties\": {\n        \"answers\": {\n            \"type\": \"array\",\n            \"items\": {\n                \"type\": \"object\",\n                \"additionalProperties\": False,\n                \"properties\": {\n                    \"id\": {\"type\": \"string\"},\n                    \"locations\": {\n                        \"type\": \"array\",\n                        \"items\": LOCATION_SCHEMA,\n                    },\n                    \"paths\": {\n                        \"type\": \"array\",\n                        \"items\": {\n                            \"type\": \"object\",\n                            \"additionalProperties\": False,\n                            \"properties\": {\n                                \"caller\": {\"oneOf\": [{\"type\": \"string\"}, LOCATION_SCHEMA]},\n                                \"focus\": {\"oneOf\": [{\"type\": \"string\"}, LOCATION_SCHEMA]},\n                                \"callee\": {\"oneOf\": [{\"type\": \"string\"}, LOCATION_SCHEMA]},\n                            },\n                            \"required\": [\"caller\", \"focus\", \"callee\"],\n                        },\n                    },\n                    \"path_families\": {\n                        \"type\": \"array\",\n                        \"items\": {\n                            \"type\": \"object\",\n                            \"additionalProperties\": False,\n                            \"properties\": {\n                                \"callers\": {\"type\": \"array\", \"items\": {\"oneOf\": [{\"type\": \"string\"}, LOCATION_SCHEMA]}},\n                                \"focus\": {\"oneOf\": [{\"type\": \"string\"}, LOCATION_SCHEMA]},\n                                \"callees\": {\"type\": \"array\", \"items\": {\"oneOf\": [{\"type\": \"string\"}, LOCATION_SCHEMA]}},\n                            },\n                            \"required\": [\"callers\", \"focus\", \"callees\"],\n                        },\n                    },\n                    \"snippet\": {\"type\": [\"string\", \"null\"]},\n                    \"limitations\": {\"type\": \"array\", \"items\": {\"type\": \"string\"}},\n                },\n                \"required\": [\"id\", \"locations\", \"paths\", \"path_families\", \"snippet\", \"limitations\"],\n            },\n        },\n        \"confidence\": {\"type\": \"string\", \"enum\": [\"high\", \"medium\", \"low\"]},\n    },\n    \"required\": [\"answers\", \"confidence\"],\n}\n\n\ndef prompt_for(repository: dict[str, Any], system: str, graph_binary: Path) -> str:\n    questions = \"\\n\".join(f\"- `{case['id']}`: {case['question']}\" for case in repository[\"cases\"])\n    if repository.get(\"oracle_complete\"):\n        question_count = \"four\"\n        answer_rules = \"\"\"For definition and caller/callee answers, put every result in `locations` with its exact repository-relative definition file and definition line. The relation questions ask for the complete compiler-resolved set within repository-authored, non-test source; exclude external dependencies and self-calls. For two-hop paths, use `path_families` to express callers × focus × callees. Every caller, focus, and callee in a path family must be a location object with `name`, `file_path`, and definition `line`, so overloads remain distinct. Do not add speculative relations.\"\"\"\n    else:\n        question_count = \"six\"\n        answer_rules = \"\"\"For definition, snippet, and code-search answers, put the relevant symbols and files in `locations`; include the requested source in `snippet` only for the snippet question. For caller/callee answers, put every direct relation in `locations`, using the related symbol's definition file and definition line rather than the call-site file. A direct module-scope call is a valid file-level caller and must not be omitted. Attribute a call inside a nested local closure to its authored enclosing repository-level function or method. For two-hop paths, use `path_families` to compactly express a Cartesian product of callers × one focus × callees; use explicit `paths` only for exceptions that cannot be represented as such a family. Here \"authored\" means the path is created by a direct call in repository-authored focus code; constructor and imported or re-exported callee endpoints remain valid.\"\"\"\n    common = f\"\"\"Investigate the repository in the current working directory and answer the {question_count} questions below.\n\n{questions}\n\nUse repository-relative paths. {answer_rules} Return one answer for every exact question id.\n\nDo not edit files. Do not use the network, Git history, Git objects, remotes, parent directories, or files outside this checkout. Do not write memory files. Normal targeted file reads are allowed for every treatment.\n\n\"\"\"\n    if system == \"file-tools\":\n        treatment = \"Use Claude Code's native Grep, Glob, Read, and Bash tools. Entire Graph and Codebase Memory are unavailable.\"\n    elif system == \"entire-graph\":\n        treatment = f\"Use normal file tools plus Entire Graph. Invoke `{graph_binary} search --repo . --query \\\"...\\\" --format agent --head` at least once. After locating the symbol that the relationship questions name, invoke `{graph_binary} neighbors --repo . --symbol NAME --file PATH --depth 2 --limit 100 --format agent --head --cache-dir \\\"$TMPDIR/entire-graph-cache\\\"`; use targeted file-tool checks to verify or fill gaps. Do not invoke neighbors for a symbol asked about only by definition, snippet, or code-search questions. Do not stream or dump the full graph.\"\n    elif system == \"cbm\":\n        treatment = \"Use normal file tools plus Codebase Memory. Index this repository and invoke at least one Codebase Memory retrieval tool, then use any targeted file-tool checks that help.\"\n    else:\n        raise SmokeError(f\"unknown treatment: {system}\")\n    return common + treatment\n\n\ndef claude_command(\n    *, claude: Path, model: str, system: str, prompt: str, mcp: Path,\n    graph: Path, max_turns: int, max_budget_usd: float,\n) -> list[str]:\n    builtins = \"Read,Grep,Glob,Bash\"\n    allowed = [\"Read\", \"Grep\", \"Glob\", \"Bash\"]\n    if system == \"entire-graph\":\n        allowed.append(f\"Bash({graph} search:*)\")\n        allowed.append(f\"Bash({graph} neighbors:*)\")\n    elif system == \"cbm\":\n        allowed.append(\"mcp__codebase-memory-mcp\")\n    return [\n        str(claude), \"-p\", prompt, \"--output-format\", \"stream-json\", \"--verbose\",\n        \"--model\", model, \"--effort\", \"high\", \"--max-turns\", str(max_turns),\n        \"--max-budget-usd\", str(max_budget_usd), \"--tools\", builtins,\n        \"--allowedTools\", \",\".join(allowed), \"--disallowedTools\",\n        \"WebFetch,WebSearch,Edit,Write,NotebookEdit\", \"--permission-mode\", \"dontAsk\",\n        \"--strict-mcp-config\", \"--mcp-config\", str(mcp), \"--setting-sources\", \"\",\n        \"--disable-slash-commands\", \"--no-session-persistence\", \"--json-schema\",\n        json.dumps(ANSWER_SCHEMA, separators=(\",\", \":\"), sort_keys=True),\n    ]\n\n\ndef structured_result(result: dict[str, Any] | None) -> dict[str, Any] | None:\n    if not isinstance(result, dict):\n        return None\n    value = result.get(\"structured_output\")\n    if isinstance(value, dict):\n        return value\n    value = result.get(\"result\")\n    if isinstance(value, dict):\n        return value\n    if isinstance(value, str):\n        try:\n            parsed = json.loads(value)\n            return parsed if isinstance(parsed, dict) else None\n        except json.JSONDecodeError:\n            return None\n    return None\n\n\ndef normalized_location(value: dict[str, Any]) -> tuple[str, str, int | None]:\n    line = value.get(\"line\")\n    return (\n        str(value.get(\"name\") or \"\").casefold(),\n        str(value.get(\"file_path\") or \"\").lstrip(\"./\").casefold(),\n        line if isinstance(line, int) else None,\n    )\n\n\ndef symbol_matches(expected: str, observed: str) -> bool:\n    \"\"\"Match the retained symbol against an agent's human-readable label.\"\"\"\n\n    expected_folded = expected.casefold()\n    observed_folded = observed.casefold()\n    candidates = {expected_folded, expected_folded.rsplit(\".\", 1)[-1]}\n    return any(\n        re.search(rf\"(?<![\\w]){re.escape(candidate)}(?![\\w])\", observed_folded)\n        for candidate in candidates\n        if candidate\n    )\n\n\ndef location_matches(\n    expected: dict[str, Any], observed: tuple[str, str, int | None], *, require_line: bool = False,\n) -> bool:\n    name, path, line = observed\n    path_matches = path == str(expected[\"file_path\"]).lstrip(\"./\").casefold()\n    line_matches = not require_line or line == expected.get(\"line\")\n    return path_matches and line_matches and symbol_matches(str(expected[\"name\"]), name)\n\n\ndef score_locations(\n    targets: list[dict[str, Any]], observed: set[tuple[str, str, int | None]], *, complete: bool,\n) -> tuple[bool, int, int, float, float]:\n    hits = sum(any(location_matches(target, row, require_line=complete) for row in observed) for target in targets)\n    recall = hits / len(targets) if targets else 1.0\n    if complete:\n        correct_observed = sum(\n            any(location_matches(target, row, require_line=True) for target in targets)\n            for row in observed\n        )\n        precision = correct_observed / len(observed) if observed else (1.0 if not targets else 0.0)\n    else:\n        precision = 1.0\n    return hits == len(targets) and precision == 1.0, hits, len(targets), recall, precision\n\n\ndef score_answer(case: dict[str, Any], answer: dict[str, Any] | None) -> dict[str, Any]:\n    answer = answer or {}\n    observed = {normalized_location(row) for row in answer.get(\"locations\", []) if isinstance(row, dict)}\n    expected = case[\"expected\"]\n    kind = expected[\"kind\"]\n    complete = expected.get(\"complete\") is True\n    if kind == \"definition\":\n        passed, matched_items, expected_items, recall, precision = score_locations(\n            [expected], observed, complete=complete,\n        )\n    elif kind == \"callgraph\":\n        targets = expected[\"items\"]\n        passed, matched_items, expected_items, recall, precision = score_locations(\n            targets, observed, complete=complete,\n        )\n    elif kind == \"call_path\":\n        if complete:\n            targets = [\n                (row[\"caller\"], row[\"focus\"], row[\"callee\"])\n                for row in expected[\"items\"]\n            ]\n        else:\n            targets = [\n                (row[\"caller\"][\"name\"], row[\"focus\"][\"name\"], row[\"callee\"][\"name\"])\n                for row in expected[\"items\"]\n            ]\n        observed_paths = [\n            (row.get(\"caller\"), row.get(\"focus\"), row.get(\"callee\"))\n            for row in answer.get(\"paths\", []) if isinstance(row, dict)\n        ]\n        for family in answer.get(\"path_families\", []):\n            if not isinstance(family, dict):\n                continue\n            focus = family.get(\"focus\")\n            callers = [value for value in family.get(\"callers\", []) if isinstance(value, (str, dict))]\n            callees = [value for value in family.get(\"callees\", []) if isinstance(value, (str, dict))]\n            observed_paths.extend((caller, focus, callee) for caller in callers for callee in callees)\n        if complete:\n            def path_matches(target: tuple[Any, Any, Any], row: tuple[Any, Any, Any]) -> bool:\n                return all(\n                    isinstance(got, dict)\n                    and location_matches(want, normalized_location(got), require_line=True)\n                    for want, got in zip(target, row)\n                )\n        else:\n            def path_matches(target: tuple[Any, Any, Any], row: tuple[Any, Any, Any]) -> bool:\n                return all(symbol_matches(want, str(got or \"\")) for want, got in zip(target, row))\n        hits = sum(any(path_matches(target, row) for row in observed_paths) for target in targets)\n        matched_items, expected_items = hits, len(targets)\n        recall = hits / len(targets) if targets else 1.0\n        if complete:\n            correct_observed = sum(any(path_matches(target, row) for target in targets) for row in observed_paths)\n            precision = correct_observed / len(observed_paths) if observed_paths else (1.0 if not targets else 0.0)\n        else:\n            precision = 1.0\n        passed = hits == len(targets) and precision == 1.0\n    else:\n        raise SmokeError(f\"unsupported expected kind: {kind}\")\n    return {\n        \"id\": case[\"id\"], \"category\": case[\"category\"], \"passed\": passed,\n        \"precision\": precision, \"recall\": recall,\n        \"matched_items\": matched_items, \"expected_items\": expected_items,\n    }\n\n\ndef score_response(cases: list[dict[str, Any]], response: dict[str, Any] | None) -> list[dict[str, Any]]:\n    answers = response.get(\"answers\", []) if isinstance(response, dict) else []\n    by_id = {row.get(\"id\"): row for row in answers if isinstance(row, dict) and isinstance(row.get(\"id\"), str)}\n    return [score_answer(case, by_id.get(case[\"id\"])) for case in cases]\n\n\ndef assert_pristine_checkout(checkout: Path, repository: dict[str, Any]) -> None:\n    head = runtime.checked_git([\"rev-parse\", \"HEAD\"], cwd=checkout).decode().strip()\n    tree = runtime.checked_git([\"rev-parse\", \"HEAD^{tree}\"], cwd=checkout).decode().strip()\n    status = runtime.checked_git([\"status\", \"--porcelain=v1\", \"--untracked-files=all\"], cwd=checkout)\n    if head != repository[\"commit\"] or tree != repository[\"tree\"] or status.strip():\n        raise SmokeError(\n            f\"agent checkout is not pristine for {repository['repository']}: \"\n            f\"head={head} tree={tree} status={status.decode('utf-8', 'replace')!r}\"\n        )\n\n\ndef audit_smoke_treatment(\n    system: str, tools: list[dict[str, Any]], graph_binary: Path,\n) -> dict[str, Any]:\n    audit = runtime.audit_treatment(system, tools, graph_binary)\n    commands = [runtime.bash_command(tool) for tool in tools if runtime.bash_command(tool)]\n    neighbor_calls = sum(\n        str(graph_binary) in command and \" neighbors \" in f\" {command} \"\n        for command in commands\n    )\n    violations = set(audit[\"violations\"])\n    if system == \"entire-graph\" and neighbor_calls == 0:\n        violations.add(\"missing_entire_graph_neighbors\")\n    if system == \"file-tools\" and neighbor_calls:\n        violations.add(\"baseline_used_graph_product\")\n    audit[\"entire_graph_neighbor_calls\"] = neighbor_calls\n    audit[\"violations\"] = sorted(violations)\n    audit[\"passed\"] = not violations\n    return audit\n\n\ndef execute_one(\n    repository: dict[str, Any], system: str, output: Path, *, claude: Path,\n    graph: Path, cbm: Path, model: str, max_turns: int, max_budget_usd: float,\n    timeout_seconds: int, runtime_path_prefix: str,\n) -> dict[str, Any]:\n) -> dict[str, Any]:\n    checkout = Path(repository[\"checkouts\"][system]).resolve(strict=True)\n    assert_pristine_checkout(checkout, repository)\n    record_root = output / \"records\" / f\"repo-{repository['execution_index']:02d}\" / system\n    record_root.mkdir(parents=True, exist_ok=True)\n    cache, temp, home = record_root / \"cbm-cache\", record_root / \"agent-temp\", record_root / \"agent-home\"\n    for path in (cache, temp, home / \".claude\"):\n        path.mkdir(parents=True, exist_ok=True)\n    runtime.copy_claude_credentials(home / \".claude\" / \".credentials.json\")\n    mcp = runtime.mcp_config(system, output, cbm, cache)\n    command = claude_command(\n        claude=claude, model=model, system=system,\n        prompt=prompt_for(repository, system, graph), mcp=mcp, graph=graph,\n        max_turns=max_turns, max_budget_usd=max_budget_usd,\n    )\n    command, sandbox_sha = runtime.sandboxed_agent_command(\n        command, checkout=checkout, output=output,\n        source_repository=Path(repository[\"source_repository\"]),\n        readable_files=[claude, graph, cbm, mcp],\n        readable_paths=[Path(row).parent for row in runtime_path_prefix.split(os.pathsep) if row],\n        writable_paths=[cache, temp, home],\n        checkout_writable=False,\n    )\n    environment = runtime.runtime_environment(runtime_path_prefix)\n    environment.update({\n        \"HOME\": str(home), \"CLAUDE_CONFIG_DIR\": str(home / \".claude\"),\n        \"TMPDIR\": str(temp), \"CLAUDE_CODE_TMPDIR\": str(temp), \"CLAUDE_TMPDIR\": str(temp),\n        \"CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC\": \"1\", \"DISABLE_AUTOUPDATER\": \"1\",\n        \"GIT_CONFIG_GLOBAL\": \"/dev/null\", \"GIT_CONFIG_NOSYSTEM\": \"1\",\n    })\n    started = time.monotonic()\n    timed_out = False\n    try:\n        process = runtime.run_command(command, cwd=checkout, env=environment, timeout=timeout_seconds)\n        stdout, stderr, returncode = process.stdout, process.stderr, process.returncode\n    except subprocess.TimeoutExpired as error:\n        timed_out, stdout, stderr, returncode = True, error.stdout or b\"\", error.stderr or b\"\", 124\n    finally:\n        shutil.rmtree(home, ignore_errors=True)\n    assert_pristine_checkout(checkout, repository)\n    (record_root / \"transcript.jsonl\").write_bytes(stdout)\n    (record_root / \"stderr.txt\").write_bytes(stderr)\n    parsed = runtime.parse_stream(stdout)\n    response = structured_result(parsed[\"result\"])\n    scores = score_response(repository[\"cases\"], response)\n    audit = audit_smoke_treatment(system, parsed[\"tools\"], graph)\n    result = parsed.get(\"result\") or {}\n    record = {\n        \"schema_version\": 1, \"suite\": repository[\"suite\"], \"repository\": repository[\"repository\"],\n        \"system\": system, \"model\": model, \"returncode\": returncode, \"timed_out\": timed_out,\n        \"wall_time_ms\": max(1, round((time.monotonic() - started) * 1000)),\n        \"sandbox_profile_sha256\": sandbox_sha, \"treatment_audit\": audit,\n        \"tool_call_count\": len(parsed[\"tools\"]), \"scores\": scores,\n        \"exact_pass_rate\": sum(row[\"passed\"] for row in scores) / len(scores),\n        \"retained_assertion_pass_rate\": (\n            None if repository.get(\"oracle_complete\")\n            else sum(row[\"passed\"] for row in scores) / len(scores)\n        ),\n        \"mean_recall\": sum(row[\"recall\"] for row in scores) / len(scores),\n        \"mean_precision\": sum(row[\"precision\"] for row in scores) / len(scores),\n        \"usage\": result.get(\"usage\") if isinstance(result.get(\"usage\"), dict) else {},\n        \"num_turns\": result.get(\"num_turns\"), \"reported_total_cost_usd\": result.get(\"total_cost_usd\"),\n        \"structured_response_present\": response is not None,\n    }\n    canonical_write(record_root / \"record.json\", record)\n    return record\n\n\ndef recover_existing_attempt(\n    repository: dict[str, Any], system: str, output: Path, *, claude: Path,\n    graph: Path, cbm: Path, runtime_path_prefix: str,\n) -> dict[str, Any] | None:\n    \"\"\"Score an immutable transcript left by a post-execution controller failure.\"\"\"\n    record_root = output / \"records\" / f\"repo-{repository['execution_index']:02d}\" / system\n    record_path = record_root / \"record.json\"\n    if record_path.is_file():\n        return artifacts.read_canonical_json(record_path, expected_type=dict).document\n    transcript = record_root / \"transcript.jsonl\"\n    if not transcript.is_file():\n        return None\n\n    checkout = Path(repository[\"checkouts\"][system]).resolve(strict=True)\n    assert_pristine_checkout(checkout, repository)\n    cache, temp, home = record_root / \"cbm-cache\", record_root / \"agent-temp\", record_root / \"agent-home\"\n    mcp = output / \"runtime\" / \"mcp\" / f\"repo-{repository['execution_index']:02d}-{system}.json\"\n    _command, sandbox_sha = runtime.sandboxed_agent_command(\n        [], checkout=checkout, output=output,\n        source_repository=Path(repository[\"source_repository\"]),\n        readable_files=[claude, graph, cbm, mcp],\n        readable_paths=[Path(row).parent for row in runtime_path_prefix.split(os.pathsep) if row],\n        writable_paths=[cache, temp, home], checkout_writable=False,\n    )\n    parsed = runtime.parse_stream(transcript.read_bytes())\n    response = structured_result(parsed[\"result\"])\n    scores = score_response(repository[\"cases\"], response)\n    audit = audit_smoke_treatment(system, parsed[\"tools\"], graph)\n    result = parsed.get(\"result\") or {}\n    record = {\n        \"schema_version\": 1, \"suite\": repository[\"suite\"],\n        \"repository\": repository[\"repository\"], \"system\": system,\n        \"model\": result.get(\"model\") or \"opus\",\n        \"returncode\": 1 if result.get(\"is_error\") else 0,\n        \"timed_out\": False,\n        \"wall_time_ms\": max(1, int(result.get(\"duration_ms\") or 1)),\n        \"sandbox_profile_sha256\": sandbox_sha,\n        \"treatment_audit\": audit,\n        \"tool_call_count\": len(parsed[\"tools\"]), \"scores\": scores,\n        \"exact_pass_rate\": sum(row[\"passed\"] for row in scores) / len(scores),\n        \"retained_assertion_pass_rate\": (\n            None if repository.get(\"oracle_complete\")\n            else sum(row[\"passed\"] for row in scores) / len(scores)\n        ),\n        \"mean_recall\": sum(row[\"recall\"] for row in scores) / len(scores),\n        \"mean_precision\": sum(row[\"precision\"] for row in scores) / len(scores),\n        \"usage\": result.get(\"usage\") if isinstance(result.get(\"usage\"), dict) else {},\n        \"num_turns\": result.get(\"num_turns\"),\n        \"reported_total_cost_usd\": result.get(\"total_cost_usd\"),\n        \"structured_response_present\": response is not None,\n        \"recovered_after_controller_scoring_failure\": True,\n        \"source_transcript_sha256\": artifacts.sha256_file(transcript),\n    }\n    canonical_write(record_path, record)\n    return record\n\n\ndef summarize(\n    records: list[dict[str, Any]], output: Path, systems_to_report: tuple[str, ...] = SYSTEMS,\n) -> dict[str, Any]:\n    oracle_complete = bool(records) and all(row.get(\"suite\") == ORACLE_SUITE for row in records)\n    systems = {}\n    for system in systems_to_report:\n        rows = [row for row in records if row[\"system\"] == system]\n        scores = [score for row in rows for score in row[\"scores\"]]\n        provider_input_tokens = sum(\n            (row[\"usage\"].get(\"input_tokens\") or 0)\n            + (row[\"usage\"].get(\"cache_creation_input_tokens\") or 0)\n            + (row[\"usage\"].get(\"cache_read_input_tokens\") or 0)\n            for row in rows\n        )\n        systems[system] = {\n            \"attempts\": len(rows), \"questions\": len(scores),\n            \"exact_pass_rate\": sum(row[\"passed\"] for row in scores) / len(scores),\n            \"retained_assertion_pass_rate\": (\n                None if oracle_complete else sum(row[\"passed\"] for row in scores) / len(scores)\n            ),\n            \"mean_recall\": sum(row[\"recall\"] for row in scores) / len(scores),\n            \"mean_precision\": sum(row[\"precision\"] for row in scores) / len(scores),\n            \"micro_recall\": sum(row[\"matched_items\"] for row in scores) / sum(row[\"expected_items\"] for row in scores),\n            \"mean_tool_calls\": sum(row[\"tool_call_count\"] for row in rows) / len(rows),\n            \"mean_wall_time_ms\": sum(row[\"wall_time_ms\"] for row in rows) / len(rows),\n            \"input_tokens\": sum((row[\"usage\"].get(\"input_tokens\") or 0) for row in rows),\n            \"provider_input_tokens_including_cache\": provider_input_tokens,\n            \"output_tokens\": sum((row[\"usage\"].get(\"output_tokens\") or 0) for row in rows),\n            \"reported_cost_usd\": sum((row.get(\"reported_total_cost_usd\") or 0) for row in rows),\n            \"treatment_compliance_rate\": sum(row[\"treatment_audit\"][\"passed\"] for row in rows) / len(rows),\n        }\n    summary = {\n        \"schema_version\": 1,\n        \"suite\": ORACLE_SUITE if oracle_complete else SUITE,\n        \"development_only\": True,\n        \"confirmatory_use_allowed\": False,\n        \"all_question_exact_claim_allowed\": oracle_complete,\n        \"callgraph_oracle_complete\": oracle_complete,\n        \"repository_count\": len({row[\"repository\"] for row in records if row.get(\"repository\")}) or 3,\n        \"attempt_count\": len(records),\n        \"systems\": systems,\n    }\n    canonical_write(output / \"summary.json\", summary)\n    if oracle_complete:\n        title = \"# Compiler-Oracle Agentic Smoke\"\n        scope = \"Development-only; predefined repositories; Claude Opus; exhaustive expectations for the selected compiler-oracle neighborhoods. Exactness is scoped to those compiled neighborhoods.\"\n        quality_label = \"Exact\"\n    else:\n        title = \"# Retained Tasks Agentic Smoke\"\n        scope = \"Development-only; predefined repositories; Claude Opus; one attempt per selected repository and treatment. Callgraph expectations are retained non-exhaustive assertions, so an all-question exact claim is disallowed.\"\n        quality_label = \"Retained assertions\"\n    lines = [title, \"\", scope, \"\", f\"| System | {quality_label} | Macro recall | Micro recall | Tool calls | Wall time (s) | Provider input incl. cache | Output tokens | Cost (USD) | Compliance |\", \"| --- | ---: | ---: | ---: | ---: | ---: | ---: | ---: | ---: | ---: |\"]\n    for system in systems_to_report:\n        row = systems[system]\n        lines.append(f\"| {system} | {row['exact_pass_rate']:.3f} | {row['mean_recall']:.3f} | {row['micro_recall']:.3f} | {row['mean_tool_calls']:.1f} | {row['mean_wall_time_ms']/1000:.1f} | {row['provider_input_tokens_including_cache']} | {row['output_tokens']} | {row['reported_cost_usd']:.4f} | {row['treatment_compliance_rate']:.3f} |\")\n    (output / \"scoreboard.md\").write_text(\"\\n\".join(lines) + \"\\n\", encoding=\"utf-8\")\n    return summary\n\n\ndef rescore(prepared: dict[str, Any], output: Path) -> dict[str, Any]:\n    repositories = {row[\"repository\"]: row for row in prepared[\"repositories\"]}\n    rescored = []\n    provenance = []\n    for record_path in sorted((output / \"records\").glob(\"repo-*/*/record.json\")):\n        source = artifacts.read_canonical_json(record_path, expected_type=dict).document\n        transcript = record_path.with_name(\"transcript.jsonl\")\n        parsed = runtime.parse_stream(transcript.read_bytes())\n        response = structured_result(parsed[\"result\"])\n        cases = repositories[source[\"repository\"]][\"cases\"]\n        scores = score_response(cases, response)\n        row = dict(source)\n        row[\"scores\"] = scores\n        row[\"exact_pass_rate\"] = sum(score[\"passed\"] for score in scores) / len(scores)\n        row[\"retained_assertion_pass_rate\"] = (\n            None if source.get(\"suite\") == ORACLE_SUITE else row[\"exact_pass_rate\"]\n        )\n        row[\"mean_recall\"] = sum(score[\"recall\"] for score in scores) / len(scores)\n        row[\"mean_precision\"] = sum(score[\"precision\"] for score in scores) / len(scores)\n        rescored.append(row)\n        provenance.append(\n            {\n                \"repository\": source[\"repository\"],\n                \"system\": source[\"system\"],\n                \"source_record_sha256\": artifacts.sha256_file(record_path),\n                \"source_transcript_sha256\": artifacts.sha256_file(transcript),\n            }\n        )\n    if len(rescored) != 9:\n        raise SmokeError(\"rescore requires nine immutable raw attempt records\")\n    summary = summarize(rescored, output / \"rescored\")\n    summary[\"source_provenance\"] = provenance\n    summary[\"scorer_sha256\"] = artifacts.sha256_file(Path(__file__).resolve())\n    summary[\"raw_records_mutated\"] = False\n    canonical_write(output / \"rescored\" / \"summary.json\", summary)\n    return summary\n\n\ndef run(prepared: dict[str, Any], output: Path, args: argparse.Namespace) -> dict[str, Any]:\n    if not isinstance(args.graph_source_head, str) or re.fullmatch(r\"[0-9a-f]{40}\", args.graph_source_head) is None:\n        raise SmokeError(\"run requires --graph-source-head with the exact 40-character product commit\")\n    selected_systems = tuple(args.systems)\n    if not selected_systems or len(set(selected_systems)) != len(selected_systems):\n        raise SmokeError(\"run requires one or more distinct --systems values\")\n    available_repositories = {row[\"repository\"] for row in prepared[\"repositories\"]}\n    selected_repositories = set(args.repositories or available_repositories)\n    unknown_repositories = selected_repositories - available_repositories\n    if unknown_repositories:\n        raise SmokeError(f\"unknown --repositories values: {sorted(unknown_repositories)}\")\n    execution_config = {\n        \"schema_version\": 1,\n        \"suite\": prepared[\"suite\"],\n        \"model\": args.model,\n        \"max_turns_per_attempt\": args.max_turns,\n        \"max_budget_usd_per_attempt\": args.max_budget_usd,\n        \"timeout_seconds_per_attempt\": args.timeout_seconds,\n        \"workers\": args.workers,\n        \"systems\": list(selected_systems),\n        \"repositories\": sorted(selected_repositories),\n        \"runtime_path_prefix\": args.runtime_path_prefix,\n        \"graph_source_head\": args.graph_source_head,\n        \"claude\": runtime.executable_binding(args.claude_binary, [\"--version\"]),\n        \"entire_graph\": runtime.executable_binding(args.graph_binary, [\"--version\"]),\n        \"cbm\": runtime.executable_binding(args.cbm_binary, [\"--version\"]),\n        \"runner_sha256\": artifacts.sha256_file(Path(__file__).resolve()),\n    }\n    canonical_write(output / \"execution-config.json\", execution_config)\n    records_by_key: dict[tuple[str, str], dict[str, Any]] = {}\n    for repo in prepared[\"repositories\"]:\n        if repo[\"repository\"] not in selected_repositories:\n            continue\n        for system in selected_systems:\n            recovered = recover_existing_attempt(\n                repo, system, output,\n                claude=args.claude_binary.resolve(strict=True),\n                graph=args.graph_binary.resolve(strict=True),\n                cbm=args.cbm_binary.resolve(strict=True),\n                runtime_path_prefix=args.runtime_path_prefix,\n            )\n            if recovered is not None:\n                records_by_key[(repo[\"repository\"], system)] = recovered\n    for round_index in range(3):\n        attempts = [\n            (repo, repo[\"system_order\"][round_index])\n            for repo in prepared[\"repositories\"]\n            if repo[\"repository\"] in selected_repositories\n            and repo[\"system_order\"][round_index] in selected_systems\n            and (repo[\"repository\"], repo[\"system_order\"][round_index]) not in records_by_key\n        ]\n        if not attempts:\n            continue\n        with concurrent.futures.ThreadPoolExecutor(max_workers=min(args.workers, 3)) as executor:\n            futures = {\n                executor.submit(\n                    execute_one, repo, system, output, claude=args.claude_binary.resolve(strict=True),\n                    graph=args.graph_binary.resolve(strict=True), cbm=args.cbm_binary.resolve(strict=True),\n                    model=args.model, max_turns=args.max_turns, max_budget_usd=args.max_budget_usd,\n                    timeout_seconds=args.timeout_seconds, runtime_path_prefix=args.runtime_path_prefix,\n                ): (repo, system) for repo, system in attempts\n            }\n            for future in concurrent.futures.as_completed(futures):\n                repo, system = futures[future]\n                record = future.result()\n                records_by_key[(repo[\"repository\"], system)] = record\n                metric = \"exact\" if repo.get(\"oracle_complete\") else \"retained_assertions\"\n                print(f\"completed {repo['repository']} {system}: {metric}={record['exact_pass_rate']:.3f}\", file=sys.stderr, flush=True)\n    return summarize(list(records_by_key.values()), output, selected_systems)\n\n\ndef build_parser() -> argparse.ArgumentParser:\n    parser = argparse.ArgumentParser(description=__doc__)\n    parser.add_argument(\"command\", choices=(\"prepare\", \"run\", \"rescore\", \"all\"))\n    parser.add_argument(\"--manifest\", type=Path, default=DEFAULT_MANIFEST)\n    parser.add_argument(\"--output\", type=Path, required=True)\n    parser.add_argument(\"--repos-dir\", type=Path, default=Path(\"/private/tmp/entire-graph-agentic-tasks-smoke-repos\"))\n    parser.add_argument(\"--claude-binary\", type=Path, default=Path(shutil.which(\"claude\") or \"/missing/claude\"))\n    parser.add_argument(\"--graph-binary\", type=Path, default=Path(shutil.which(\"entire-graph\") or \"/missing/entire-graph\"))\n    parser.add_argument(\"--cbm-binary\", type=Path, default=Path(shutil.which(\"codebase-memory-mcp\") or \"/missing/codebase-memory-mcp\"))\n    parser.add_argument(\"--model\", default=\"opus\")\n    parser.add_argument(\"--graph-source-head\")\n    parser.add_argument(\"--max-turns\", type=int, default=24)\n    parser.add_argument(\"--max-budget-usd\", type=float, default=5.0)\n    parser.add_argument(\"--timeout-seconds\", type=int, default=1200)\n    parser.add_argument(\"--workers\", type=int, default=3)\n    parser.add_argument(\"--systems\", nargs=\"+\", choices=SYSTEMS, default=list(SYSTEMS))\n    parser.add_argument(\"--repositories\", nargs=\"+\")\n    parser.add_argument(\"--runtime-path-prefix\", default=\"\")\n    return parser\n\n\ndef main() -> int:\n    args = build_parser().parse_args()\n    manifest = load_manifest(args.manifest)\n    if args.command in {\"prepare\", \"all\"}:\n        prepared = prepare(manifest, args.output, args.repos_dir, args.manifest)\n    else:\n        prepared = artifacts.read_canonical_json(args.output / \"runtime-manifest.json\", expected_type=dict).document\n    if args.command in {\"run\", \"all\"}:\n        run(prepared, args.output, args)\n    elif args.command == \"rescore\":\n        rescore(prepared, args.output)\n    return 0\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n"}],"internal_chat_message_metadata_passthrough":{"turn_id":"019f756f-5147-7222-9084-187ed68d3651"}}}
