{"timestamp":"2026-07-18T14:59:19.964Z","type":"response_item","payload":{"type":"custom_tool_call_output","id":"ctco_019f75bd-2d1c-77f0-bbad-aec81337ff62","call_id":"call_zjxleY4cy42pedoTRV4TzP3V","output":[{"type":"input_text","text":"Script completed\nWall time 0.3 seconds\nOutput:\n"},{"type":"input_text","text":"Warning: truncated output (original token count: 12028)\nTotal output lines: 261\n\nWarning: truncated output (original token count: 262144)\nTotal output lines: 258\n\nfrom __future__ import annotations\n\nimport copy\nimport functools\nimport importlib.metadata\nimport importlib.machinery\nimport importlib.util\nimport json\nimport re\nimport shutil\nimport stat\nimport subprocess\nimport sys\nimport sysconfig\nfrom pathlib import Path\n\nimport pytest\n\nTOOLS = Path(__file__).resolve().parent\n\n\ndef load_tool_module(name):\n    existing = sys.modules.get(name)\n    if existing is not None:\n        expected = (TOOLS / f\"{name}.py\").resolve()\n        observed = Path(existing.__file__).resolve()\n        if observed != expected:\n            raise RuntimeError(f\"tool module resolved outside the test tree: {name}\")\n        return existing\n    spec = importlib.util.spec_from_file_location(name, TOOLS / f\"{name}.py\")\n    if spec is None or spec.loader is None:\n        raise RuntimeError(f\"cannot load tool module: {name}\")\n    module = importlib.util.module_from_spec(spec)\n    sys.modules[name] = module\n    spec.loader.exec_module(module)\n    return module\n\n\nartifacts = load_tool_module(\"sem_v7_artifacts\")\nfreeze = load_tool_module(\"freeze_graph_toolchain_v8\")\nTEST_PYTHON: Path | None = None\n\n\ndef test_committed_v8_toolchain_closure_recomputes_exactly():\n    root = Path(__file__).resolve().parents[2]\n    # CI compiles the test tree before pytest; remove only generated bytecode so\n    # the source-only closure is recomputed against the same clean input class.\n    for cache in (root / \"competitive-eval/tools\").rglob(\"__pycache__\"):\n        shutil.rmtree(cache)\n    artifact_path = root / \"competitive-eval/graph-v8/graph-toolchain-closure.json\"\n    observed = artifacts.read_canonical_json(artifact_path, expected_type=dict)\n    closure = observed.document\n    assert closure[\"catalog_authorized\"] is False\n    assert closure[\"rank_authorized\"] is False\n    assert closure[\"publication_authorized\"] is False\n    sources = closure[\"source_closure\"][\"local_sources\"]\n    assert closure[\"source_closure\"][\"local_source_count\"] == len(sources)\n    for relative, descriptor in sources.items():\n        assert descriptor[\"repository_path\"] == relative\n        assert artifacts.sha256_file(root / relative) == descriptor[\"sha256\"]\n    recorded_source_closure = closure[\"source_closure\"]\n    stdlib_names = {\n        module\n        for stage in closure[\"input_contract\"][\"stages\"].values()\n        for module, owner in stage[\"reviewed_module_ownership\"].items()\n        if owner[\"owner_kind\"] == \"python_standard_library\"\n    }\n    unshadowable = {\n        binding[\"module\"]\n        for stage in recorded_source_closure[\"stages\"].values()\n        for bindings in stage[\"imports_by_source\"].values()\n        for binding in bindings\n        if binding[\"classification\"] == \"unshadowable_builtin_or_frozen_standard_library\"\n    }\n    recomputed = freeze._build_source_closure(\n        root,\n        closure[\"input_contract\"][\"stages\"],\n        stdlib_names,\n        closure[\"input_contract\"][\"third_party_imports\"],\n        unshadowable_stdlib_names=unshadowable,\n        enforce_reviewed_ownership=True,\n    )\n    assert recomputed == recorded_source_closure\n    support = closure[\"reviewed_support_sources\"]\n    assert set(support) == {\n        \"graph_comparator_adapter\", \"graph_comparator_adapter_tests\",\n        \"graph_comparator_cli\", \"graph_comparator_cli_tests\",\n        \"historical_freezer\", \"historical_runner\",\n    }\n    for descriptor in support.values():\n        assert artifacts.sha256_file(root / descriptor[\"repository_path\"]) == descriptor[\"sha256\"]\n    comparator = closure[\"external_executables\"][\"comparator-cli\"]\n    assert comparator[\"probe_stdout\"] == \"graph-v8-comparator-cli-1\\n\"\n\n\n@pytest.fixture(scope=\"session\", autouse=True)\ndef canonical_test_python(tmp_path_factory):\n    \"\"\"Use a copied venv executable with a complete public dist inventory.\"\"\"\n    global TEST_PYTHON\n    root = tmp_path_factory.mktemp(\"graph-toolchain-python\") / \"venv\"\n    subprocess.run(\n        [sys.executable, \"-m\", \"venv\", \"--copies\", str(root)],\n        check=True,\n        capture_output=True,\n    )\n    candidates = sorted((root / \"bin\").glob(\"python3.*\"))\n    if len(candidates) != 1 or candidates[0].is_symlink():\n        raise RuntimeError(\"copied test Python executable is not canonical\")\n    TEST_PYTHON = candidates[0]\n    yield\n    TEST_PYTHON = None\n\n\n@functools.lru_cache(maxsize=None)\ndef reviewed_stdlib_ownership(\n    direct_imports: tuple[str, ...],\n) -> dict[str, dict[str, str]]:\n    executable = Path(sys.executable).resolve()\n    expected = set(direct_imports)\n    for _attempt in range(8):\n        observed = freeze._python_json_probe(\n            executable,\n            freeze.PYTHON_IMPORT_ORIGIN_PROBE,\n            {\n                \"stdlib_modules\": sorted(expected),\n                \"allowed_nonmodule_aliases_by_version\": (\n                    freeze.PYTHON_RUNTIME_NONMODULE_ALIASES_BY_VERSION\n                ),\n            },\n            load_site=False,\n        )\n        names = {row[\"name\"] for row in observed[\"modules\"]}\n        if names == expected:\n            return {\n                name: {\n                    \"owner_kind\": \"python_standard_library\",\n                    \"owner\": \"python_runtime\",\n                }\n                for name in sorted(names)\n            }\n        expected.update(names)\n    raise RuntimeError(\"test fixture could not reach a reviewed stdlib fixed point\")\n\n\ndef write_source(root: Path, relative: str, source: str) -> Path:\n    path = root / relative\n    path.parent.mkdir(parents=True, exist_ok=True)\n    path.write_text(source)\n    return path\n\n\ndef write_executable(path: Path, source: str) -> Path:\n    path.parent.mkdir(parents=True, exist_ok=True)\n    path.write_text(source)\n    path.chmod(0o755)\n    return path.resolve()\n\n\ndef synthetic_inputs(tmp_path: Path) -> tuple[Path, dict]:\n    if TEST_PYTHON is None:\n        raise RuntimeError(\"canonical test Python fixture is unavailable\")\n    root = (tmp_path / \"repository\").resolve()\n    root.mkdir()\n    write_source(\n        root,\n        \"app/runner.py\",\n        \"import json\\nimport local_flat\\nfrom pkg.worker import work\\n\",\n    )\n    write_source(\n        root,\n        \"app/test_runner.py\",\n        \"import pathlib\\nimport pip\\nfrom pkg import worker\\n\",\n    )\n    write_source(root, \"app/local_flat.py\", \"from pkg import config\\n\")\n    write_source(root, \"app/pkg/__init__.py\", \"from . import config\\n\")\n    write_source(root, \"app/pkg/config.py\", \"import dataclasses\\nVALUE = 1\\n\")\n    write_source(\n        root,\n        \"app/pkg/worker.py\",\n        \"import collections.abc\\nfrom .config import VALUE\\ndef work():\\n    return VALUE\\n\",\n    )\n\n    external = write_executable(\n        tmp_path / \"runtime\" / \"synthetic-tool\",\n        \"#!/bin/sh\\nprintf 'synthetic-tool 1.0 poison=%s\\\\n' \"\n        '\"${TOOLCHAIN_POISON-unset}\"\\n',\n    )\n    sandbox = write_executable(\n        tmp_path / \"runtime\" / \"sandbox-exec\",\n        \"#!/bin/sh\\nexit 0\\n\",\n    )\n    profile = (tmp_path / \"runtime\" / \"profile.sb\").resolve()\n    profile.write_text(\n        \"(version 1)\\n(deny default)\\n(allow process*)\\n(deny network*)\\n\"\n    )\n    reviewed_ownership = copy.deepcopy(\n        reviewed_stdlib_ownership(\n            (\"_dbm\", \"collections.abc\", \"dataclasses\", \"json\", \"pathlib\")\n        )\n    )\n    reviewed_ownership.update(\n        {\n            \"local_flat\": {\n                \"owner_kind\": \"repository_source\",\n                \"owner\": \"app/local_flat.py\",\n            },\n            \"pkg\": {\n                \"owner_kind\": \"repository_source\",\n                \"owner\": \"app/pkg/__init__.py\",\n            },\n            \"pkg.config\": {\n                \"owner_kind\": \"repository_source\",\n                \"owner\": \"app/pkg/config.py\",\n            },\n            \"pkg.worker\": {\n                \"owner_kind\": \"repository_source\",\n                \"owner\": \"app/pkg/worker.py\",\n            },\n            \"runner\": {\n                \"owner_kind\": \"repository_source\",\n                \"owner\": \"app/runner.py\",\n            },\n            \"test_runner\": {\n                \"owner_kind\": \"repository_source\",\n                \"owner\": \"app/test_runner.py\",\n            },\n            \"pip\": {\n                \"owner_kind\": \"third_party_distribution\",\n                \"owner\": \"pip\",\n            },\n        }\n    )\n    specification = {\n        \"schema_version\": 2,\n        \"stages\": {\n            \"runner\": {\n                \"entrypoint\": \"app/runner.py\",\n                \"tests\": [\"app/test_runner.py\"],\n                \"reviewed_module_ownership\": reviewed_ownership,\n            }\nrg: Makefile: No such file or directory (os error 2)\nrg: mise.toml: No such file or directory (os error 2)\ncompetitive-eval/graph-v7/README.md:133:and `graph-toolchain-closure.json`, SHA-256\ncompetitive-eval/graph-v7/graph-toolchain-closure.json:1:{\"authorization\":{\"blocking_prerequisites\":[\"runtime_import_and_python_startup_file_origin_audit_rehearsal\",\"python_sys_path_and_importer_cache_mutable_root_binding\",\"process_e