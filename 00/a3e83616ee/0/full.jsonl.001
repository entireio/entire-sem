} | {row['provider_input_tokens_including_cache']} | {row['output_tokens']} | {row['reported_cost_usd']:.4f} | {row['treatment_compliance_rate']:.3f} |\\\")\\n+        lines.append(f\\\"| {system} | {row['exact_pass_rate']:.3f} | {row['mean_recall']:.3f} | {row['micro_recall']:.3f} | {row['mean_tool_calls']:.1f} | {row['mean_task_wall_time_ms']/1000:.1f} | {row['mean_setup_wall_time_ms']/1000:.1f} | {row['provider_input_tokens_including_cache']} | {row['output_tokens']} | {row['reported_cost_usd']:.4f} | {row['treatment_compliance_rate']:.3f} |\\\")\\n*** End Patch\";\ntext(await tools.apply_patch(patch));","internal_chat_message_metadata_passthrough":{"turn_id":"019f756f-5147-7222-9084-187ed68d3651"}}}
