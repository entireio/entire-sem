ry, checkout = frozen_repository(tmp_path, \\\"entire-graph\\\")\\n+    calls = []\\n+\\n+    def fake_run(command, **_kwargs):\\n+        calls.append(command)\\n+        cache = Path(command[command.index(\\\"--cache-dir\\\") + 1])\\n+        cache.mkdir(parents=True, exist_ok=True)\\n+        (cache / \\\"snapshot.gz\\\").write_bytes(b\\\"index\\\")\\n+        response = {\\n+            \\\"repo_root\\\": str(checkout.resolve()), \\\"commit\\\": repository[\\\"commit\\\"],\\n+            \\\"tree\\\": repository[\\\"tree\\\"], \\\"profile\\\": \\\"full\\\",\\n+            \\\"index_cache_hit\\\": len(calls) > 1,\\n+        }\\n+        return subprocess.CompletedProcess(command, 0, json.dumps(response).encode(), b\\\"\\\")\\n+\\n+    monkeypatch.setattr(smoke.runtime, \\\"run_command\\\", fake_run)\\n+    setup = smoke.setup_treatment_index(\\n+        repository, \\\"entire-graph\\\", tmp_path / \\\"output\\\",\\n+        graph=Path(\\\"/runtime/entire-graph\\\"), cbm=Path(\\\"/runtime/cbm\\\"),\\n+        runtime_path_prefix=\\\"\\\", timeout_seconds=30,\\n+    )\\n+    assert len(calls) == 2\\n+    assert setup[\\\"validation\\\"][\\\"validation_cache_hit\\\"] is True\\n+    assert setup[\\\"validation\\\"][\\\"cache_inventory\\\"]\\n+    assert setup[\\\"setup_wall_time_ms\\\"] >= 1\\n+\\n+\\n+def test_cbm_degraded_setup_fails_before_paid_execution(tmp_path, monkeypatch):\\n+    repository, _checkout = frozen_repository(tmp_path, \\\"cbm\\\")\\n+\\n+    def fake_run(command, **_kwargs):\\n+        response = {\\\"project\\\": \\\"example\\\", \\\"status\\\": \\\"degraded\\\", \\\"nodes\\\": 0, \\\"error\\\": None}\\n+        return subprocess.CompletedProcess(command, 0, json.dumps(response).encode(), b\\\"\\\")\\n+\\n+    monkeypatch.setattr(smoke.runtime, \\\"run_command\\\", fake_run)\\n+    with pytest.raises(smoke.SmokeError, match=\\\"not healthy\\\"):\\n+        smoke.setup_treatment_index(\\n+            repository, \\\"cbm\\\", tmp_path / \\\"output\\\",\\n+            graph=Path(\\\"/runtime/entire-graph\\\"), cbm=Path(\\\"/runtime/cbm\\\"),\\n+            runtime_path_prefix=\\\"\\\", timeout_seconds=30,\\n+        )\\n+    assert not (tmp_path / \\\"output\\\" / \\\"records\\\" / \\\"repo-01\\\" / \\\"cbm\\\" / \\\"setup.json\\\").exists()\\n*** End Patch\";\ntext(await tools.apply_patch(patch));","internal_chat_message_metadata_passthrough":{"turn_id":"019f756f-5147-7222-9084-187ed68d3651"}}}
