./generated/ts.js\";\ninternal/sem/provider_test.go:13518:\t\tt.Errorf(\"missing TypeScript generated namespace import CALLS createGetSourceFile->createSourceFile: %#v\", relationsOfType(snapshot.Relations, \"CALLS\"))\ninternal/sem/provider_test.go:13878:// In an ordinary repo (no vendored CPython stdlib) os.path.* calls must emit\n"}],"internal_chat_message_metadata_passthrough":{"turn_id":"019f756f-5147-7222-9084-187ed68d3651"}}}
