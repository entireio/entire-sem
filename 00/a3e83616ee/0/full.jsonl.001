{"timestamp":"2026-07-18T13:36:37.469Z","type":"response_item","payload":{"type":"custom_tool_call_output","id":"ctco_019f7571-745d-7640-914f-ec65ab68e40c","call_id":"call_KYB0xpGaRQdkqiKTaszXgE8H","output":[{"type":"input_text","text":"Script completed\nWall time 0.4 seconds\nOutput:\n"},{"type":"input_text","text":"            \"rank\": len(results) + 1,\n            \"score\": row.get(\"rank\"),\n            \"file_path\": file_path,\n            \"start_line\": start_line,\n            \"end_line\": int(row.get(\"end_line\") or start_line),\n            \"name\": row.get(\"name\"),\n            \"qualified_name\": row.get(\"qualified_name\"),\n            \"kind\": row.get(\"label\"),\n        })\n    return results\n\n\ndef cbm_results(\n    checkout: Path,\n    case: dict[str, Any],\n    config: dict[str, Any],\n    binary: Path,\n    cache_root: Path,\n) -> tuple[list[dict[str, Any]], dict[str, Any]]:\n    case_state = cache_root / case[\"id\"]\n    if case_state.exists():\n        shutil.rmtree(case_state)\n    case_cache = case_state / \"cache\"\n    home = case_state / \"home\"\n    xdg_cache = case_state / \"xdg-cache\"\n    xdg_config = case_state / \"xdg-config\"\n    temporary = case_state / \"tmp\"\n    for directory in (case_cache, home, xdg_cache, xdg_config, temporary):\n        directory.mkdir(parents=True)\n    environment = {\n        \"HOME\": str(home),\n        \"XDG_CACHE_HOME\": str(xdg_cache),\n        \"XDG_CONFIG_HOME\": str(xdg_config),\n        \"TMPDIR\": str(temporary),\n    }\n    traces = []\n    try:\n        indexed, trace, error = cbm_call(\n            binary,\n            case_cache,\n            \"index_repository\",\n            {\"repo_path\": str(checkout)},\n            config[\"index_timeout_seconds\"],\n            environment,\n        )\n        traces.append(trace)\n        if error:\n            raise ValueError(f\"CBM index failed: {error}\")\n        project = cbm_project_name(checkout)\n        if indexed.get(\"status\") != \"indexed\" or indexed.get(\"project\") != project:\n            raise ValueError(\"CBM index response does not identify the indexed project\")\n        if directory_bytes(case_state) <= 0:\n            raise ValueError(\"CBM_CACHE_DIR did not receive a persistent project index\")\n        payload = {\n            \"project\": project,\n            \"query\": case[\"query\"],\n            \"limit\": config[\"maximum_results\"],\n        }\n        if config.get(\"query_tool\") != \"search_graph\" or config.get(\"repeat_queries\") != 2:\n            raise ValueError(\"CBM query tool or repeat count differs from the adapter contract\")\n        responses = []\n        ranked_responses = []\n        persistent_index_bytes = 0\n        for attempt in range(config[\"repeat_queries\"]):\n            response, trace, error = cbm_call(\n                binary,\n                case_cache,\n                config[\"query_tool\"],\n                payload,\n                config[\"query_timeout_seconds\"],\n                environment,\n        )\n    with pytest.raises(ValueError, match=\"missing\"):\n        MODULE.validate_cbm_search_response({}, 7)\n\n\ndef test_cbm_project_name_preserves_lexical_tmp_path():\n    assert MODULE.cbm_project_name(Path(\"/tmp/case\")) == \"tmp-case\"\n\n\ndef test_cbm_adapter_uses_native_limit_and_persistent_isolation(tmp_path, monkeypatch):\n    checkout = tmp_path / \"checkout\"\n    checkout.mkdir()\n    cache_root = tmp_path / \"cache\"\n    calls = []\n\n    def fake_call(_binary, cache_dir, tool, payload, _timeout, environment=None):\n        calls.append((tool, payload))\n        assert environment is not None\n        assert environment[\"HOME\"].endswith(\"/home\")\n        if tool == \"index_repository\":\n            cache_dir.mkdir(parents=True, exist_ok=True)\n            (cache_dir / \"project.db\").write_bytes(b\"index\")\n            return {\n                \"project\": MODULE.cbm_project_name(checkout),\n                \"status\": \"indexed\",\n                \"nodes\": 1,\n                \"edges\": 0,\n            }, {\"tool\": tool}, None\n        response = {\n            \"results\": [{\n                \"file_path\": \"src/router.go\",\n                \"start_line\": 4,\n                \"end_line\": 4,\n                \"name\": f\"Router-{len(calls)}\",\n                \"rank\": -1.0,\n            }],\n            \"total\": 1,\n            \"has_more\": False,\n        }\n        return response, {\"tool\": tool}, None\n\n    monkeypatch.setattr(MODULE, \"cbm_call\", fake_call)\n    config = comparison_config()[\"cbm\"]\n    results, retrieval = MODULE.cbm_results(\n        checkout,\n        {\"id\": \"case-a\", \"query\": \"router\"},\n        config,\n        Path(\"/fake/cbm\"),\n        cache_root,\n    )\n\n    assert results[0][\"file_path\"] == \"src/router.go\"\n    assert calls[0] == (\"index_repository\", {\"repo_path\": str(checkout)})\n    assert calls[1][1][\"limit\"] == 100\n    assert \"max_results\" not in calls[1][1]\n    assert len(calls) == 3\n    assert retrieval[\"persistent_index_bytes\"] > 0\n    assert retrieval[\"repeat_identical\"] is True\n    assert retrieval[\"measurements\"][\"repeat_identical\"] is True\n    assert retrieval[\"measurements\"][\"persistent_index_bytes\"] > 0\n    assert not (cache_root / \"case-a\").exists()\n            },\n        },\n        \"limitations\": {\"type\": \"array\", \"items\": {\"type\": \"string\"}},\n        \"confidence\": {\"type\": \"string\", \"enum\": [\"high\", \"medium\", \"low\"]},\n    },\n    \"required\": [\"summary\", \"tests\", \"limitations\", \"confidence\"],\n}\n\n\ndef mcp_config(system: str, output: Path, cbm_binary: Path, cache_dir: Path) -> Path:\n    case_name = cache_dir.parent.parent.name\n    path = output / \"runtime\" / \"mcp\" / f\"{case_name}-{system}.json\"\n    if system == \"cbm\":\n        value = {\n            \"mcpServers\": {\n                \"codebase-memory-mcp\": {\n                    \"command\": str(cbm_binary),\n                    \"args\": [],\n                    \"env\": {\"CBM_CACHE_DIR\": str(cache_dir)},\n                }\n            }\n        }\n    else:\n        value = {\"mcpServers\": {}}\n    canonical_write(path, value)\n    return path\n\n\ndef claude_command(\n    *,\n    claude_binary: Path,\n    model: str,\n    max_budget_usd: float,\n    max_turns: int,\n    system: str,\n    prompt: str,\n    mcp_path: Path,\n    graph_binary: Path,\n) -> list[str]:\n    builtins = {\n        \"file-tools\": \"Read,Grep,Glob,Bash,Edit,Write\",\n        \"entire-graph\": \"Read,Grep,Glob,Bash,Edit,Write\",\n        \"cbm\": \"Read,Grep,Glob,Bash,Edit,Write\",\n    }[system]\n    if system == \"file-tools\":\n        allowed = builtins\n    else:\n        allowed_tools = [\n            \"Read\",\n            \"Grep\",\n            \"Glob\",\n            \"Edit\",\n            \"Write\",\n            \"Bash\",\n            \"Bash(git status:*)\",\n            \"Bash(git diff:*)\",\n            \"Bash(git --no-pager diff:*)\",\n            \"Bash(cmake:*)\",\n            \"Bash(ctest:*)\",\n            \"Bash(make:*)\",\n            \"Bash(ninja:*)\",\n            \"Bash(pytest:*)\",\n            \"Bash(python -m pytest:*)\",\n            \"Bash(go test:*)\",\n            \"Bash(cargo test:*)\",\n            \"Bash(npm test:*)\",\n            \"Bash(npm run test:*)\",\n            \"Bash(pnpm test:*)\",\n            \"Bash(pnpm run test:*)\",\n            \"Bash(yarn test:*)\",\n            \"Bash(tsc:*)\",\n        ]\n        if system == \"entire-graph\":\n            allowed_tools.append(f\"Bash({graph_binary} search:*)\")\n        else:\n            allowed_tools.append(\"mcp__codebase-memory-mcp\")\n        allowed = \",\".join(allowed_tools)\n    disallowed_tools = [\"WebFetch\", \"WebSearch\"]\n    if system in {\"entire-graph\", \"cbm\"}:\n        disallowed_tools.extend(\n            [\n                \"Bash(git log:*)\",\n                \"Bash(git show:*)\",\n                \"Bash(git blame:*)\",\n                \"Bash(git fetch:*)\",\n                \"Bash(git pull:*)\",\n                \"Bash(git clone:*)\",\n                \"Bash(curl:*)\",\n                \"Bash(wget:*)\",\n                \"Bash(ssh:*)\",\n                \"Bash(scp:*)\",\n            ]\n        )\n    return [\n        str(claude_binary),\n        \"-p\",\n        prompt,\n        \"--output-format\",\n        \"stream-json\",\n        \"--verbose\",\n        \"--model\",\n"}],"internal_chat_message_metadata_passthrough":{"turn_id":"019f756f-5147-7222-9084-187ed68d3651"}}}
