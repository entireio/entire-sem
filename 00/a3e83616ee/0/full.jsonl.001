_calls\\\"] == 1\\n+    assert neighbors[\\\"passed\\\"]\\n+    assert neighbors[\\\"entire_graph_neighbor_calls\\\"] == 1\\n+\\n+\\n+def test_smoke_audit_rejects_graph_cache_misses_and_timed_cbm_indexing(monkeypatch):\\n+    graph = Path(\\\"/runtime/entire-graph\\\")\\n+    monkeypatch.setattr(\\n+        smoke.runtime,\\n+        \\\"audit_treatment\\\",\\n+        lambda *_args: {\\\"passed\\\": True, \\\"violations\\\": []},\\n+    )\\n+    monkeypatch.setattr(smoke.runtime, \\\"bash_command\\\", lambda tool: tool.get(\\\"command\\\", \\\"\\\"))\\n+    invalid = smoke.audit_smoke_treatment(\\n+        \\\"entire-graph\\\",\\n+        [{\\\"command\\\": f\\\"{graph} neighbors --repo . --symbol X --format agent --worktree --no-cache\\\"}],\\n+        graph, graph_cache=Path(\\\"/runtime/cache\\\"),\\n+    )\\n+    assert \\\"entire_graph_retrieval_not_bound_to_preindexed_head\\\" in invalid[\\\"violations\\\"]\\n+    assert \\\"entire_graph_retrieval_wrong_cache\\\" in invalid[\\\"violations\\\"]\\n+\\n+    indexed = smoke.audit_smoke_treatment(\\n+        \\\"cbm\\\",\\n+        [{\\\"name\\\": \\\"mcp__codebase-memory-mcp__index_repository\\\", \\\"input\\\": {\\\"repo_path\\\": \\\".\\\"}}],\\n+        graph, cbm_project=\\\"project-a\\\",\\n+    )\\n+    assert \\\"cbm_mutated_index_during_timed_task\\\" in indexed[\\\"violations\\\"]\\n+    assert \\\"missing_cbm_retrieval\\\" in indexed[\\\"violations\\\"]\\n*** End Patch\";\ntext(await tools.apply_patch(patch));","internal_chat_message_metadata_passthrough":{"turn_id":"019f756f-5147-7222-9084-187ed68d3651"}}}
