{"timestamp":"2026-07-18T14:17:06.803Z","type":"response_item","payload":{"type":"custom_tool_call_output","id":"ctco_019f7596-85f2-7ff0-854d-7eca04ded0a3","call_id":"call_54ytdKydtkvULRC7L4TOh5AP","output":[{"type":"input_text","text":"Script completed\nWall time 0.2 seconds\nOutput:\n"},{"type":"input_text","text":"#!/usr/bin/env python3\n\"\"\"Run a frozen three-repository agentic smoke through Claude Code treatments.\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport concurrent.futures\nimport json\nimport os\nimport re\nimport shutil\nimport subprocess\nimport sys\nimport time\nfrom collections import defaultdict\nfrom pathlib import Path\nfrom typing import Any\n\nimport agentic_parity\nimport run_graph_agentic_repair_pilot as runtime\nimport sem_v7_artifacts as artifacts\n\n\nROOT = Path(__file__).resolve().parents[2]\nDEFAULT_MANIFEST = ROOT / \"competitive-eval\" / \"agentic-tasks-smoke\" / \"manifest.json\"\nSUITE = \"entire_graph_agentic_mini_v1\"\nORACLE_SUITE = \"entire_graph_oracle_agentic_overlay_v1\"\nMEASUREMENT_PROTOCOL = \"preindexed-agentic-v2\"\nSYSTEMS = (\"file-tools\", \"entire-graph\", \"cbm\")\nROTATIONS = (\n    SYSTEMS,\n    (\"entire-graph\", \"cbm\", \"file-tools\"),\n    (\"cbm\", \"file-tools\", \"entire-graph\"),\n)\n\n\nclass SmokeError(ValueError):\n    pass\n\n\ndef canonical_write(path: Path, value: Any) -> str:\n    path.parent.mkdir(parents=True, exist_ok=True)\n    data = artifacts.canonical_bytes(value)\n    path.write_bytes(data)\n    return artifacts.sha256_bytes(data)\n\n\ndef load_manifest(path: Path) -> dict[str, Any]:\n    manifest = artifacts.read_canonical_json(path, expected_type=dict).document\n    common_invalid = (\n        manifest.get(\"development_only\") is not True\n        or manifest.get(\"confirmatory_use_allowed\") is not False\n        or manifest.get(\"repository_count\") != 3\n    )\n    if common_invalid or manifest.get(\"suite\") not in {SUITE, ORACLE_SUITE}:\n        raise SmokeError(\"manifest is not the frozen three-repository Tasks smoke\")\n    if manifest[\"suite\"] == SUITE:\n        if manifest.get(\"case_count\") != 18:\n            raise SmokeError(\"retained Tasks smoke must contain 18 cases\")\n        for repository in manifest[\"repositories\"]:\n            for task in repository[\"tasks\"]:\n                task_path = ROOT / task[\"path\"]\n                if artifacts.sha256_file(task_path) != task[\"sha256\"]:\n                    raise SmokeError(f\"retained task commitment changed: {task['path']}\")\n    else:\n        if manifest.get(\"case_count\") != 12:\n            raise SmokeError(\"compiler-oracle overlay must contain 12 cases\")\n        boundary = manifest.get(\"claim_boundary\", {})\n        if boundary.get(\"callgraph_oracle_complete\") is not True:\n            raise SmokeError(\"compiler-oracle overlay must declare complete callgraph scope\")\n    return manifest\n\n\ndef oracle_case(case: dict[str, Any]) -> dict[str, Any]:\n    \"\"\"Convert a frozen oracle case to the runner's controller-only shape.\"\"\"\n    def expected_location(value: dict[str, Any]) -> dict[str, Any]:\n        return {\n            \"name\": value[\"name\"], \"file_path\": value[\"file\"],\n            \"line\": value[\"line\"], \"symbol_kind\": value[\"kind\"],\n        }\n\n    category = case[\"category\"]\n    if category == \"symbol_discovery\":\n        expected = {\n            \"kind\": \"definition\", \"complete\": True,\n        \"stage\": \"complete_posthoc_parser_rescore\",\n        \"scorer_sha256\": sha256_file(Path(__file__).resolve()),\n        \"source_summary_sha256\": sha256_file(source_summary),\n        \"systems\": aggregate(updated_records),\n        \"attempts\": provenance,\n        \"claim_boundary\": {\n            \"agent_outcomes_measured\": True,\n            \"controller_future_test_acceptance_measured\": False,\n            \"full_upstream_acceptance_measured\": False,\n            \"reference_overlap_is_task_correctness\": False,\n            \"workflow_completion_is_task_correctness\": False,\n            \"development_only\": True,\n            \"raw_records_mutated\": False,\n        },\n    }\n    canonical_write(output / \"rescored-summary.json\", summary)\n    write_report(output, summary, \"rescored-scoreboard.md\")\n    return summary\n\n\ndef executable_binding(path: Path, arguments: list[str]) -> dict[str, Any]:\n    resolved = path.resolve(strict=True)\n    if not os.access(resolved, os.X_OK):\n        raise PilotError(f\"executable is not runnable: {resolved}\")\n    process = run_command([str(resolved), *arguments], timeout=30)\n    if process.returncode != 0:\n        raise PilotError(f\"version probe failed: {resolved}\")\n    first = (process.stdout + process.stderr).decode(\"utf-8\", \"replace\").splitlines()\n    return {\n        \"sha256\": sha256_file(resolved),\n        \"version_first_line\": first[0] if first else \"\",\n    }\n\n\ndef build_parser() -> argparse.ArgumentParser:\n    parser = argparse.ArgumentParser(description=__doc__)\n    parser.add_argument(\n        \"command\", choices=(\"prepare\", \"bootstrap\", \"run\", \"accept\", \"rescore\", \"all\")\n    )\n    parser.add_argument(\"--output\", type=Path, required=True)\n    parser.add_argument(\"--manifest\", type=Path, default=DEVELOPMENT / \"manifest.json\")\n    parser.add_argument(\"--repository-catalog\", type=Path, default=DEVELOPMENT / \"repository-catalog.json\")\n    parser.add_argument(\"--judgments\", type=Path, default=DEVELOPMENT / \"judgments.json\")\n    parser.add_argument(\n        \"--public-capture-catalog\",\n        type=Path,\n        help=\"pre-selection GitHub metadata capture catalog; required for prepare/all\",\n    )\n    parser.add_argument(\"--claude-binary\", type=Path, required=True)\n    parser.add_argument(\"--graph-binary\", type=Path, required=True)\n    parser.add_argument(\"--cbm-binary\", type=Path, required=True)\n    parser.add_argument(\"--model\", default=\"opus\")\n    parser.add_argument(\"--max-budget-usd\", type=float, default=5.0)\n    parser.add_argument(\"--max-turns\", type=int, default=80)\n    parser.add_argument(\"--timeout-seconds\", type=int, default=1800)\n    parser.add_argument(\"--workers\", type=int, default=3)\n"}],"internal_chat_message_metadata_passthrough":{"turn_id":"019f756f-5147-7222-9084-187ed68d3651"}}}
