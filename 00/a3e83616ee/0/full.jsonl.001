        smoke.run(prepared, tmp_path / \"output\", args)\n+    assert launched == []\n+\n+\n+def test_preindexed_runner_rejects_legacy_evidence_directory(tmp_path, monkeypatch):\n+    output = tmp_path / \"output\"\n+    output.mkdir()\n+    smoke.canonical_write(output / \"execution-config.json\", {\"schema_version\": 1})\n+    args = runner_args(tmp_path)\n+    monkeypatch.setattr(smoke.runtime, \"executable_binding\", lambda *_args: {\"sha256\": \"fixture\"})\n+    prepared = {\"suite\": smoke.ORACLE_SUITE, \"repositories\": []}\n+    with pytest.raises(smoke.SmokeError, match=\"legacy evidence directory\"):\n+        smoke.run(prepared, output, args)\n+\n+\n def test_prompt_defines_file_level_and_imported_path_semantics():\n","move_path":null}},"status":"completed"}}
