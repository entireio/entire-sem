{"timestamp":"2026-07-18T13:43:54.820Z","type":"event_msg","payload":{"type":"token_count","info":{"total_token_usage":{"input_tokens":927794896,"cached_input_tokens":914681344,"cache_write_input_tokens":0,"output_tokens":1288390,"reasoning_output_tokens":296103,"total_tokens":929083286},"last_token_usage":{"input_tokens":136500,"cached_input_tokens":133888,"cache_write_input_tokens":0,"output_tokens":96,"reasoning_output_tokens":11,"total_tokens":136596},"model_context_window":258400},"rate_limits":{"limit_id":"codex","limit_name":null,"primary":{"used_percent":24.0,"window_minutes":10080,"resets_at":1784955710},"secondary":null,"credits":{"has_credits":false,"unlimited":false,"balance":"0"},"individual_limit":null,"spend_control_reached":null,"plan_type":"pro","rate_limit_reached_type":null}}}
