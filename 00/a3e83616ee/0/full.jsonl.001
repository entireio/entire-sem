   lines = [title, \"\", scope, \"\", f\"| System | {quality_label} | Macro recall | Micro recall | Tool calls | Wall time (s) | Provider input incl. cache | Output tokens | Cost (USD) | Compliance |\", \"| --- | ---: | ---: | ---: | ---: | ---: | ---: | ---: | ---: | ---: |\"]\n+    lines = [title, \"\", scope, \"\", f\"| System | {quality_label} | Macro recall | Micro recall | Tool calls | Task wall time, preindexed (s) | Setup/index, excluded (s) | Provider input incl. cache | Output tokens | Cost (USD) | Compliance |\", \"| --- | ---: | ---: | ---: | ---: | ---: | ---: | ---: | ---: | ---: | ---: |\"]\n     for system in systems_to_report:\n         row = systems[system]\n-        lines.append(f\"| {system} | {row['exact_pass_rate']:.3f} | {row['mean_recall']:.3f} | {row['micro_recall']:.3f} | {row['mean_tool_calls']:.1f} | {row['mean_wall_time_ms']/1000:.1f} | {row['provider_input_tokens_including_cache']} | {row['output_tokens']} | {row['reported_cost_usd']:.4f} | {row['treatment_compliance_rate']:.3f} |\")\n+        lines.append(f\"| {system} | {row['exact_pass_rate']:.3f} | {row['mean_recall']:.3f} | {row['micro_recall']:.3f} | {row['mean_tool_calls']:.1f} | {row['mean_task_wall_time_ms']/1000:.1f} | {row['mean_setup_wall_time_ms']/1000:.1f} | {row['provider_input_tokens_including_cache']} | {row['output_tokens']} | {row['reported_cost_usd']:.4f} | {row['treatment_compliance_rate']:.3f} |\")\n     (output / \"scoreboard.md\").write_text(\"\\n\".join(lines) + \"\\n\", encoding=\"utf-8\")\n     return summary\n \n@@ -690,8 +974,16 @@ def run(prepared: dict[str, Any], output: Path, args: argparse.Namespace) -> dic\n     unknown_repositories = selected_repositories - available_repositories\n     if unknown_repositories:\n         raise SmokeError(f\"unknown --repositories values: {sorted(unknown_repositories)}\")\n+    if args.workers != 1:\n+        raise SmokeError(\"preindexed-agentic-v2 requires --workers 1 for uncontended latency measurement\")\n+    existing_config = output / \"execution-config.json\"\n+    if existing_config.is_file():\n+        previous = artifacts.read_canonical_json(existing_config, expected_type=dict).document\n+        if previous.get(\"measurement_protocol\") != MEASUREMENT_PROTOCOL:\n+            raise SmokeError(\"refusing to run the preindexed protocol in a legacy evidence directory\")\n     execution_config = {\n         \"schema_version\": 1,\n+        \"measurement_protocol\": MEASUREMENT_PROTOCOL,\n         \"suite\": prepared[\"suite\"],\n         \"model\": args.model,\n         \"max_turns_per_attempt\": args.max_turns,\n@@ -708,6 +1000,21 @@ def run(prepared: dict[str, Any], output: Path, args: argparse.Namespace) -> dic\n         \"runner_sha256\": artifacts.sha256_file(Path(__file__).resolve()),\n     }\n     canonical_write(output / \"execution-config.json\", execution_config)\n+    graph = args.graph_binary.resolve(strict=True)\n+    cbm = args.cbm_binary.resolve(strict=True)\n+    setups_by_key: dict[tuple[str, str], dict[str, Any]] = {}\n+    # Fail closed before launching any paid process. Index setup is deliberately\n+    # sequential so comparator indexing never competes for local CPU or I/O.\n+    for repo in prepared[\"repositories\"]:\n+        if repo[\"repository\"] not in selected_repositories:\n+            continue\n+        for system in selected_systems:\n+            setup = load_or_setup_treatment_index(\n+                repo, system, output, graph=graph, cbm=cbm,\n+                runtime_path_prefix=args.runtime_path_prefix,\n+                timeout_seconds=args.timeout_seconds,\n+            )\n+            setups_by_key[(repo[\"repository\"], system)] = setup\n     records_by_key: dict[tuple[str, str], dict[str, Any]] = {}\n     for repo in prepared[\"repositories\"]:\n         if repo[\"repository\"] not in selected_repositories:\n@@ -736,9 +1043,10 @@ def run(prepared: dict[str, Any], output: Path, args: argparse.Namespace) -> dic\n             futures = {\n                 executor.submit(\n                     execute_one, repo, system, output, claude=args.claude_binary.resolve(strict=True),\n-                    graph=args.graph_binary.resolve(strict=True), cbm=args.cbm_binary.resolve(strict=True),\n+                    graph=graph, cbm=cbm,\n                     model=args.model, max_turns=args.max_turns, max_budget_usd=args.max_budget_usd,\n                     timeout_seconds=args.timeout_seconds, runtime_path_prefix=args.runtime_path_prefix,\n+                    setup=setups_by_key[(repo[\"repository\"], system)],\n                 ): (repo, system) for repo, system in attempts\n             }\n             for future in concurrent.futures.as_completed(futures):\n@@ -764,7 +1072,7 @@ def build_parser() -> argparse.ArgumentParser:\n     parser.add_argument(\"--max-turns\", type=int, default=24)\n     parser.add_argument(\"--max-budget-usd\", type=float, default=5.0)\n     parser.add_argument(\"--timeout-seconds\", type=int, default=1200)\n-    parser.add_argument(\"--workers\", type=int, default=3)\n+    parser.add_argument(\"--workers\", type=int, default=1)\n     parser.add_argument(\"--systems\", nargs=\"+\", choices=SYSTEMS, default=list(SYSTEMS))\n     parser.add_argument(\"--repositories\", nargs=\"+\")\n     parser.add_argument(\"--runtime-path-prefix\", default=\"\")\ndiff --git a/competitive-eval/tools/test_run_agentic_tasks_smoke.py b/competitive-eval/tools/test_run_agentic_tasks_smoke.py\nindex bb26336..94f320b 100644\n--- a/competitive-eval/tools/test_run_agentic_tasks_smoke.py\n+++ b/competitive-eval/tools/test_run_agentic_tasks_smoke.py\n@@ -1,5 +1,9 @@\n+import json\n import subprocess\n from pathlib import Path\n+from types import SimpleNamespace\n+\n+import pytest\n \n import run_agentic_tasks_smoke as smoke\n \n@@ -121,7 +125,31 @@ def test_structured_result_accepts_cli_object_or_json_string():\n     assert smoke.structured_result({\"result\": '{\"answers\":[]}'}) == {\"answers\": []}\n \n \n-def test_smoke_audit_requires_neighbors_for_graph(monkeypatch):\n+def test_smoke_audit_accepts_one_preindexed_graph_retrieval(monkeypatch):\n+    graph = Path(\"/runtime/entire-graph\")\n+    cache = Path(\"/runtime/cache\")\n+    monkeypatch.setattr(\n+        smoke.runtime,\n+        \"audit_treatment\",\n+        lambda *_args: {\"passed\": True, \"violations\": []},\n+    )\n+    monkeypatch.setattr(smoke.runtime, \"bash_command\", lambda tool: tool.get(\"command\", \"\"))\n+    search = smoke.audit_smoke_treatment(\n+        \"entire-graph\",\n+        [{\"command\": f'{graph} search --repo . --query x --format agent --head --profile full --index-all-files --cache-dir \"{cache}\"', \"result\": {\"content\": \"Index: cache-hit (1ms)\"}}],\n+        graph, graph_cache=cache,\n+    )\n+    assert search[\"passed\"]\n+    neighbors = smoke.audit_smoke_treatment(\n+        \"entire-graph\",\n+        [{\"command\": f'{graph} neighbors --repo . --symbol X --format agent --head --profile full --cache-dir \"{cache}\"', \"result\": {\"content\": \"Index: cache-hit (1ms)\"}}],\n+        graph, graph_cache=cache,\n+    )\n+    assert neighbors[\"passed\"]\n+    assert neighbors[\"entire_graph_neighbor_calls\"] == 1\n+\n+\n+def test_smoke_audit_rejects_graph_cache_misses_and_timed_cbm_indexing(monkeypatch):\n     graph = Path(\"/runtime/entire-graph\")\n     monkeypatch.setattr(\n         smoke.runtime,\n@@ -129,15 +157,21 @@ def test_smoke_audit_requires_neighbors_for_graph(monkeypatch):\n         lambda *_args: {\"passed\": True, \"violations\": []},\n     )\n     monkeypatch.setattr(smoke.runtime, \"bash_command\", lambda tool: tool.get(\"command\", \"\"))\n-    missing = smoke.audit_smoke_treatment(\n-        \"entire-graph\", [{\"command\": f\"{graph} search --repo . --query x --format agent\"}], graph\n+    invalid = smoke.audit_smoke_treatment(\n+        \"entire-graph\",\n+        [{\"command\": f\"{graph} neighbors --repo . --symbol X --format agent --worktree --no-cache\"}],\n+        graph, graph_cache=Path(\"/runtime/cache\"),\n     )\n-    assert missing[\"violations\"] == [\"missing_entire_graph_neighbors\"]\n-    present = smoke.audit_smoke_treatment(\n-        \"entire-graph\", [{\"command\": f\"{graph} neighbors --repo . --symbol X\"}], graph\n+    assert \"entire_graph_retrieval_not_bound_to_preindexed_head\" in invalid[\"violations\"]\n+    assert \"entire_graph_retrieval_wrong_cache\" in invalid[\"violations\"]\n+\n+    indexed = smoke.audit_smoke_treatment(\n+        \"cbm\",\n+        [{\"name\": \"mcp__codebase-memory-mcp__index_repository\", \"input\": {\"repo_path\": \".\"}}],\n+        graph, cbm_project=\"project-a\",\n     )\n-    assert present[\"passed\"]\n-    assert present[\"entire_graph_neighbor_calls\"] == 1\n+    assert \"cbm_mutated_index_during_timed_task\" in indexed[\"violations\"]\n+    assert \"missing_cbm_retrieval\" in indexed[\"violations\"]\n \n \n def test_pristine_checkout_rejects_dirty_worktree(tmp_path):\n@@ -161,6 +195,70 @@ def test_pristine_checkout_rejects_dirty_worktree(tmp_path):\n         raise AssertionError(\"dirty checkout passed the smoke guard\")\n \n \n+def frozen_repository(tmp_path, system):\n+    checkout = tmp_path / \"checkouts\" / system\n+    smoke.runtime.checked_git([\"init\", \"--quiet\", str(checkout)])\n+    smoke.runtime.checked_git([\"config\", \"user.name\", \"Test\"], cwd=checkout)\n+    smoke.runtime.checked_git([\"config\", \"user.email\", \"test@example.com\"], cwd=checkout)\n+    (checkout / \"source.py\").write_text(\"value = 1\\n\")\n+    smoke.runtime.checked_git([\"add\", \"source.py\"], cwd=checkout)\n+    smoke.runtime.checked_git([\"commit\", \"--quiet\", \"-m\", \"base\"], cwd=checkout)\n+    head = smoke.runtime.checked_git([\"rev-parse\", \"HEAD\"], cwd=checkout).decode().strip()\n+    tree = smoke.runtime.checked_git([\"rev-parse\", \"HEAD^{tree}\"], cwd=checkout).decode().strip()\n+    return {\n+        \"execution_index\": 1, \"suite\": smoke.ORACLE_SUITE,\n+        \"repository\": \"example/repo\", \"commit\": head, \"tree\": tree,\n+        \"source_repository\": str(checkout), \"checkouts\": {system: str(checkout)},\n+    }, checkout\n+\n+\n+def test_graph_setup_builds_and_validates_cache_before_task(tmp_path, monkeypatch):\n+    repository, checkout = frozen_repository(tmp_path, \"entire-graph\")\n+    calls = []\n+\n+    def fake_run(command, **_kwargs):\n+        calls.append(command)\n+        cache = Path(command[command.index(\"--cache-dir\") + 1])\n+        cache.mkdir(parents=True, exist_ok=True)\n+        (cache / \"snapshot.gz\").write_bytes(b\"index\")\n+        response = {\n+            \"repo_root\": str(checkout.resolve()), \"commit\": repository[\"commit\"],\n+            \"tree\": repository[\"tree\"], \"profile\": \"full\",\n+            \"index_cache_hit\": len(calls) > 1,\n+        }\n+        return subprocess.CompletedProcess(command, 0, json.dumps(response).encode(), b\"\")\n+\n+    monkeypatch.setattr(smoke, \"assert_pristine_checkout\", lambda *_args: None)\n+    monkeypatch.setattr(smoke.runtime, \"run_command\", fake_run)\n+    setup = smoke.setup_treatment_index(\n+        repository, \"entire-graph\", tmp_path / \"output\",\n+        graph=Path(\"/runtime/entire-graph\"), cbm=Path(\"/runtime/cbm\"),\n+        runtime_path_prefix=\"\", timeout_seconds=30,\n+    )\n+    assert len(calls) == 2\n+    assert setup[\"validation\"][\"validation_cache_hit\"] is True\n+    assert setup[\"validation\"][\"cache_inventory\"]\n+    assert setup[\"setup_wall_time_ms\"] >= 1\n+\n+\n+def test_cbm_degraded_setup_fails_before_paid_execution(tmp_path, monkeypatch):\n+    repository, _checkout = frozen_repository(tmp_path, \"cbm\")\n+\n+    def fake_run(command, **_kwargs):\n+        response = {\"project\": \"example\", \"status\": \"degraded\", \"nodes\": 0, \"error\": None}\n+        return subprocess.CompletedProcess(command, 0, json.dumps(response).encode(), b\"\")\n+\n+    monkeypatch.setattr(smoke, \"assert_pristine_checkout\", lambda *_args: None)\n+    monkeypatch.setattr(smoke.runtime, \"run_command\", fake_run)\n+    with pytest.raises(smoke.SmokeError, match=\"not healthy\"):\n+        smoke.setup_treatment_index(\n+            repository, \"cbm\", tmp_path / \"output\",\n+            graph=Path(\"/runtime/entire-graph\"), cbm=Path(\"/runtime/cbm\"),\n+            runtime_path_prefix=\"\", timeout_seconds=30,\n+        )\n+    assert not (tmp_path / \"output\" / \"records\" / \"repo-01\" / \"cbm\" / \"setup.json\").exists()\n+\n+\n def test_smoke_sandbox_checkout_is_read_only(tmp_path):\n     output = tmp_path / \"output\"\n     checkout = output / \"checkouts\" / \"file-tools\"\n@@ -202,6 +300,51 @@ def test_summary_supports_targeted_single_system_followup(tmp_path):\n     assert summary[\"systems\"][\"entire-graph\"][\"retained_assertion_pass_rate\"] == 1.0\n \n \n+def runner_args(tmp_path):\n+    binaries = {}\n+    for name in (\"claude\", \"graph\", \"cbm\"):\n+        path = tmp_path / name\n+        path.write_text(\"fixture\\n\")\n+        binaries[name] = path\n+    return SimpleNamespace(\n+        graph_source_head=\"a\" * 40, systems=[\"entire-graph\"], repositories=None,\n+        model=\"opus\", max_turns=4, max_budget_usd=1.0, timeout_seconds=30,\n+        workers=1, runtime_path_prefix=\"\", claude_binary=binaries[\"claude\"],\n+        graph_binary=binaries[\"graph\"], cbm_binary=binaries[\"cbm\"],\n+    )\n+\n+\n+def test_setup_failure_launches_zero_paid_attempts(tmp_path, monkeypatch):\n+    prepared = {\n+        \"suite\": smoke.ORACLE_SUITE,\n+        \"repositories\": [{\n+            \"repository\": \"example/repo\", \"system_order\": [\"entire-graph\"] * 3,\n+        }],\n+    }\n+    args = runner_args(tmp_path)\n+    launched = []\n+    monkeypatch.setattr(smoke.runtime, \"executable_binding\", lambda *_args: {\"sha256\": \"fixture\"})\n+    monkeypatch.setattr(\n+        smoke, \"load_or_setup_treatment_index\",\n+        lambda *_args, **_kwargs: (_ for _ in ()).throw(smoke.SmokeError(\"setup failed\")),\n+    )\n+    monkeypatch.setattr(smoke, \"execute_one\", lambda *_args, **_kwargs: launched.append(True))\n+    with pytest.raises(smoke.SmokeError, match=\"setup failed\"):\n+        smoke.run(prepared, tmp_path / \"output\", args)\n+    assert launched == []\n+\n+\n+def test_preindexed_runner_rejects_legacy_evidence_directory(tmp_path, monkeypatch):\n+    output = tmp_path / \"output\"\n+    output.mkdir()\n+    smoke.canonical_write(output / \"execution-config.json\", {\"schema_version\": 1})\n+    args = runner_args(tmp_path)\n+    monkeypatch.setattr(smoke.runtime, \"executable_binding\", lambda *_args: {\"sha256\": \"fixture\"})\n+    prepared = {\"suite\": smoke.ORACLE_SUITE, \"repositories\": []}\n+    with pytest.raises(smoke.SmokeError, match=\"legacy evidence directory\"):\n+        smoke.run(prepared, output, args)\n+\n+\n def test_prompt_defines_file_level_and_imported_path_semantics():\n     repository = {\"cases\": [{\"id\": \"case\", \"question\": \"Question?\"}]}\n     prompt = smoke.prompt_for(repository, \"file-tools\", Path(\"/graph\"))\n# Preindexed Agentic Measurement Protocol\n\nThe completed `20260718` compiler-oracle smoke remains immutable diagnostic\nevidence. Its transcripts, raw records, authorization, recovery record,\nscoreboard, report, and overlay documentation are not rescored or rewritten by\nthis protocol.\n\n## Historical comparison boundary\n\nThe historical wall-time comparison is invalid. The timed Entire Graph arm was\nrequired to run an uncached selective `search` and a separately cached full\n`neighbors` build. One Zod attempt also invoked `neighbors` without `--head`,\nwhich forced another worktree build. The CBM arm was instructed to index during\nthe task and repeatedly returned a degraded index. These setup costs were inside\nthe agent timer and competed across concurrent attempts.\n\nThe historical prompt also forced Entire Graph to use `search`, then\n`neighbors`, then file-tool verification. The file-tools arm had no comparable\nminimum workflow. Consequently, task latency cannot be repaired by subtracting\na single observed indexing duration.\n\nRaw transcript facts such as returned answers, provider token billing, and tool\ncalls remain useful diagnostics of that exact treatment. They are not clean\ncausal estimates for the repaired product or corrected protocol.\n\n## Replacement protocol\n\nNew runs use `preindexed-agentic-v2` and a new output directory.\n\n1. Materialize and verify the exact committed repository tree.\n2. Build each product index before any paid agent process starts.\n3. Validate the index against the exact tree, product version, profile, and\n   isolated cache. Any missing, degraded, corrupt, or cache-miss state aborts\n   the whole run before a paid attempt launches.\n4. Record setup/index duration separately from task duration.\n5. Give each product arm symmetric instructions: use its assigned preindexed\n   retrieval system as primary, choose the appropriate retrieval call, and use\n   targeted file reads only when useful. Do not force duplicate verification.\n6. Require timed Entire Graph calls to use the validated committed-tree cache;\n   reject worktree builds, alternate caches, cache misses, and no-cache calls.\n7. Reject CBM indexing or project mutation during a timed task.\n8. Run attempts without concurrent local indexing. Report cached retrieval and\n   end-to-end agent latency separately from setup and incremental-update cost.\n\nThe corrected runner refuses to write into an evidence directory whose\nexecution configuration does not declare `preindexed-agentic-v2`.\n\n## Claim boundary\n\nThe same three repositories are a development regression smoke only. They can\nverify that diagnosed defects no longer recur, but they cannot support a broad\nsuperiority claim after the outcomes have been observed. A claim requires a\nfresh, outcome-blind predefined slice, frozen product and comparator heads,\nexplicit semantics for abstract declarations, constructors, generated mirrors,\nand repeated paired attempts.\n\nNo paid rerun is authorized by this protocol document.\n"}],"internal_chat_message_metadata_passthrough":{"turn_id":"019f756f-5147-7222-9084-187ed68d3651"}}}
