{"timestamp":"2026-07-18T12:47:55.566Z","type":"response_item","payload":{"type":"custom_tool_call_output","call_id":"call_Q2Yh3NJTUaRoMC7Im1QQxfK8","output":[{"type":"input_text","text":"Script completed\nWall time 0.2 seconds\nOutput:\n"},{"type":"input_text","text":"\t\t\tt.Fatalf(\"read golden %s: %v\", name, err)\n\t\t}\n\t\tfor _, line := range strings.Split(strings.TrimSpace(string(data)), \"\\n\") {\n\t\t\tif line == \"\" {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tvar record struct {\n\t\t\t\tRecordType string `json:\"record_type\"`\n\t\t\t\tLanguage   string `json:\"language\"`\n\t\t\t\tKind       string `json:\"kind\"`\n\t\t\t\tType       string `json:\"type\"`\n\t\t\t}\n\t\t\tif err := json.Unmarshal([]byte(line), &record); err != nil {\n\t\t\t\tt.Fatalf(\"parse golden %s: %v\\n%s\", name, err, line)\n\t\t\t}\n\t\t\tswitch record.RecordType {\n\t\t\tcase \"file\":\n\t\t\t\tif record.Language != \"\" {\n\t\t\t\t\tgot.FileLanguages[record.Language]++\n\t\t\t\t}\n\t\t\tcase \"symbol\":\n\t\t\t\tif record.Kind != \"\" {\n\t\t\t\t\tgot.SymbolKinds[record.Kind]++\n\t\t\t\t}\n\t\t\tcase \"relation\":\n\t\t\t\tif record.Type != \"\" {\n\t\t\t\t\tgot.RelationTypes[record.Type]++\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\treportPath := filepath.Join(\"testdata\", \"fixtures\", \"quality_coverage.json\")\n\tvar want goldenFixtureCoverage\n\tdata, err := os.ReadFile(reportPath)\n\tif err != nil {\n\t\tt.Fatalf(\"read quality coverage report: %v\", err)\n\t}\n\tif err := json.Unmarshal(data, &want); err != nil {\n\t\tt.Fatalf(\"parse quality coverage report: %v\", err)\n\t}\n\tif !reflect.DeepEqual(got, want) {\n\t\tgotJSON, _ := json.MarshalIndent(got, \"\", \"  \")\n\t\tt.Fatalf(\"golden fixture quality coverage drifted; update %s\\n%s\", reportPath, gotJSON)\n\t}\n}\n\n// buildFixtureNDJSON copies a fixture into an isolated temp directory (outside\n// any git tree, so repo_key resolves to a stable local/<name>), snapshots it in\n// worktree mode, and returns the normalized NDJSON stream. Worktree mode avoids\n// a machine-specific git error in the no-HEAD warning detail, leaving repo_root\n// as the only path-dependent field, which is normalized below.\nfunc buildFixtureNDJSON(t *testing.T, name string) string {\n\tt.Helper()\n\tsrc := filepath.Join(\"testdata\", \"fixtures\", name)\n\tdir := filepath.Join(t.TempDir(), name)\n\tcopyFixtureTree(t, src, dir)\n\n\tsnapshot, err := BuildProviderSnapshotWithOptions(t.Context(), dir, \"0.0.0-test\", ProviderSnapshotOptions{Worktree: true})\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tvar buf bytes.Buffer\n\tif err := WriteSnapshotNDJSON(&buf, snapshot); err != nil {\n\t\tt.Fatal(err)\n\t}\n\treturn normalizeSnapshotRoot(buf.String(), dir)\ndiff --git a/internal/sem/testdata/fixtures/typescript-oo.ndjson.golden b/internal/sem/testdata/fixtures/typescript-oo.ndjson.golden\nindex 14b9c2f..8fa2f83 100644\n--- a/internal/sem/testdata/fixtures/typescript-oo.ndjson.golden\n+++ b/internal/sem/testdata/fixtures/typescript-oo.ndjson.golden\n@@ -1,8 +1,9 @@\n-{\"schema_version\":\"1.1\",\"provider\":\"entire-graph\",\"provider_version\":\"0.0.0-test\",\"repo_root\":\"<repo>\",\"repo_key\":\"local/typescript-oo\",\"commit\":\"\",\"tree\":\"\",\"languages\":[\"TypeScript\"],\"language_tiers\":{\"TypeScript\":\"semantic\"},\"capabilities\":[\"ndjson\",\"stable-symbol-id-v1\",\"local-only\",\"partial-failures\"],\"schema_features\":[\"boundary_source_locations\",\"completeness_breakdown\",\"language_versions\",\"relation_evidence\",\"relation_resolution\",\"relation_scope\",\"relation_target_kind\"],\"language_versions\":{\"go-tree-sitter\":\"github.com/smacker/go-tree-sitter\"},\"profile\":\"full\",\"profile_limits\":{\"evidence\":\"full\",\"call_resolution\":\"full\"},\"relation_set\":[\"ACCESSES\",\"ASYNC_CALLS\",\"CALLS\",\"CONFIGURES\",\"CONSTRUCTS\",\"CONTAINS\",\"DATA_FLOWS\",\"DEFINES\",\"EMITS\",\"EXTENDS\",\"FILE_CHANGES_WITH\",\"HANDLES_GRAPHQL\",\"HANDLES_GRPC\",\"HANDLES_ROUTE\",\"HANDLES_TOOL\",\"