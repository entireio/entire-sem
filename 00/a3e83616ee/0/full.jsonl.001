Primitive } from \"./helpers/typeAliases.ts\";\nimport { getParsedType, objectUtil, util, ZodParsedType } from \"./helpers/util.ts\";\nimport {\n  IssueData,\n  StringValidation,\n  ZodCustomIssue,\n  ZodError,\n  ZodErrorMap,\n  ZodIssue,\n  ZodIssueCode,\n\n7. src/helpers/parseUtil.ts:66-70 ParseInput\nexport type ParseInput = {\n  data: any;\n  path: (string | number)[];\n  parent: ParseContext;\n};\n\n8. deno/lib/README.md:1939-1939 .parseAsync\n### `.parseAsync`\n\n9. README_ZH.md:1501-1501 .safeParseAsync\n### `.safeParseAsync`\n\n10. deno/lib/helpers/parseUtil.ts:178-178 AsyncParseReturnType\nexport type AsyncParseReturnType<T> = Promise<SyncParseReturnType<T>>;\n"},{"type":"input_text","text":"== zod canonical mirror ranking ==\nIndex: cache-hit (56ms)\n1. src/helpers/parseUtil.ts:189-192 isAsync\nexport const isAsync = <T>(\n  x: ParseReturnType<T>\n): x is AsyncParseReturnType<T> =>\n  typeof Promise !== \"undefined\" && x instanceof Promise;\n\n2. src/types.ts:8-12\n  INVALID,\n  isAborted,\n  isAsync,\n  isDirty,\n  isValid,\n\n3. src/types.ts:225-229 ZodType._parseSync\n  _parseSync(input: ParseInput): SyncParseReturnType<Output> {\n    const result = this._parse(input);\n    if (isAsync(result)) {\n      throw new Error(\"Synchronous parse encountered promise.\");\n    }\n\n4. src/types.ts:290-294 ZodType.safeParseAsync\n\n    const maybeAsyncResult = this._parse({ data, path: ctx.path, parent: ctx });\n    const result = await (isAsync(maybeAsyncResult)\n      ? maybeAsyncResult\n      : Promise.resolve(maybeAsyncResult));\n\n5. src/helpers/parseUtil.ts:187-188 isValid\nexport const isValid = <T>(x: ParseReturnType<T>): x is OK<T> =>\n  (x as any).status === \"valid\";\n\n6. README_ZH.md:77-81\n- [Instanceof](#instanceof)\n- [Function schemas](#function-schemas)\n- [基础类方法 (ZodType)](#zodtype-methods-and-properties)\n  - [.parse](#parse)\n  - [.parseAsync](#parseasync)\n\n7. deno/lib/types.ts:1-18\nimport { defaultErrorMap, getErrorMap } from \"./errors.ts\";\nimport { enumUtil } from \"./helpers/enumUtil.ts\";\nimport { errorUtil } from \"./helpers/errorUtil.ts\";\nimport {\n  addIssueToContext,\n  AsyncParseReturnType,\n  DIRTY,\n  INVALID,\n  isAborted,\n  isAsync,\n  isDirty,\n  isValid,\n  makeIssue,\n  OK,\n  ParseContext,\n  ParseInput,\n  ParseParams,\n  ParsePath,\n\n8. deno/lib/helpers/util.ts:166-220 getParsedType\nexport const getParsedType = (data: any): ZodParsedType => {\n  const t = typeof data;\n\n  switch (t) {\n    case \"undefined\":\n      return ZodParsedType.undefined;\n\n    case \"string\":\n      return ZodParsedType.string;\n\n    case \"number\":\n      return isNaN(data) ? ZodParsedType.nan : ZodParsedType.number;\n\n    case \"boolean\":\n      return ZodParsedType.boolean;\n\n    case \"function\":\n      return ZodParsedType.function;\n\n    case \"bigint\":\n      return ZodParsedType.bigint;\n\n    case \"symbol\":\n      return ZodParsedType.symbol;\n\n    case \"object\":\n      if (Array.isArray(data)) {\n        return ZodParsedType.array;\n      }\n      if (data === null) {\n        return ZodParsedType.null;\n      }\n      if (\n        data.then &&\n        typeof data.then === \"function\" &&\n        data.catch &&\n        typeof data.catch === \"function\"\n      ) {\n        return ZodParsedType.promise;\n      }\n\n9. src/helpers/parseUtil.ts:178-178 AsyncParseReturnType\nexport type AsyncParseReturnType<T> = Promise<SyncParseReturnType<T>>;\n\n10. src/__tests__/async-parsing.test.ts:345-351 base\n  const base = (is_async?: boolean) =>\n    z.object({\n      hello: z.string(),\n      foo: z.object({\n        bar: z.number().refine(is_async ? async () => false : () => false),\n      }),\n    });\n"}],"internal_chat_message_metadata_passthrough":{"turn_id":"019f756f-5147-7222-9084-187ed68d3651"}}}
