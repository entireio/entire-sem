{"timestamp":"2026-07-18T13:49:02.093Z","type":"event_msg","payload":{"type":"token_count","info":{"total_token_usage":{"input_tokens":930569095,"cached_input_tokens":917426176,"cache_write_input_tokens":0,"output_tokens":1294768,"reasoning_output_tokens":298506,"total_tokens":931863863},"last_token_usage":{"input_tokens":165889,"cached_input_tokens":165632,"cache_write_input_tokens":0,"output_tokens":1557,"reasoning_output_tokens":502,"total_tokens":167446},"model_context_window":258400},"rate_limits":{"limit_id":"codex","limit_name":null,"primary":{"used_percent":24.0,"window_minutes":10080,"resets_at":1784955710},"secondary":null,"credits":{"has_credits":false,"unlimited":false,"balance":"0"},"individual_limit":null,"spend_control_reached":null,"plan_type":"pro","rate_limit_reached_type":null}}}
