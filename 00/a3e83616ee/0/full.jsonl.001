{"timestamp":"2026-07-18T14:22:32.508Z","type":"event_msg","payload":{"type":"token_count","info":{"total_token_usage":{"input_tokens":950470251,"cached_input_tokens":937066752,"cache_write_input_tokens":0,"output_tokens":1338456,"reasoning_output_tokens":311017,"total_tokens":951808707},"last_token_usage":{"input_tokens":151301,"cached_input_tokens":149248,"cache_write_input_tokens":0,"output_tokens":143,"reasoning_output_tokens":8,"total_tokens":151444},"model_context_window":258400},"rate_limits":{"limit_id":"codex","limit_name":null,"primary":{"used_percent":27.0,"window_minutes":10080,"resets_at":1784955710},"secondary":null,"credits":{"has_credits":false,"unlimited":false,"balance":"0"},"individual_limit":null,"spend_control_reached":null,"plan_type":"pro","rate_limit_reached_type":null}}}
