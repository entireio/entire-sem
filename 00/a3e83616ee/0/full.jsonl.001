{"timestamp":"2026-07-18T13:59:33.280Z","type":"event_msg","payload":{"type":"token_count","info":{"total_token_usage":{"input_tokens":939956065,"cached_input_tokens":926745344,"cache_write_input_tokens":0,"output_tokens":1312816,"reasoning_output_tokens":301634,"total_tokens":941268881},"last_token_usage":{"input_tokens":213393,"cached_input_tokens":211712,"cache_write_input_tokens":0,"output_tokens":181,"reasoning_output_tokens":69,"total_tokens":213574},"model_context_window":258400},"rate_limits":{"limit_id":"codex","limit_name":null,"primary":{"used_percent":26.0,"window_minutes":10080,"resets_at":1784955710},"secondary":null,"credits":{"has_credits":false,"unlimited":false,"balance":"0"},"individual_limit":null,"spend_control_reached":null,"plan_type":"pro","rate_limit_reached_type":null}}}
