7 12:01:48 +0200 163) \t\tt.Fatal(err)\nf61585cf (Thomas Dohmke 2026-07-17 12:01:48 +0200 164) \t}\nf61585cf (Thomas Dohmke 2026-07-17 12:01:48 +0200 165) \tif len(response.Results) == 0 {\nf61585cf (Thomas Dohmke 2026-07-17 12:01:48 +0200 166) \t\tt.Fatal(\"focused default search returned no results\")\nf61585cf (Thomas Dohmke 2026-07-17 12:01:48 +0200 167) \t}\naf44ca23 (Thomas Dohmke 2026-07-17 12:18:21 +0200 168) \tconst (\naf44ca23 (Thomas Dohmke 2026-07-17 12:18:21 +0200 169) \t\twantMaxLines = 80\naf44ca23 (Thomas Dohmke 2026-07-17 12:18:21 +0200 170) \t\tneedleLine   = 94\naf44ca23 (Thomas Dohmke 2026-07-17 12:18:21 +0200 171) \t)\nf61585cf (Thomas Dohmke 2026-07-17 12:01:48 +0200 172) \tfor _, result := range response.Results {\naf44ca23 (Thomas Dohmke 2026-07-17 12:18:21 +0200 173) \t\tif lines := result.EndLine - result.StartLine + 1; lines > wantMaxLines {\naf44ca23 (Thomas Dohmke 2026-07-17 12:18:21 +0200 174) \t\t\tt.Fatalf(\"default result spans %d lines, want at most %d: %#v\", lines, wantMaxLines, result)\naf44ca23 (Thomas Dohmke 2026-07-17 12:18:21 +0200 175) \t\t}\naf44ca23 (Thomas Dohmke 2026-07-17 12:18:21 +0200 176) \t\tif result.StartLine > needleLine || result.EndLine < needleLine {\naf44ca23 (Thomas Dohmke 2026-07-17 12:18:21 +0200 177) \t\t\tt.Fatalf(\"focused result omitted needle line %d: %#v\", needleLine, result)\nf61585cf (Thomas Dohmke 2026-07-17 12:01:48 +0200 178) \t\t}\nf61585cf (Thomas Dohmke 2026-07-17 12:01:48 +0200 179) \t}\nf61585cf (Thomas Dohmke 2026-07-17 12:01:48 +0200 180) }\nf61585cf (Thomas Dohmke 2026-07-17 12:01:48 +0200 181) \na22500f6 (Thomas Dohmke 2026-07-17 12:47:09 +0200 182) func TestSearchRepositoryBuildsSparseRegionsOnlyForDeepSearch(t *testing.T) {\na22500f6 (Thomas Dohmke 2026-07-17 12:47:09 +0200 183) \trepo := t.TempDir()\na22500f6 (Thomas Dohmke 2026-07-17 12:47:09 +0200 184) \twrite(t, repo, \"source/large.go\", \"package source\\n\"+strings.Repeat(\"// filler line\\n\", 140)+\"// sparse retrieval needle\\n\")\n8e56095b (Thomas Dohmke 2026-07-11 16:15:01 +0200 185) \n"}],"internal_chat_message_metadata_passthrough":{"turn_id":"019f756f-5147-7222-9084-187ed68d3651"}}}
