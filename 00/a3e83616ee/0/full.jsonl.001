{"timestamp":"2026-07-18T14:28:33.189Z","type":"response_item","payload":{"type":"custom_tool_call","id":"ctc_0bd6d73b974b1fab016a5b8d91219c81918058f8513112ab0e","status":"completed","call_id":"call_KRCws2WaaGQauxlJq5hhikMz","name":"exec","input":"const patch = \"*** Begin Patch\\n*** Update File: /private/tmp/brain-bench-graph-agentic-pilot/competitive-eval/tools/test_run_agentic_tasks_smoke.py\\n@@\\n def test_smoke_audit_rejects_graph_cache_misses_and_timed_cbm_indexing(monkeypatch):\\n@@\\n     assert \\\"missing_cbm_retrieval\\\" in indexed[\\\"violations\\\"]\\n+\\n+\\n+def test_smoke_audit_requires_completed_healthy_product_results(monkeypatch):\\n+    graph = Path(\\\"/runtime/entire-graph\\\")\\n+    monkeypatch.setattr(\\n+        smoke.runtime,\\n+        \\\"audit_treatment\\\",\\n+        lambda *_args: {\\\"passed\\\": True, \\\"violations\\\": []},\\n+    )\\n+    monkeypatch.setattr(smoke.runtime, \\\"bash_command\\\", lambda tool: tool.get(\\\"command\\\", \\\"\\\"))\\n+    unfinished = smoke.audit_smoke_treatment(\\n+        \\\"entire-graph\\\",\\n+        [{\\\"command\\\": f\\\"{graph} search --repo . --query x --format agent --head --profile full --cache-dir /runtime/cache\\\"}],\\n+        graph, graph_cache=Path(\\\"/runtime/cache\\\"),\\n+    )\\n+    assert \\\"missing_entire_graph_retrieval\\\" in unfinished[\\\"violations\\\"]\\n+\\n+    unhealthy = smoke.audit_smoke_treatment(\\n+        \\\"cbm\\\",\\n+        [{\\n+            \\\"name\\\": \\\"mcp__codebase-memory-mcp__search_graph\\\",\\n+            \\\"input\\\": {\\\"project\\\": \\\"project-a\\\"},\\n+            \\\"result\\\": {\\\"content\\\": json.dumps({\\\"error\\\": \\\"corrupt index\\\"})},\\n+        }],\\n+        graph, cbm_project=\\\"project-a\\\",\\n+    )\\n+    assert \\\"cbm_retrieval_returned_unhealthy_result\\\" in unhealthy[\\\"violations\\\"]\\n@@\\n def test_graph_setup_builds_and_validates_cache_before_task(tmp_path, monkeypatch):\\n@@\\n     assert setup[\\\"setup_wall_time_ms\\\"] >= 1\\n+\\n+\\n+def test_graph_setup_rejects_empty_or_partial_index(tmp_path, monkeypatch):\\n+    repository, checkout = frozen_repository(tmp_path, \\\"entire-graph\\\")\\n+    calls = []\\n+\\n+    def fake_run(command, **_kwargs):\\n+        calls.append(command)\\n+        cache = Path(command[command.index(\\\"--cache-dir\\\") + 1])\\n+        cache.mkdir(parents=True, exist_ok=True)\\n+        (cache / \\\"snapshot.gz\\\").write_bytes(b\\\"index\\\")\\n+        response = {\\n+            \\\"format_version\\\": 1, \\\"provider\\\": \\\"entire-graph\\\",\\n+            \\\"provider_version\\\": \\\"test-version\\\", \\\"repo_root\\\": str(checkout.resolve()),\\n+            \\\"commit\\\": repository[\\\"commit\\\"], \\\"tree\\\": repository[\\\"tree\\\"],\\n+            \\\"profile\\\": \\\"full\\\", \\\"index_cache_hit\\\": len(calls) > 1,\\n+            \\\"counts\\\": {\\n+                \\\"files\\\": 1, \\\"parsed_files\\\": 1, \\\"symbols\\\": 0,\\n+                \\\"partial_failures\\\": 0, \\\"completeness_level\\\": \\\"ok\\\",\\n+            },\\n+        }\\n+        return subprocess.CompletedProcess(command, 0, json.dumps(response).encode(), b\\\"\\\")\\n+\\n+    monkeypatch.setattr(smoke, \\\"assert_pristine_checkout\\\", lambda *_args: None)\\n+    monkeypatch.setattr(smoke.runtime, \\\"run_command\\\", fake_run)\\n+    with pytest.raises(smoke.SmokeError, match=\\\"incomplete\\\"):\\n+        smoke.setup_treatment_index(\\n+            repository, \\\"entire-graph\\\", tmp_path / \\\"output\\\",\\n+            graph=Path(\\\"/runtime/entire-graph\\\"), cbm=Path(\\\"/runtime/cbm\\\"),\\n+            runtime_path_prefix=\\\"\\\", timeout_seconds=30,\\n+            execution_config_sha256=\\\"config-binding\\\",\\n+        )\\n+\\n+\\n+def test_cbm_nonready_status_fails_closed(tmp_path, monkeypatch):\\n+    repository, _checkout = frozen_repository(tmp_path, \\\"cbm\\\")\\n+    calls = 0\\n+\\n+    def fake_run(command, **_kwargs):\\n+        nonlocal calls\\n+        calls += 1\\n+        response = (\\n+            {\\\"project\\\": \\\"example\\\", \\\"status\\\": \\\"indexed\\\", \\\"nodes\\\": 2}\\n+            if calls == 1\\n+            else {\\\"project\\\": \\\"example\\\", \\\"status\\\": \\\"indexing\\\", \\\"nodes\\\": 2}\\n+        )\\n+        return subprocess.CompletedProcess(command, 0, json.dumps(response).encode(), b\\\"\\\")\\n+\\n+    monkeypatch.setattr(smoke, \\\"assert_pristine_checkout\\\", lambda *_args: None)\\n+    monkeypatch.setattr(smoke.runtime, \\\"run_command\\\", fake_run)\\n+    with pytest.raises(smoke.SmokeError, match=\\\"not healthy\\\"):\\n+        smoke.setup_treatment_index(\\n+            repository, \\\"cbm\\\", tmp_path / \\\"output\\\",\\n+            graph=Path(\\\"/runtime/entire-graph\\\"), cbm=Path(\\\"/runtime/cbm\\\"),\\n+            runtime_path_prefix=\\\"\\\", timeout_seconds=30,\\n+            execution_config_sha256=\\\"config-binding\\\",\\n+        )\\n@@\\n def test_preindexed_runner_rejects_legacy_evidence_directory(tmp_path, monkeypatch):\\n@@\\n     with pytest.raises(smoke.SmokeError, match=\\\"legacy evidence directory\\\"):\\n         smoke.run(prepared, output, args)\\n+\\n+\\n+def test_preindexed_runner_rejects_changed_exact_config(tmp_path, monkeypatch):\\n+    args = runner_args(tmp_path)\\n+    prepared = {\\\"suite\\\": smoke.ORACLE_SUITE, \\\"repositories\\\": []}\\n+    monkeypatch.setattr(smoke.runtime, \\\"executable_binding\\\", lambda *_args: {\\\"sha256\\\": \\\"fixture\\\"})\\n+    monkeypatch.setattr(smoke, \\\"summarize\\\", lambda *_args, **_kwargs: {\\\"ok\\\": True})\\n+    output = tmp_path / \\\"output\\\"\\n+    smoke.run(prepared, output, args)\\n+    args.graph_source_head = \\\"b\\\" * 40\\n+    with pytest.raises(smoke.SmokeError, match=\\\"configuration differs\\\"):\\n+        smoke.run(prepared, output, args)\\n+\\n+\\n+def test_preindexed_runner_rejects_parallel_workers(tmp_path):\\n+    args = runner_args(tmp_path)\\n+    args.workers = 2\\n+    with pytest.raises(smoke.SmokeError, match=\\\"workers 1\\\"):\\n+        smoke.run({\\\"suite\\\": smoke.ORACLE_SUITE, \\\"repositories\\\": []}, tmp_path / \\\"output\\\", args)\\n+\\n+\\n+def test_invalid_treatment_aborts_before_next_paid_attempt(tmp_path, monkeypatch):\\n+    args = runner_args(tmp_path)\\n+    prepared = {\\n+        \\\"suite\\\": smoke.ORACLE_SUITE,\\n+        \\\"repositories\\\": [{\\n+            \\\"repository\\\": \\\"example/repo\\\",\\n+            \\\"system_order\\\": [\\\"entire-graph\\\", \\\"entire-graph\\\", \\\"entire-graph\\\"],\\n+        }],\\n+    }\\n+    launches = []\\n+    monkeypatch.setattr(smoke.runtime, \\\"executable_binding\\\", lambda *_args: {\\\"sha256\\\": \\\"fixture\\\"})\\n+    monkeypatch.setattr(\\n+        smoke, \\\"load_or_setup_treatment_index\\\",\\n+        lambda *_args, **_kwargs: {\\\"record_sha256\\\": \\\"setup\\\"},\\n+    )\\n+    monkeypatch.setattr(smoke, \\\"recover_existing_attempt\\\", lambda *_args, **_kwargs: None)\\n+\\n+    def fail_once(*_args, **_kwargs):\\n+        launches.append(True)\\n+        raise smoke.SmokeError(\\\"timed treatment protocol violation\\\")\\n+\\n+    monkeypatch.setattr(smoke, \\\"execute_one\\\", fail_once)\\n+    with pytest.raises(smoke.SmokeError, match=\\\"protocol violation\\\"):\\n+        smoke.run(prepared, tmp_path / \\\"output\\\", args)\\n+    assert launches == [True]\\n+\\n+\\n+def test_recovery_refuses_started_attempt_without_transcript(tmp_path):\\n+    repository = {\\\"execution_index\\\": 1, \\\"repository\\\": \\\"example/repo\\\"}\\n+    record_root = tmp_path / \\\"records\\\" / \\\"repo-01\\\" / \\\"entire-graph\\\"\\n+    smoke.canonical_write(record_root / \\\"attempt-start.json\\\", {\\\"schema_version\\\": 1})\\n+    with pytest.raises(smoke.SmokeError, match=\\\"no recoverable transcript\\\"):\\n+        smoke.recover_existing_attempt(\\n+            repository, \\\"entire-graph\\\", tmp_path,\\n+            claude=Path(\\\"/runtime/claude\\\"), graph=Path(\\\"/runtime/graph\\\"),\\n+            cbm=Path(\\\"/runtime/cbm\\\"), runtime_path_prefix=\\\"\\\",\\n+            execution_config_sha256=\\\"config\\\", model=\\\"opus\\\", max_turns=4,\\n+            max_budget_usd=1.0,\\n+        )\\n+\\n+\\n+def test_rescore_refuses_legacy_evidence_without_mutation(tmp_path):\\n+    output = tmp_path / \\\"output\\\"\\n+    source = b'{\\\"schema_version\\\":1}\\\\n'\\n+    output.mkdir()\\n+    (output / \\\"execution-config.json\\\").write_bytes(source)\\n+    with pytest.raises(smoke.SmokeError, match=\\\"legacy evidence directory\\\"):\\n+        smoke.rescore({\\\"repositories\\\": []}, output)\\n+    assert (output / \\\"execution-config.json\\\").read_bytes() == source\\n*** End Patch\";\ntext(await tools.apply_patch(patch));\n","internal_chat_message_metadata_passthrough":{"turn_id":"019f756f-5147-7222-9084-187ed68d3651"}}}
{"timestamp":"2026-07-18T14:28:38.405Z","type":"event_msg","payload":{"type":"patch_apply_end","call_id":"exec-6079562e-6738-44e8-b5fd-d73176a964e3","turn_id":"019f756f-5147-7222-9084-187ed68d3651","stdout":"Success. Updated the following files:\nM /private/tmp/brain-bench-graph-agentic-pilot/competitive-eval/tools/test_run_agentic_tasks_smoke.py\n","stderr":"","success":true,"changes":{"/private/tmp/brain-bench-graph-agentic-pilot/competitive-eval/tools/test_run_agentic_tasks_smoke.py":{"type":"update","unified_diff":"@@ -176,2 +176,29 @@\n \n+def test_smoke_audit_requires_completed_healthy_product_results(monkeypatch):\n+    graph = Path(\"/runtime/entire-graph\")\n+    monkeypatch.setattr(\n+        smoke.runtime,\n+        \"audit_treatment\",\n+        lambda *_args: {\"passed\": True, \"violations\": []},\n+    )\n+    monkeypatch.setattr(smoke.runtime, \"bash_command\", lambda tool: tool.get(\"command\", \"\"))\n+    unfinished = smoke.audit_smoke_treatment(\n+        \"entire-graph\",\n+        [{\"command\": f\"{graph} search --repo . --query x --format agent --head --profile full --cache-dir /runtime/cache\"}],\n+        graph, graph_cache=Path(\"/runtime/cache\"),\n+    )\n+    assert \"missing_entire_graph_retrieval\" in unfinished[\"violations\"]\n+\n+    unhealthy = smoke.audit_smoke_treatment(\n+        \"cbm\",\n+        [{\n+            \"name\": \"mcp__codebase-memory-mcp__search_graph\",\n+            \"input\": {\"project\": \"project-a\"},\n+            \"result\": {\"content\": json.dumps({\"error\": \"corrupt index\"})},\n+        }],\n+        graph, cbm_project=\"project-a\",\n+    )\n+    assert \"cbm_retrieval_returned_unhealthy_result\" in unhealthy[\"violations\"]\n+\n+\n def test_pristine_checkout_rejects_dirty_worktree(tmp_path):\n@@ -251,2 +278,59 @@\n \n+def test_graph_setup_rejects_empty_or_partial_index(tmp_path, monkeypatch):\n+    repository, checkout = frozen_repository(tmp_path, \"entire-graph\")\n+    calls = []\n+\n+    def fake_run(command, **_kwargs):\n+        calls.append(command)\n+        cache = Path(command[command.index(\"--cache-dir\") + 1])\n+        cache.mkdir(parents=True, exist_ok=True)\n+        (cache / \"snapshot.gz\").write_bytes(b\"index\")\n+        response = {\n+            \"format_version\": 1, \"provider\": \"entire-graph\",\n+            \"provider_version\": \"test-version\", \"repo_root\": str(checkout.resolve()),\n+            \"commit\": repository[\"commit\"], \"tree\": repository[\"tree\"],\n+            \"profile\": \"full\", \"index_cache_hit\": len(calls) > 1,\n+            \"counts\": {\n+                \"files\": 1, \"parsed_files\": 1, \"symbols\": 0,\n+                \"partial_failures\": 0, \"completeness_level\": \"ok\",\n+            },\n+        }\n+        return subprocess.CompletedProcess(command, 0, json.dumps(response).encode(), b\"\")\n+\n+    monkeypatch.setattr(smoke, \"assert_pristine_checkout\", lambda *_args: None)\n+    monkeypatch.setattr(smoke.runtime, \"run_command\", fake_run)\n+    with pytest.raises(smoke.SmokeError, match=\"incomplete\"):\n+        smoke.setup_treatment_index(\n+            repository, \"entire-graph\", tmp_path / \"output\",\n+            graph=Path(\"/runtime/entire-graph\"), cbm=Path(\"/runtime/cbm\"),\n+            runtime_path_prefix=\"\", timeout_seconds=30,\n+            execution_config_sha256=\"config-binding\",\n+        )\n+\n+\n+def test_cbm_nonready_status_fails_closed(tmp_path, monkeypatch):\n+    repository, _checkout = frozen_repository(tmp_path, \"cbm\")\n+    calls = 0\n+\n+    def fake_run(command, **_kwargs):\n+        nonlocal calls\n+        calls += 1\n+        response = (\n+            {\"project\": \"example\", \"status\": \"indexed\", \"nodes\": 2}\n+            if calls == 1\n+            else {\"project\": \"example\", \"status\": \"indexing\", \"nodes\": 2}\n+        )\n+        return subprocess.CompletedProcess(command, 0, json.dumps(response).encode(), b\"\")\n+\n+    monkeypatch.setattr(smoke, \"assert_pristine_checkout\", lambda *_args: None)\n+    monkeypatch.setattr(smoke.runtime, \"run_command\", fake_run)\n+    with pytest.raises(smoke.SmokeError, match=\"not healthy\"):\n+        smoke.setup_treatment_index(\n+            repository, \"cbm\", tmp_path / \"output\",\n+            graph=Path(\"/runtime/entire-graph\"), cbm=Path(\"/runtime/cbm\"),\n+            runtime_path_prefix=\"\", timeout_seconds=30,\n+            execution_config_sha256=\"config-binding\",\n+        )\n+\n+\n def test_cbm_degraded_setup_fails_before_paid_execution(tmp_path, monkeypatch):\n@@ -357,2 +441,72 @@\n \n+def test_preindexed_runner_rejects_changed_exact_config(tmp_path, monkeypatch):\n+    args = runner_args(tmp_path)\n+    prepared = {\"suite\": smoke.ORACLE_SUITE, \"repositories\": []}\n+    monkeypatch.setattr(smoke.runtime, \"executable_binding\", lambda *_args: {\"sha256\": \"fixture\"})\n+    monkeypatch.setattr(smoke, \"summarize\", lambda *_args, **_kwargs: {\"ok\": True})\n+    output = tmp_path / \"output\"\n+    smoke.run(prepared, output, args)\n+    args.graph_source_head = \"b\" * 40\n+    with pytest.raises(smoke.SmokeError, match=\"configuration differs\"):\n+        smoke.run(prepared, output, args)\n+\n+\n+def test_preindexed_runner_rejects_parallel_workers(tmp_path):\n+    args = runner_args(tmp_path)\n+    args.workers = 2\n+    with pytest.raises(smoke.SmokeError, match=\"workers 1\"):\n+        smoke.run({\"suite\": smoke.ORACLE_SUITE, \"repositories\": []}, tmp_path / \"output\", args)\n+\n+\n+def test_invalid_treatment_aborts_before_next_paid_attempt(tmp_path, monkeypatch):\n+    args = runner_args(tmp_path)\n+    prepared = {\n+        \"suite\": smoke.ORACLE_SUITE,\n+        \"repositories\": [{\n+            \"repository\": \"example/repo\",\n+            \"system_order\": [\"entire-graph\", \"entire-graph\", \"entire-graph\"],\n+        }],\n+    }\n+    launches = []\n+    monkeypatch.setattr(smoke.runtime, \"executable_binding\", lambda *_args: {\"sha256\": \"fixture\"})\n+    monkeypatch.setattr(\n+        smoke, \"load_or_setup_treatment_index\",\n+        lambda *_args, **_kwargs: {\"record_sha256\": \"setup\"},\n+    )\n+    monkeypatch.setattr(smoke, \"recover_existing_attempt\", lambda *_args, **_kwargs: None)\n+\n+    def fail_once(*_args, **_kwargs):\n+        launches.append(True)\n+        raise smoke.SmokeError(\"timed treatment protocol violation\")\n+\n+    monkeypatch.setattr(smoke, \"execute_one\", fail_once)\n+    with pytest.raises(smoke.SmokeError, match=\"protocol violation\"):\n+        smoke.run(prepared, tmp_path / \"output\", args)\n+    assert launches == [True]\n+\n+\n+def test_recovery_refuses_started_attempt_without_transcript(tmp_path):\n+    repository = {\"execution_index\": 1, \"repository\": \"example/repo\"}\n+    record_root = tmp_path / \"records\" / \"repo-01\" / \"entire-graph\"\n+    smoke.canonical_write(record_root / \"attempt-start.json\", {\"schema_version\": 1})\n+    with pytest.raises(smoke.SmokeError, match=\"no recoverable transcript\"):\n+        smoke.recover_existing_attempt(\n+            repository, \"entire-graph\", tmp_path,\n+            claude=Path(\"/runtime/claude\"), graph=Path(\"/runtime/graph\"),\n+            cbm=Path(\"/runtime/cbm\"), runtime_path_prefix=\"\",\n+            execution_config_sha256=\"config\", model=\"opus\", max_turns=4,\n+            max_budget_usd=1.0,\n+        )\n+\n+\n+def test_rescore_refuses_legacy_evidence_without_mutation(tmp_path):\n+    output = tmp_path / \"output\"\n+    source = b'{\"schema_version\":1}\\n'\n+    output.mkdir()\n+    (output / \"execution-config.json\").write_bytes(source)\n+    with pytest.raises(smoke.SmokeError, match=\"legacy evidence directory\"):\n+        smoke.rescore({\"repositories\": []}, output)\n+    assert (output / \"execution-config.json\").read_bytes() == source\n+\n+\n def test_prompt_defines_file_level_and_imported_path_semantics():\n","move_path":null}},"status":"completed"}}
